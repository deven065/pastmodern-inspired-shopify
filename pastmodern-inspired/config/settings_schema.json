[
  {
    "name": "theme_info",
    "theme_name": "Pastmodern",
    "theme_version": "1.0.0",
    "theme_author": "Pastmodern Studio",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "work_sans_n4",
        "label": "Body font",
        "info": "Clean readable sans-serif. Work Sans recommended."
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "cormorant_n4",
        "label": "Display / heading font",
        "info": "Refined serif for editorial headlines. Cormorant recommended."
      },
      {
        "type": "range",
        "id": "heading_scale",
        "label": "Heading size scale",
        "min": 0.8,
        "max": 1.2,
        "step": 0.1,
        "default": 1.0,
        "info": "Scales all display headings (h1, h2, h3) proportionally."
      },
      {
        "type": "select",
        "id": "body_font_size",
        "label": "Body text size",
        "options": [
          {
            "value": "0.8125rem",
            "label": "Small \u2014 13px"
          },
          {
            "value": "0.9375rem",
            "label": "Medium \u2014 15px"
          },
          {
            "value": "1rem",
            "label": "Standard \u2014 16px"
          }
        ],
        "default": "0.9375rem",
        "info": "Base size for body copy and UI text."
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "default": "#F7F3EC",
        "label": "Background",
        "info": "Ivory Mist — the Sulu Luxe canvas."
      },
      {
        "type": "color",
        "id": "color_text",
        "default": "#1E1D1A",
        "label": "Text",
        "info": "Charcoal Ink — soft warm-black, elegant against ivory."
      },
      {
        "type": "color",
        "id": "color_accent",
        "default": "#214630",
        "label": "Accent",
        "info": "Deep Emerald — used on buttons, selected states, footer. Heritage Green (#2B5F41) is the hover state."
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "page_width",
        "label": "Maximum content width",
        "options": [
          {
            "value": "80rem",
            "label": "Narrow \u2014 1280px"
          },
          {
            "value": "90rem",
            "label": "Standard \u2014 1440px"
          },
          {
            "value": "105rem",
            "label": "Wide \u2014 1680px"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "page_margin",
        "min": 16,
        "max": 80,
        "step": 4,
        "unit": "px",
        "label": "Page margin",
        "default": 24,
        "info": "Minimum space between content and the viewport edge."
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "min": 60,
        "max": 280,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 140,
        "info": "Maximum display width for the header logo image."
      },
      {
        "type": "select",
        "id": "section_spacing",
        "label": "Section spacing",
        "options": [
          {
            "value": "compact",
            "label": "Compact"
          },
          {
            "value": "comfortable",
            "label": "Comfortable"
          },
          {
            "value": "generous",
            "label": "Generous"
          }
        ],
        "default": "compact",
        "info": "Vertical breathing room between page sections."
      },
      {
        "type": "range",
        "id": "input_radius",
        "min": 0,
        "max": 8,
        "step": 1,
        "unit": "px",
        "label": "Input border radius",
        "default": 0
      },
      {
        "type": "checkbox",
        "id": "enable_cart_drawer",
        "label": "Enable cart drawer",
        "default": true
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "checkbox",
        "id": "header_sticky",
        "label": "Sticky header",
        "default": true,
        "info": "Header remains fixed to the top while scrolling."
      },
      {
        "type": "select",
        "id": "header_logo_position",
        "label": "Logo alignment",
        "options": [
          {
            "value": "left",
            "label": "Left"
          },
          {
            "value": "center",
            "label": "Center"
          }
        ],
        "default": "center"
      }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      {
        "type": "select",
        "id": "button_style",
        "label": "Button corner style",
        "options": [
          {
            "value": "sharp",
            "label": "Sharp \u2014 0px (luxury)"
          },
          {
            "value": "soft",
            "label": "Soft \u2014 2px"
          },
          {
            "value": "rounded",
            "label": "Rounded \u2014 6px"
          }
        ],
        "default": "sharp",
        "info": "Applies to all primary, secondary, and ghost buttons."
      }
    ]
  },
  {
    "name": "Conversion",
    "settings": [
      {
        "type": "range",
        "id": "free_shipping_threshold",
        "label": "Free shipping threshold",
        "min": 0,
        "max": 1000,
        "step": 25,
        "unit": "USD",
        "default": 200
      },
      {
        "type": "collection",
        "id": "cart_cross_sell_collection",
        "label": "Cart cross-sell collection"
      },
      {
        "type": "checkbox",
        "id": "enable_welcome_capture",
        "label": "Enable first-session welcome capture",
        "default": true
      },
      {
        "type": "text",
        "id": "welcome_incentive_label",
        "label": "Welcome incentive label",
        "default": "Unlock complimentary first-order shipping"
      },
      {
        "type": "text",
        "id": "welcome_heading",
        "label": "Welcome heading",
        "default": "Make your first order feel easier"
      },
      {
        "type": "textarea",
        "id": "welcome_subtext",
        "label": "Welcome message",
        "default": "Join the private list for complimentary first-order shipping, early access to new drops, and the pieces that usually move first."
      },
      {
        "type": "text",
        "id": "welcome_button_label",
        "label": "Welcome button label",
        "default": "Unlock access"
      },
      {
        "type": "text",
        "id": "welcome_success_message",
        "label": "Welcome success message",
        "default": "You're in. Watch your inbox for early access and shipping perks."
      },
      {
        "type": "textarea",
        "id": "welcome_fine_print",
        "label": "Welcome fine print",
        "default": "By subscribing, you agree to receive marketing emails. No hard discounts. Just first access, soft perks, and the pieces that move fastest."
      },
      {
        "type": "text",
        "id": "proof_item_1_label",
        "label": "Proof item 1 label",
        "default": "Dispatch"
      },
      {
        "type": "text",
        "id": "proof_item_1_text",
        "label": "Proof item 1 text",
        "default": "Ships in 3–5 business days."
      },
      {
        "type": "text",
        "id": "proof_item_2_label",
        "label": "Proof item 2 label",
        "default": "Returns"
      },
      {
        "type": "text",
        "id": "proof_item_2_text",
        "label": "Proof item 2 text",
        "default": "Easy exchanges and returns within 30 days."
      },
      {
        "type": "text",
        "id": "proof_item_3_label",
        "label": "Proof item 3 label",
        "default": "Craft"
      },
      {
        "type": "text",
        "id": "proof_item_3_text",
        "label": "Proof item 3 text",
        "default": "Small-batch pieces with premium finishing."
      },
      {
        "type": "url",
        "id": "shipping_policy_url",
        "label": "Shipping policy URL"
      },
      {
        "type": "url",
        "id": "returns_policy_url",
        "label": "Returns policy URL"
      },
      {
        "type": "url",
        "id": "size_help_url",
        "label": "Size guide URL"
      },
      {
        "type": "url",
        "id": "support_url",
        "label": "Support link URL"
      },
      {
        "type": "text",
        "id": "support_label",
        "label": "Support link label",
        "default": "Need styling help?"
      }
    ]
  }
]
