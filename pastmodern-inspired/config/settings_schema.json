[
  {
    "name": "theme_info",
    "theme_name": "Pastmodern",
    "theme_version": "1.0.0",
    "theme_author": "Pastmodern",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "work_sans_n4",
        "label": "Body font"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "cormorant_n4",
        "label": "Heading font"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "default": "#F5F4F0",
        "label": "Background"
      },
      {
        "type": "color",
        "id": "color_text",
        "default": "#1A1A1A",
        "label": "Text"
      },
      {
        "type": "color",
        "id": "color_accent",
        "default": "#8B7355",
        "label": "Accent",
        "info": "Used for sale prices, highlights, and hover states."
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "page_width",
        "label": "Page width",
        "options": [
          { "value": "80rem", "label": "Narrow (1280px)" },
          { "value": "90rem", "label": "Standard (1440px)" },
          { "value": "105rem", "label": "Wide (1680px)" }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "page_margin",
        "min": 16,
        "max": 80,
        "step": 4,
        "unit": "px",
        "label": "Page margin",
        "default": 24
      },
      {
        "type": "range",
        "id": "input_radius",
        "min": 0,
        "max": 12,
        "step": 1,
        "unit": "px",
        "label": "Input corner radius",
        "default": 0
      },
      {
        "type": "checkbox",
        "id": "enable_cart_drawer",
        "label": "Enable cart drawer",
        "default": true
      }
    ]
  }
]
