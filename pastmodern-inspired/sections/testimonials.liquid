{%- liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign cols    = section.settings.columns
-%}

<div class="testimonials" style="--t-cols: {{ cols }};">

  {%- comment -%} ── Section header ── {%- endcomment -%}
  {%- if eyebrow != blank or heading != blank -%}
    <div class="testimonials__header">
      {%- if eyebrow != blank -%}
        <p class="eyebrow">{{ eyebrow }}</p>
      {%- endif -%}
      {%- if heading != blank -%}
        <h2 class="testimonials__heading">{{ heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Quote grid ── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <ul class="testimonials__grid" role="list">
      {%- for block in section.blocks -%}
        {%- assign quote_text   = block.settings.text -%}
        {%- assign quote_author = block.settings.author -%}
        {%- assign quote_loc    = block.settings.location -%}
        <li class="testimonial reveal" {{ block.shopify_attributes }}>
          <blockquote class="testimonial__quote">
            <p class="testimonial__mark" aria-hidden="true">“</p>
            {%- if quote_text != blank -%}
              <p class="testimonial__text">{{ quote_text | escape }}</p>
            {%- endif -%}
            {%- if quote_author != blank -%}
              <footer class="testimonial__footer">
                <span class="testimonial__rule" aria-hidden="true"></span>
                <div class="testimonial__attribution">
                  <cite class="testimonial__author">{{ quote_author | escape }}</cite>
                  {%- if quote_loc != blank -%}
                    <span class="testimonial__location">{{ quote_loc | escape }}</span>
                  {%- endif -%}
                </div>
              </footer>
            {%- endif -%}
          </blockquote>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

</div>

{% stylesheet %}
  /* ── Wrapper ────────────────────────────────────────────── */
  .testimonials {
    display: flex;
    flex-direction: column;
    gap: var(--space-14);
  }

  /* ── Header ─────────────────────────────────────────────── */
  .testimonials__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
    text-align: center;
  }

  .testimonials__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-style: italic;
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  /* ── Grid ───────────────────────────────────────────────── */
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(var(--t-cols, 3), 1fr);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: start;
  }

  /* ── Individual testimonial ──────────────────────────────── */
  .testimonial {
    padding-block: var(--space-10);
    border-block-start: 1px solid var(--color-border);
  }

  /* Column dividers */
  .testimonial + .testimonial {
    border-inline-start: 1px solid var(--color-border);
    padding-inline-start: var(--space-8);
  }

  .testimonial:first-child {
    padding-inline-start: 0;
  }

  .testimonials__grid .testimonial:not(:first-child) {
    padding-inline-start: var(--space-8);
  }

  /* ── Blockquote ──────────────────────────────────────────── */
  .testimonial__quote {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin: 0;
  }

  /* ── Large decorative opening quote mark ─────────────────── */
  .testimonial__mark {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 5rem;
    line-height: 0.75;
    color: var(--color-border);
    margin: 0 0 var(--space-3);
    user-select: none;
    pointer-events: none;
  }

  /* ── Quote text ──────────────────────────────────────────── */
  .testimonial__text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(var(--text-md), 1.5vw, var(--text-lg));
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0;
  }

  /* ── Attribution ─────────────────────────────────────────── */
  .testimonial__footer {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-block-start: var(--space-4);
  }

  .testimonial__rule {
    display: block;
    width: 1.75rem;
    height: 1px;
    background-color: var(--color-border);
    flex-shrink: 0;
  }

  .testimonial__attribution {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonial__author {
    font-style: normal;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text);
  }

  .testimonial__location {
    display: block;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
  }

  /* ── Mobile: single column ───────────────────────────────── */
  @media (max-width: 62rem) {
    .testimonials__grid {
      grid-template-columns: 1fr;
    }

    .testimonial + .testimonial {
      border-inline-start: none;
      padding-inline-start: 0;
    }

    .testimonials__grid .testimonial:not(:first-child) {
      padding-inline-start: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "placeholder": "Client voices"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our clients say"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Quote",
          "default": "An extraordinary piece. The quality speaks for itself."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Name",
          "default": "A. Client"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "placeholder": "London"
        }
      ]
    }
  ],
  "presets": [
    {
