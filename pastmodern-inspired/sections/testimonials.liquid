{%- liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign cols    = section.settings.columns
-%}

<div class="testimonials" style="--t-cols: {{ cols }};">

  {%- comment -%} ── Section header ── {%- endcomment -%}
  {%- if eyebrow != blank or heading != blank -%}
    <div class="testimonials__header">
      {%- if eyebrow != blank -%}
        <p class="eyebrow">{{ eyebrow }}</p>
      {%- endif -%}
      {%- if heading != blank -%}
        <h2 class="testimonials__heading">{{ heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Quote grid ── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <ul class="testimonials__grid" role="list">
      {%- for block in section.blocks -%}
        {%- assign quote_text   = block.settings.text -%}
        {%- assign quote_author = block.settings.author -%}
        {%- assign quote_loc    = block.settings.location -%}
        {%- assign show_stars   = block.settings.show_stars -%}
        <li class="testimonial" {{ block.shopify_attributes }}>
          {%- if show_stars -%}
            <p class="testimonial__stars" aria-label="5 out of 5 stars" role="img">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="12" height="12"><path d="M12 2l2.9 6.3L22 9.5l-5 5 1.2 7L12 18l-6.2 3.5L7 14.5 2 9.5l7.1-1.2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="12" height="12"><path d="M12 2l2.9 6.3L22 9.5l-5 5 1.2 7L12 18l-6.2 3.5L7 14.5 2 9.5l7.1-1.2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="12" height="12"><path d="M12 2l2.9 6.3L22 9.5l-5 5 1.2 7L12 18l-6.2 3.5L7 14.5 2 9.5l7.1-1.2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="12" height="12"><path d="M12 2l2.9 6.3L22 9.5l-5 5 1.2 7L12 18l-6.2 3.5L7 14.5 2 9.5l7.1-1.2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="12" height="12"><path d="M12 2l2.9 6.3L22 9.5l-5 5 1.2 7L12 18l-6.2 3.5L7 14.5 2 9.5l7.1-1.2z"/></svg>
            </p>
          {%- endif -%}

          <blockquote class="testimonial__quote">
            {%- if quote_text != blank -%}
              <p class="testimonial__text">{{ quote_text | escape }}</p>
            {%- endif -%}
            {%- if quote_author != blank -%}
              <footer class="testimonial__attribution">
                <cite class="testimonial__author">{{ quote_author | escape }}</cite>
                {%- if quote_loc != blank -%}
                  <span class="testimonial__location">{{ quote_loc | escape }}</span>
                {%- endif -%}
              </footer>
            {%- endif -%}
          </blockquote>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

</div>

{% stylesheet %}
  /* ── Wrapper ───────────────────────────────────────────────── */
  .testimonials {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    text-align: center;
  }

  /* ── Header ────────────────────────────────────────────────── */
  .testimonials__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
  }

  .testimonials__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-style: italic;
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  /* ── Grid ──────────────────────────────────────────────────── */
  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(var(--t-cols, 3), 1fr);
    gap: var(--space-1) var(--space-10);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: start;
  }

  /* ── Individual card ───────────────────────────────────────── */
  .testimonial {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-block: var(--space-8);
    border-block-start: 1px solid var(--color-border);
  }

  /* ── Stars ─────────────────────────────────────────────────── */
  .testimonial__stars {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    margin: 0;
    color: var(--color-text);
  }

  /* ── Blockquote ────────────────────────────────────────────── */
  .testimonial__quote {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin: 0;
  }

  .testimonial__text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(var(--text-lg), 2vw, var(--text-xl));
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0;
  }

  /* ── Attribution ───────────────────────────────────────────── */
  .testimonial__attribution {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonial__author {
    font-style: normal;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text);
  }

  .testimonial__location {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
  }

  /* ── Mobile: single column ─────────────────────────────────── */
  @media (max-width: 48rem) {
    .testimonials__grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "placeholder": "Client voices"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our clients say"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Quote",
          "default": "An extraordinary piece. The quality speaks for itself."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Name",
          "default": "A. Client"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "placeholder": "London"
        },
        {
          "type": "checkbox",
          "id": "show_stars",
          "label": "Show star rating",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "settings": {
        "eyebrow":  "Client voices",
        "heading":  "What our clients say",
        "columns":  "3"
      },
      "blocks": [
        {
          "type": "quote",
          "settings": {
            "text":       "The quality exceeded every expectation. The fabric is extraordinary and the cut is simply perfect.",
            "author":     "Amelia R.",
            "location":   "London",
            "show_stars": true
          }
        },
        {
          "type": "quote",
          "settings": {
            "text":       "I wore this to a gallery opening and received compliments all evening. Effortlessly elegant.",
            "author":     "Isabelle C.",
            "location":   "Paris",
            "show_stars": true
          }
        },
        {
          "type": "quote",
          "settings": {
            "text":       "Beautifully packaged, thoughtfully made. This is what conscious luxury looks like.",
            "author":     "Sophia M.",
            "location":   "New York",
            "show_stars": true
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
