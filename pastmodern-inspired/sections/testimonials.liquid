{%- liquid
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign cols    = section.settings.columns
-%}

<div class="testimonials" style="--t-cols: {{ cols }};">

  {%- comment -%} ── Section header ── {%- endcomment -%}
  {%- if eyebrow != blank or heading != blank -%}
    <div class="testimonials__header">
      {%- if eyebrow != blank -%}
        <p class="eyebrow">{{ eyebrow }}</p>
      {%- endif -%}
      {%- if heading != blank -%}
        <h2 class="testimonials__heading">{{ heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Quote grid ── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <ul class="testimonials__grid" role="list">
      {%- for block in section.blocks -%}
        {%- assign quote_text   = block.settings.text -%}
        {%- assign quote_author = block.settings.author -%}
        {%- assign quote_loc    = block.settings.location -%}
        {%- assign quote_image  = block.settings.image -%}
        {%- assign quote_rating = block.settings.rating -%}
        {%- assign quote_fit    = block.settings.fit_note -%}
        {%- assign quote_product = block.settings.product_label -%}
        <li class="testimonial reveal" {{ block.shopify_attributes }}>
          <blockquote class="testimonial__quote">
            {%- if quote_image != blank -%}
              <div class="testimonial__media">
                {{
                  quote_image
                  | image_url: width: 240
                  | image_tag:
                      widths: '120, 180, 240',
                      sizes: '96px',
                      loading: 'lazy',
                      class: 'testimonial__image',
                      alt: quote_author | default: quote_product
                }}
              </div>
            {%- endif -%}

            {%- if quote_rating != blank or quote_fit != blank or quote_product != blank -%}
              <div class="testimonial__meta">
                {%- if quote_rating != blank -%}
                  <span class="testimonial__pill testimonial__pill--rating">
                    <svg class="testimonial__pill-star" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" focusable="false" width="10" height="10">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/>
                    </svg>
                    {{ quote_rating | escape }}
                  </span>
                {%- endif -%}
                {%- if quote_fit != blank -%}
                  <span class="testimonial__pill">{{ quote_fit | escape }}</span>
                {%- endif -%}
                {%- if quote_product != blank -%}
                  <span class="testimonial__pill">{{ quote_product | escape }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}

            <p class="testimonial__mark" aria-hidden="true">“</p>
            {%- if quote_text != blank -%}
              <p class="testimonial__text">{{ quote_text | escape }}</p>
            {%- endif -%}
            {%- if quote_author != blank -%}
              <footer class="testimonial__footer">
                <span class="testimonial__rule" aria-hidden="true"></span>
                <div class="testimonial__attribution">
                  <cite class="testimonial__author">{{ quote_author | escape }}</cite>
                  {%- if quote_loc != blank -%}
                    <span class="testimonial__location">{{ quote_loc | escape }}</span>
                  {%- endif -%}
                </div>
              </footer>
            {%- endif -%}
          </blockquote>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

</div>

{% stylesheet %}
  .testimonials {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .testimonials__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
    text-align: left;
    max-width: 38rem;
  }

  .testimonials__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-style: italic;
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: start;
  }

  .testimonial {
    min-height: 100%;
    padding: clamp(var(--space-6), 2.5vw, var(--space-8));
    border: 1px solid color-mix(in srgb, var(--color-gold) 20%, var(--color-border));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-bg) 78%, white) 0%, color-mix(in srgb, var(--color-bg) 96%, var(--color-bg-warm)) 100%);
    box-shadow: var(--shadow-soft);
    border-radius: 1.35rem;
  }

  .testimonial:first-child {
    grid-column: 1 / -1;
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--color-accent) 96%, black) 0%, color-mix(in srgb, var(--color-accent-soft) 88%, var(--color-accent)) 100%);
    color: #F8F4EA;
    border-color: color-mix(in srgb, var(--color-gold) 34%, transparent);
  }

  .testimonial:nth-child(2) {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-mint) 22%, white) 0%, color-mix(in srgb, var(--color-bg) 96%, white) 100%);
  }

  .testimonial:nth-child(3) {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-gold) 12%, white) 0%, color-mix(in srgb, var(--color-bg) 96%, white) 100%);
  }

  /* ── Blockquote ──────────────────────────────────────────── */
  .testimonial__quote {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin: 0;
  }

  .testimonial__media {
    width: 5.5rem;
    height: 6.75rem;
    overflow: hidden;
    border-radius: 1rem;
    background-color: color-mix(in srgb, var(--color-bg) 84%, white);
    border: 1px solid color-mix(in srgb, var(--color-gold) 18%, var(--color-border));
  }

  .testimonial__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center top;
  }

  .testimonial__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .testimonial__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    background-color: color-mix(in srgb, var(--color-bg) 86%, white);
    border: 1px solid color-mix(in srgb, var(--color-gold) 18%, var(--color-border));
    font-size: 0.5625rem;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text);
  }

  .testimonial__pill-star {
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .testimonial__mark {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(4rem, 6vw, 7rem);
    line-height: 0.65;
    color: var(--color-gold);
    opacity: 0.45;
    margin: 0 0 var(--space-4);
    user-select: none;
    pointer-events: none;
  }

  .testimonial__text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(var(--text-lg), 1.8vw, var(--text-xl));
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    margin: 0;
  }

  .testimonial:first-child .testimonial__text,
  .testimonial:first-child .testimonial__author {
    color: #F8F4EA;
  }

  .testimonial:first-child .testimonial__location {
    color: color-mix(in srgb, #F8F4EA 64%, transparent);
  }

  .testimonial:first-child .testimonial__rule {
    background-color: color-mix(in srgb, var(--color-gold) 55%, transparent);
  }

  .testimonial__footer {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-block-start: var(--space-4);
  }

  .testimonial__rule {
    display: block;
    width: 1.75rem;
    height: 1px;
    background-color: var(--color-border);
    flex-shrink: 0;
  }

  .testimonial__attribution {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .testimonial__author {
    font-style: normal;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-brand, 0.18em);
    text-transform: uppercase;
    color: var(--color-text);
  }

  .testimonial__location {
    display: block;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
  }

  @media (max-width: 62rem) {
    .testimonials__grid {
      grid-template-columns: 1fr;
    }

    .testimonial:first-child {
      grid-column: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "placeholder": "Client voices"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our clients say"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "UGC image"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Quote",
          "default": "An extraordinary piece. The quality speaks for itself."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Name",
          "default": "A. Client"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "placeholder": "London"
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Rating label",
          "placeholder": "4.9 / 5"
        },
        {
          "type": "text",
          "id": "fit_note",
          "label": "Fit note",
          "placeholder": "True to size"
        },
        {
          "type": "text",
          "id": "product_label",
          "label": "Product label",
          "placeholder": "Ruched Mini Dress"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "settings": {
        "eyebrow":  "Client voices",
        "heading":  "What our clients say",
        "columns":  "3"
      },
      "blocks": [
        {
          "type": "quote",
          "settings": {
            "text":     "The quality exceeded every expectation. The fabric is extraordinary and the cut is simply perfect.",
            "author":   "Amelia R.",
            "location": "London"
          }
        },
        {
          "type": "quote",
          "settings": {
            "text":     "I wore this to a gallery opening and received compliments all evening. Effortlessly elegant.",
            "author":   "Isabelle C.",
            "location": "Paris"
          }
        },
        {
          "type": "quote",
          "settings": {
            "text":     "Beautifully packaged, thoughtfully made. This is what conscious luxury looks like.",
            "author":   "Sophia M.",
            "location": "New York"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
