{%- liquid
  assign ig_eyebrow = section.settings.eyebrow
  assign ig_heading = section.settings.heading
  assign ig_text = section.settings.text
  assign ig_handle = section.settings.handle | default: '@sulu_luxe'
  assign ig_cta_label = section.settings.cta_label | default: 'Follow on Instagram'
  assign ig_cta_url = section.settings.cta_url
-%}

<section class="instagram-showcase">
  <div class="instagram-showcase__panel">
    <div class="instagram-showcase__intro">
      {%- if ig_eyebrow != blank -%}
        <p class="eyebrow instagram-showcase__eyebrow">{{ ig_eyebrow | escape }}</p>
      {%- endif -%}

      {%- if ig_heading != blank -%}
        <h2 class="instagram-showcase__heading">{{ ig_heading }}</h2>
      {%- endif -%}

      {%- if ig_text != blank -%}
        <p class="instagram-showcase__text">{{ ig_text }}</p>
      {%- endif -%}

      <div class="instagram-showcase__signals" aria-label="Instagram proof">
        <span class="instagram-showcase__signal">Real styling cues</span>
        <span class="instagram-showcase__signal">Fit and finish detail</span>
        <span class="instagram-showcase__signal">Drop previews</span>
      </div>
    </div>

    <div class="instagram-showcase__profile-card">
      <div class="instagram-showcase__profile-topline">
        <span class="instagram-showcase__profile-badge">Instagram</span>
        <span class="instagram-showcase__profile-handle">{{ ig_handle | escape }}</span>
      </div>

      <p class="instagram-showcase__profile-copy">
        Real styling, event dressing in motion, and closer product detail that helps first-time visitors trust the collection beyond the PDP.
      </p>

      <div class="instagram-showcase__profile-points" aria-hidden="true">
        <span class="instagram-showcase__profile-point">Styled away from the studio</span>
        <span class="instagram-showcase__profile-point">Closer finish and fabric views</span>
        <span class="instagram-showcase__profile-point">A more human feel for the brand</span>
      </div>

      <a href="{{ ig_cta_url | default: 'https://www.instagram.com/sulu_luxe/' }}" class="btn btn-secondary instagram-showcase__cta" target="_blank" rel="noopener noreferrer">
        {{ ig_cta_label }}
      </a>
    </div>
  </div>

  <div class="instagram-showcase__grid" role="list">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <article class="instagram-post instagram-post--{{ forloop.index }}" role="listitem" {{ block.shopify_attributes }}>
          <a
            href="{{ block.settings.post_url | default: ig_cta_url | default: 'https://www.instagram.com/sulu_luxe/' }}"
            class="instagram-post__link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="{{ block.settings.caption | default: ig_handle | escape }}"
          >
            <div class="instagram-post__media">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 900
                  | image_tag:
                      widths: '280, 420, 560, 720, 900',
                      sizes: '(max-width: 48rem) 100vw, 28vw',
                      loading: 'lazy',
                      class: 'instagram-post__image',
                      alt: block.settings.caption | default: ig_handle | escape
                }}
              {%- else -%}
                <div class="instagram-post__placeholder" aria-hidden="true">
                  <span class="instagram-post__placeholder-chip">{{ block.settings.label | default: 'Instagram edit' | escape }}</span>
                  <span class="instagram-post__placeholder-mark">{{ ig_handle | escape }}</span>
                </div>
              {%- endif -%}
            </div>

            <div class="instagram-post__overlay">
              {%- if block.settings.label != blank -%}
                <span class="instagram-post__label">{{ block.settings.label | escape }}</span>
              {%- endif -%}
              {%- if block.settings.caption != blank -%}
                <p class="instagram-post__caption">{{ block.settings.caption | escape }}</p>
              {%- endif -%}
            </div>
          </a>
        </article>
      {%- endfor -%}
    {%- else -%}
      {%- assign fallback_labels = 'Bridal details,Occasionwear in motion,Behind the seams,Best-seller styling' | split: ',' -%}
      {%- for fallback in fallback_labels -%}
        <article class="instagram-post instagram-post--{{ forloop.index }}" role="listitem">
          <a
            href="{{ ig_cta_url | default: 'https://www.instagram.com/sulu_luxe/' }}"
            class="instagram-post__link"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="{{ fallback | escape }}"
          >
            <div class="instagram-post__media">
              <div class="instagram-post__placeholder" aria-hidden="true">
                <span class="instagram-post__placeholder-chip">{{ fallback | escape }}</span>
                <span class="instagram-post__placeholder-mark">{{ ig_handle | escape }}</span>
              </div>
            </div>
            <div class="instagram-post__overlay">
              <span class="instagram-post__label">Instagram edit</span>
              <p class="instagram-post__caption">{{ fallback | escape }}</p>
            </div>
          </a>
        </article>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .instagram-showcase {
    display: flex;
    flex-direction: column;
    gap: clamp(var(--space-6), 4vw, var(--space-10));
    align-items: start;
    position: relative;
  }

  .instagram-showcase::before {
    content: '';
    position: absolute;
    inset: -3rem auto auto -3rem;
    width: 16rem;
    height: 16rem;
    border-radius: 999px;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-gold) 16%, transparent) 0%, transparent 72%);
    pointer-events: none;
    z-index: 0;
  }

  .instagram-showcase::after {
    content: '';
    position: absolute;
    inset: auto -2rem 3rem auto;
    width: 22rem;
    height: 22rem;
    border-radius: 999px;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-accent-soft) 10%, transparent) 0%, transparent 72%);
    pointer-events: none;
    z-index: 0;
  }

  .instagram-showcase__panel,
  .instagram-showcase__intro,
  .instagram-showcase__grid {
    position: relative;
    z-index: 1;
  }

  .instagram-showcase__panel {
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(19rem, 0.9fr);
    gap: clamp(var(--space-5), 4vw, var(--space-10));
    padding: clamp(var(--space-6), 4vw, var(--space-10));
    border: 1px solid color-mix(in srgb, var(--color-gold) 22%, var(--color-border));
    border-radius: 1.8rem;
    background:
      linear-gradient(140deg, color-mix(in srgb, var(--color-bg) 96%, white) 0%, color-mix(in srgb, var(--color-bg-warm) 90%, white) 54%, color-mix(in srgb, var(--color-gold) 8%, var(--color-bg)) 100%);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }

  .instagram-showcase__panel::before {
    content: '';
    position: absolute;
    inset: 1rem;
    border-radius: 1.25rem;
    border: 1px solid color-mix(in srgb, var(--color-gold) 18%, transparent);
    pointer-events: none;
  }

  .instagram-showcase__intro {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-5);
    min-width: 0;
  }

  .instagram-showcase__eyebrow,
  .instagram-showcase__heading,
  .instagram-showcase__text {
    margin: 0;
  }

  .instagram-showcase__heading {
    max-width: 12ch;
    font-size: clamp(var(--text-3xl), 5vw, 4.75rem);
  }

  .instagram-showcase__text {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 50ch;
  }

  .instagram-showcase__profile-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    justify-content: center;
    min-height: 100%;
    padding: clamp(var(--space-6), 2.5vw, var(--space-8));
    border: 1px solid color-mix(in srgb, var(--color-gold) 26%, var(--color-border));
    border-radius: 1.4rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-bg) 82%, white) 0%, color-mix(in srgb, var(--color-bg) 95%, var(--color-bg-warm)) 100%);
    box-shadow: var(--shadow-soft);
  }

  .instagram-showcase__profile-card::before {
    content: '';
    position: absolute;
    inset: auto -3rem -3rem auto;
    width: 11rem;
    height: 11rem;
    border-radius: 999px;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-gold) 18%, transparent) 0%, transparent 72%);
    pointer-events: none;
  }

  .instagram-showcase__profile-topline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }

  .instagram-showcase__profile-badge,
  .instagram-showcase__profile-handle {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    font-size: 0.625rem;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }

  .instagram-showcase__profile-badge {
    background-color: var(--color-accent);
    color: #F8F4EA;
  }

  .instagram-showcase__profile-handle {
    border: 1px solid color-mix(in srgb, var(--color-gold) 24%, var(--color-border));
    color: var(--color-text);
  }

  .instagram-showcase__profile-copy {
    margin: 0;
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 32ch;
  }

  .instagram-showcase__signals {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .instagram-showcase__signal {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-gold) 20%, var(--color-border));
    background-color: color-mix(in srgb, var(--color-gold) 5%, white);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    color: var(--color-text);
  }

  .instagram-showcase__profile-points {
    display: grid;
    gap: var(--space-2);
  }

  .instagram-showcase__profile-point {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.65rem;
    align-items: start;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .instagram-showcase__profile-point::before {
    content: '';
    width: 0.45rem;
    height: 0.45rem;
    margin-top: 0.45rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-gold) 70%, var(--color-accent));
    box-shadow: 0 0 0 0.2rem color-mix(in srgb, var(--color-gold) 12%, transparent);
  }

  .instagram-showcase__cta {
    align-self: flex-start;
  }

  .instagram-showcase__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(var(--space-4), 3vw, var(--space-5));
    width: 100%;
  }

  .instagram-post {
    min-width: 0;
  }

  .instagram-post__link {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    height: 100%;
    overflow: hidden;
    border-radius: 1.4rem;
    text-decoration: none;
    color: inherit;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-bg) 84%, white) 0%, color-mix(in srgb, var(--color-bg) 98%, var(--color-bg-warm)) 100%);
    border: 1px solid color-mix(in srgb, var(--color-gold) 18%, var(--color-border));
    box-shadow: var(--shadow-soft);
    transition:
      transform var(--duration-base) var(--ease-default),
      box-shadow var(--duration-base) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default);
  }

  .instagram-post__link:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--color-gold) 46%, var(--color-border));
    box-shadow: var(--shadow-card);
    color: inherit;
  }

  .instagram-post__media {
    position: relative;
    min-height: 21rem;
    background-color: color-mix(in srgb, var(--color-bg) 92%, white);
  }

  .instagram-post__image,
  .instagram-post__media > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .instagram-post__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-5);
    overflow: hidden;
    background:
      radial-gradient(circle at 16% 18%, color-mix(in srgb, var(--color-gold) 26%, transparent) 0%, transparent 24%),
      radial-gradient(circle at 82% 18%, rgba(247, 243, 236, 0.12) 0%, transparent 28%),
      linear-gradient(160deg, color-mix(in srgb, var(--color-accent) 96%, black) 0%, color-mix(in srgb, var(--color-accent-soft) 90%, var(--color-accent)) 100%);
  }

  .instagram-post__placeholder::before {
    content: '';
    position: absolute;
    inset: 1rem;
    border: 1px solid rgba(247, 243, 236, 0.18);
    border-radius: 1rem;
  }

  .instagram-post__placeholder::after {
    content: '';
    position: absolute;
    top: 1.35rem;
    right: 1.35rem;
    width: min(42%, 10rem);
    aspect-ratio: 0.82;
    border-radius: 1.15rem;
    border: 1px solid rgba(247, 243, 236, 0.16);
    background:
      linear-gradient(180deg, rgba(247, 243, 236, 0.16) 0%, rgba(247, 243, 236, 0.04) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 1.25rem 2rem rgba(0, 0, 0, 0.14);
    transform: rotate(8deg);
    transform-origin: center;
  }

  .instagram-post__placeholder-chip {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    width: fit-content;
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    border: 1px solid rgba(247, 243, 236, 0.18);
    background: rgba(247, 243, 236, 0.08);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: rgba(247, 243, 236, 0.84);
    backdrop-filter: blur(8px);
  }

  .instagram-post__placeholder-mark {
    position: relative;
    z-index: 1;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(var(--text-xl), 3vw, var(--text-3xl));
    line-height: 1;
    color: rgba(247, 243, 236, 0.88);
    max-width: 10ch;
    text-shadow: 0 0.35rem 1.25rem rgba(0, 0, 0, 0.18);
  }

  .instagram-post__overlay {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-5) var(--space-5);
  }

  .instagram-post__label {
    font-size: 0.625rem;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .instagram-post__caption {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(var(--text-lg), 2vw, var(--text-xl));
    font-style: italic;
    line-height: var(--leading-snug);
    color: var(--color-text);
  }

  @media (max-width: 64rem) {
    .instagram-showcase__panel {
      grid-template-columns: 1fr;
    }

    .instagram-showcase__intro {
      max-width: none;
    }

    .instagram-showcase__heading,
    .instagram-showcase__text,
    .instagram-showcase__profile-copy {
      max-width: none;
    }
  }

  @media (max-width: 48rem) {
    .instagram-showcase__grid {
      grid-template-columns: 1fr;
    }

    .instagram-showcase__panel {
      padding: var(--space-5);
    }

    .instagram-post__media {
      min-height: 24rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Instagram showcase",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Seen on Instagram"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A closer look at @sulu_luxe"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Style notes, behind-the-scenes moments, and real-life wear that make the brand feel richer before the first order."
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Instagram handle",
      "default": "@sulu_luxe"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Follow on Instagram"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Instagram profile URL"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Instagram post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "post_url",
          "label": "Post URL"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Small label",
          "default": "Instagram edit"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Styled for real plans"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Instagram showcase",
      "blocks": [
        {
          "type": "post",
          "settings": {
            "label": "Bridal details",
            "caption": "Closer detail for the pieces that get saved first"
          }
        },
        {
          "type": "post",
          "settings": {
            "label": "Occasionwear",
            "caption": "Event dressing in motion, beyond the product grid"
          }
        },
        {
          "type": "post",
          "settings": {
            "label": "Behind the seams",
            "caption": "A more human look at craft, finish, and fit"
          }
        },
        {
          "type": "post",
          "settings": {
            "label": "Best sellers",
            "caption": "How the strongest silhouettes land in real life"
          }
        }
      ]
    }
  ]
}
{% endschema %}
