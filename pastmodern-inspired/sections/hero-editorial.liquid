{%- liquid
  assign desktop_image  = section.settings.desktop_image
  assign mobile_image   = section.settings.mobile_image | default: desktop_image
  assign align          = section.settings.text_align
  assign overlay        = section.settings.overlay_opacity | divided_by: 100.0
  assign min_height_desk = section.settings.min_height_desktop
  assign min_height_mob  = section.settings.min_height_mobile
  assign text_color      = section.settings.text_color
  assign eyebrow         = section.settings.eyebrow
  assign heading         = section.settings.heading
  assign subtext         = section.settings.subtext
  assign cta1_label      = section.settings.cta1_label
  assign cta1_url        = section.settings.cta1_url
  assign cta2_label      = section.settings.cta2_label
  assign cta2_url        = section.settings.cta2_url
  assign season_label    = section.settings.season_label
  assign show_scroll     = section.settings.show_scroll_indicator
  assign feature_1       = section.settings.feature_1
  assign feature_2       = section.settings.feature_2
  assign feature_3       = section.settings.feature_3
  assign spotlight_heading = section.settings.spotlight_heading
  assign spotlight_text    = section.settings.spotlight_text
-%}

<div
  class="hero"
  data-text-align="{{ align }}"
  style="
    --hero-min-h-desk: {{ min_height_desk }}px;
    --hero-min-h-mob:  {{ min_height_mob }}px;
    --hero-overlay:    {{ overlay }};
    --hero-text:       {{ text_color }};
  "
>
  {%- comment -%} ── Background images ── {%- endcomment -%}
  <div class="hero__media" aria-hidden="true">
    {%- if desktop_image != blank -%}
      {{
        desktop_image
        | image_url: width: 2400
        | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '100vw',
            widths: '600, 900, 1200, 1600, 2000, 2400',
            class: 'hero__img hero__img--desktop',
            alt: desktop_image.alt | default: heading
      }}
    {%- else -%}
      <div class="hero__placeholder hero__img--desktop">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder-svg' }}
      </div>
    {%- endif -%}

    {%- if section.settings.mobile_image != blank -%}
      {{
        mobile_image
        | image_url: width: 1000
        | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '100vw',
            widths: '400, 600, 800, 1000',
            class: 'hero__img hero__img--mobile',
            alt: mobile_image.alt | default: heading
      }}
    {%- endif -%}

    <div class="hero__overlay"></div>
  </div>

  {%- comment -%} ── Season indicator (top right) ── {%- endcomment -%}
  {%- if season_label != blank -%}
    <p class="hero__season" aria-hidden="true">{{ season_label | escape }}</p>
  {%- endif -%}

  {%- comment -%} ── Content ── {%- endcomment -%}
  <div class="hero__content">
    {%- if eyebrow != blank -%}
      <p class="hero__eyebrow eyebrow">{{ eyebrow }}</p>
    {%- endif -%}

    {%- if heading != blank -%}
      <h1 class="hero__heading">{{ heading | newline_to_br }}</h1>
    {%- endif -%}

    {%- if subtext != blank -%}
      <p class="hero__subtext">{{ subtext }}</p>
    {%- endif -%}

    {%- if feature_1 != blank or feature_2 != blank or feature_3 != blank -%}
      <ul class="hero__capsules" role="list" aria-label="Shopping benefits">
        {%- if feature_1 != blank -%}
          <li class="hero__capsule">{{ feature_1 }}</li>
        {%- endif -%}
        {%- if feature_2 != blank -%}
          <li class="hero__capsule">{{ feature_2 }}</li>
        {%- endif -%}
        {%- if feature_3 != blank -%}
          <li class="hero__capsule">{{ feature_3 }}</li>
        {%- endif -%}
      </ul>
    {%- endif -%}

    {%- if cta1_label != blank or cta2_label != blank -%}
      <div class="hero__actions">
        {%- if cta1_label != blank -%}
          <a href="{{ cta1_url | default: '#' }}" class="btn hero__btn hero__btn--primary">
            {{- cta1_label -}}
          </a>
        {%- endif -%}
        {%- if cta2_label != blank -%}
          <a href="{{ cta2_url | default: '#' }}" class="btn hero__btn hero__btn--secondary">
            {{- cta2_label -}}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- if spotlight_heading != blank or spotlight_text != blank -%}
    <aside class="hero__spotlight reveal">
      {%- if spotlight_heading != blank -%}
        <p class="hero__spotlight-heading">{{ spotlight_heading }}</p>
      {%- endif -%}
      {%- if spotlight_text != blank -%}
        <p class="hero__spotlight-text">{{ spotlight_text }}</p>
      {%- endif -%}
    </aside>
  {%- endif -%}

  {%- comment -%} ── Scroll indicator ── {%- endcomment -%}
  {%- if show_scroll -%}
    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-label">Scroll</span>
      <span class="hero__scroll-line"></span>
    </div>
  {%- endif -%}

</div>

{% stylesheet %}
  .shopify-section:has(.hero) {
    padding-block: 0;
  }

  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: var(--hero-min-h-desk, 92dvh);
    overflow: hidden;
    color: var(--hero-text, #f5f4f0);
    grid-column: 1 / -1;
    width: 100%;
    isolation: isolate;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--color-gold) 28%, transparent) 0%, transparent 32%),
      linear-gradient(180deg, rgba(0, 0, 0, 0.08) 0%, transparent 38%);
    z-index: 0;
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    inset: auto auto 6% -6%;
    width: clamp(18rem, 30vw, 36rem);
    aspect-ratio: 1;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-butter) 38%, transparent);
    filter: blur(18px);
    opacity: 0.7;
    pointer-events: none;
  }

  /* ── Background ── */
  .hero__media {
    position: absolute;
    inset: 0;
  }

  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* top-anchored: faces & upper body always visible on crop */
    object-position: center top;
  }

  .hero__img--mobile { display: none; }

  .hero__placeholder {
    width: 100%;
    height: 100%;
    background-color: var(--color-bg-subtle);
  }

  .hero__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Directional gradient calibrated for deep editorial photography:
     reduced bottom multiplier avoids crushing naturally dark image bases;
     fade clears higher so upper image detail (faces, skies) breathes. */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to top,
        rgba(0, 0, 0, calc(var(--hero-overlay, 0.4) * 1.5)) 0%,
        rgba(0, 0, 0, calc(var(--hero-overlay, 0.4) * 0.9)) 40%,
        rgba(0, 0, 0, calc(var(--hero-overlay, 0.4) * 0.08)) 85%
      ),
      linear-gradient(
        to right,
        rgba(0, 0, 0, calc(var(--hero-overlay, 0.4) * 0.82)) 0%,
        transparent                                           58%
      );
  }

  .hero[data-text-align="center"] .hero__overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, calc(var(--hero-overlay, 0.4) * 1.25)) 0%,
      rgba(0, 0, 0, var(--hero-overlay, 0.4))               50%,
      rgba(0, 0, 0, calc(var(--hero-overlay, 0.4) * 0.15)) 100%
    );
  }

  /* ── Season indicator ── */
  .hero__season {
    position: absolute;
    top: var(--space-8);
    right: var(--page-margin);
    z-index: 1;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--hero-text, #f5f4f0);
    opacity: 0.55;
    margin: 0;
    padding: 0.65rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--hero-text, #f5f4f0) 20%, transparent);
    background-color: color-mix(in srgb, var(--hero-text, #f5f4f0) 10%, transparent);
    backdrop-filter: blur(12px);
  }

  /* ── Content ──
     Independent block-start/end so content sits close to the bottom
     of the frame while still having generous interior headroom above
     the eyebrow when the hero is very tall. */
  .hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    padding-block-start: clamp(var(--space-20), 11vw, var(--space-36));
    padding-block-end: clamp(var(--space-8), 5vw, var(--space-16));
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .hero[data-text-align="left"]   .hero__content { align-items: flex-start; text-align: left; }
  .hero[data-text-align="center"] .hero__content { align-items: center;     text-align: center; }
  .hero[data-text-align="right"]  .hero__content { align-items: flex-end;   text-align: right; }

  /* ── Eyebrow with leading rule (left-aligned only) ── */
  .hero__eyebrow {
    color: var(--color-gold-soft);
    opacity: 1;
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .hero[data-text-align="left"] .hero__eyebrow::before {
    content: '';
    display: block;
    width: 2.5rem;
    height: 1px;
    background: currentColor;
    opacity: 0.55;
    flex-shrink: 0;
  }

  /* ── Heading ── */
  .hero__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-style: italic;
    font-size: clamp(var(--text-3xl), 6.8vw, var(--text-5xl));
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: inherit;
    margin: 0;
    max-width: 11ch;
    overflow-wrap: normal;
    word-break: normal;
    hyphens: none;
    text-wrap: balance;
    text-shadow: 0 10px 32px rgba(0, 0, 0, 0.14);
  }

  .hero[data-text-align="center"] .hero__heading { max-width: 20ch; }

  /* ── Subtext ── */
  .hero__subtext {
    font-size: clamp(var(--text-base), 1.4vw, var(--text-md));
    line-height: var(--leading-relaxed);
    color: inherit;
    opacity: 0.82;
    max-width: 41ch;
    margin: 0;
  }

  .hero__capsules {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 40rem;
  }

  .hero__capsule {
    padding: 0.7rem 0.95rem;
    border: 1px solid color-mix(in srgb, var(--color-gold) 32%, transparent);
    background-color: color-mix(in srgb, var(--header-bg, var(--color-accent)) 62%, transparent);
    backdrop-filter: blur(18px);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: inherit;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  /* ── CTAs ── */
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-block-start: var(--space-4);
  }

  .hero[data-text-align="center"] .hero__actions { justify-content: center; }
  .hero[data-text-align="right"]  .hero__actions { justify-content: flex-end; }

  .hero__btn { min-width: 10rem; }

  .hero__btn--primary {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-gold-soft) 88%, white) 0%, var(--color-gold) 100%);
    color: #182015;
    border-color: color-mix(in srgb, var(--color-gold-soft) 65%, transparent);
  }

  .hero__btn--primary:hover {
    background: color-mix(in srgb, var(--color-gold-soft) 92%, white);
    color: #182015;
    border-color: color-mix(in srgb, var(--color-gold-soft) 75%, transparent);
  }

  .hero__btn--secondary {
    background-color: color-mix(in srgb, var(--hero-text, #f5f4f0) 12%, transparent);
    color: var(--hero-text, #f5f4f0);
    border-color: color-mix(in srgb, var(--hero-text, #f5f4f0) 26%, transparent);
    letter-spacing: var(--tracking-widest);
  }

  .hero__btn--secondary:hover {
    background-color: color-mix(in srgb, var(--hero-text, #f5f4f0) 12%, transparent);
    color: var(--hero-text, #f5f4f0);
    border-color: color-mix(in srgb, var(--hero-text, #f5f4f0) 55%, transparent);
  }

  .hero__spotlight {
    position: absolute;
    right: var(--page-margin);
    bottom: clamp(var(--space-8), 6vw, var(--space-14));
    z-index: 1;
    width: min(22rem, 28vw);
    padding: clamp(var(--space-5), 2.4vw, var(--space-7));
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--header-bg, var(--color-accent)) 82%, transparent) 0%,
        color-mix(in srgb, var(--header-bg, var(--color-accent)) 66%, transparent) 100%
      );
    border: 1px solid color-mix(in srgb, var(--color-gold) 30%, transparent);
    box-shadow: 0 20px 42px rgba(8, 14, 11, 0.18);
    backdrop-filter: blur(22px);
    border-radius: 1.25rem;
  }

  .hero__spotlight-heading {
    margin: 0 0 var(--space-3);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-gold-soft);
    opacity: 1;
  }

  .hero__spotlight-text {
    margin: 0;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(var(--text-md), 1.8vw, var(--text-xl));
    line-height: 1.15;
    max-width: 14ch;
  }

  /* ── Scroll indicator ── */
  .hero__scroll {
    position: absolute;
    bottom: var(--space-10);
    right: var(--page-margin);
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    color: var(--hero-text, #f5f4f0);
    opacity: 0.45;
  }

  .hero__scroll-label {
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 3rem;
    background: currentColor;
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--hero-text, white);
    animation: scroll-pulse 2.2s ease-in-out 0.5s infinite;
    transform: translateY(-100%);
  }

  @keyframes scroll-pulse {
    0%   { transform: translateY(-100%); }
    60%  { transform: translateY(100%); }
    100% { transform: translateY(100%); }
  }

  /* ── Mobile ── */
  @media (max-width: 48rem) {
    .hero {
      min-height: var(--hero-min-h-mob, 78dvh);
      align-items: flex-end;
    }

    .hero__img--desktop { display: none; }
    .hero__img--mobile  { display: block; }
    .hero:not(:has(.hero__img--mobile)) .hero__img--desktop { display: block; }

    .hero__heading {
      font-size: clamp(var(--text-2xl), 8.6vw, var(--text-3xl));
      max-width: 11ch;
    }

    .hero__season  { display: none; }
    .hero__scroll  { display: none; }

    .hero__actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero__btn { min-width: min(100%, 14rem); }

    .hero__capsules {
      gap: var(--space-2);
    }

    .hero__capsule {
      padding: 0.65rem 0.85rem;
    }

    .hero__spotlight {
      position: static;
      width: auto;
      margin: 0 var(--page-margin) var(--space-8);
    }

    .hero__spotlight-text {
      max-width: none;
    }

    .hero[data-text-align="center"] .hero__content,
    .hero[data-text-align="right"]  .hero__content {
      align-items: flex-start;
      text-align: left;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial hero",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Recommended: 2400 × 1400px or wider"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Recommended: 900 × 1200px portrait. Falls back to desktop image if blank."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay darkness",
      "default": 35
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "placeholder": "New collection"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Dressed for\nevery moment"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "placeholder": "Discover the new season"
    },
    {
      "type": "header",
      "content": "Benefit chips"
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature chip 1",
      "placeholder": "Easy exchanges"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature chip 2",
      "placeholder": "Small-batch drops"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature chip 3",
      "placeholder": "Worldwide shipping"
    },
    {
      "type": "text",
      "id": "cta1_label",
      "label": "Primary button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "cta1_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Secondary button label"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Editorial details"
    },
    {
      "type": "text",
      "id": "season_label",
      "label": "Season / collection label",
      "placeholder": "SS '26",
      "info": "Appears top-right of the hero. Leave blank to hide."
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    },
    {
      "type": "header",
      "content": "Spotlight panel"
    },
    {
      "type": "text",
      "id": "spotlight_heading",
      "label": "Spotlight heading",
      "placeholder": "The edit of now"
    },
    {
      "type": "textarea",
      "id": "spotlight_text",
      "label": "Spotlight text",
      "placeholder": "A short editorial statement shown in the floating panel."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "min": 400,
      "max": 1000,
      "step": 20,
      "unit": "px",
      "label": "Minimum height — desktop",
      "default": 780
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Minimum height — mobile",
      "default": 620
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text and button color",
      "default": "#F5F4F0"
    }
  ],
  "presets": [
    {
      "name": "Editorial hero",
      "settings": {
        "heading":          "Dressed for\nevery moment",
        "eyebrow":          "New arrivals",
        "feature_1":        "Easy exchanges",
        "feature_2":        "Small-batch drops",
        "feature_3":        "Worldwide shipping",
        "spotlight_heading": "The edit of now",
        "spotlight_text":   "Statement shapes, tactile fabrics, and pieces that make everyday dressing feel like an event.",
        "cta1_label":       "Shop now",
        "text_align":       "left",
        "overlay_opacity":  35,
        "min_height_desktop": 780,
        "min_height_mobile":  620,
        "text_color":       "#F5F4F0"
      }
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
