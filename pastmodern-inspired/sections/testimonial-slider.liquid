{%- liquid
  assign ts_eyebrow  = section.settings.eyebrow
  assign ts_heading  = section.settings.heading
  assign ts_bg       = section.settings.bg_style
  assign block_count = section.blocks.size
-%}

{%- if block_count > 0 -%}
<div
  class="testimonial-slider{% if ts_bg == 'subtle' %} testimonial-slider--subtle{% endif %}"
  data-testimonial-slider
>

  {%- comment -%} ── Section header ── {%- endcomment -%}
  {%- if ts_eyebrow != blank or ts_heading != blank -%}
    <div class="testimonial-slider__header">
      {%- if ts_eyebrow != blank -%}
        <p class="eyebrow">{{ ts_eyebrow }}</p>
      {%- endif -%}
      {%- if ts_heading != blank -%}
        <h2 class="testimonial-slider__heading">{{ ts_heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Track ── {%- endcomment -%}
  <div class="testimonial-slider__viewport" aria-label="Testimonials" role="region">
    <ul
      class="testimonial-slider__track"
      data-ts-track
      style="--ts-count: {{ block_count }};"
    >
      {%- for block in section.blocks -%}
        {%- liquid
          assign stars = block.settings.stars | default: 5
        -%}
        <li
          class="testimonial-slider__slide"
          data-ts-slide
          id="ts-slide-{{ block.id }}"
          {{ block.shopify_attributes }}
        >
          {%- comment -%} Stars ── {%- endcomment -%}
          {%- if stars > 0 -%}
            <div class="ts-stars" aria-label="{{ stars }} out of 5 stars" role="img">
              {%- for i in (1..5) -%}
                <svg
                  class="ts-star{% if i <= stars %} ts-star--filled{% endif %}"
                  width="14" height="14" viewBox="0 0 24 24"
                  fill="{% if i <= stars %}currentColor{% else %}none{% endif %}"
                  stroke="currentColor" stroke-width="1.5"
                  aria-hidden="true"
                ><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} Quote ── {%- endcomment -%}
          {%- if block.settings.quote != blank -%}
            <blockquote class="ts-quote">
              <p class="ts-quote__text">{{ block.settings.quote | escape }}</p>
            </blockquote>
          {%- endif -%}

          {%- comment -%} Author ── {%- endcomment -%}
          {%- if block.settings.author != blank -%}
            <figcaption class="ts-author">
              <span class="ts-author__name">{{ block.settings.author | escape }}</span>
              {%- if block.settings.author_sub != blank -%}
                <span class="ts-author__sub text-muted">{{ block.settings.author_sub | escape }}</span>
              {%- endif -%}
            </figcaption>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>

  {%- comment -%} ── Controls (only if > 1 block) ── {%- endcomment -%}
  {%- if block_count > 1 -%}
    <div class="testimonial-slider__controls" aria-label="Testimonial navigation">
      <button
        class="ts-btn ts-btn--prev"
        type="button"
        data-ts-prev
        aria-label="Previous testimonial"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <ul class="ts-dots" role="list" aria-label="Go to testimonial">
        {%- for block in section.blocks -%}
          <li>
            <button
              class="ts-dot"
              type="button"
              data-ts-dot="{{ forloop.index0 }}"
              aria-label="Testimonial {{ forloop.index }}"
              aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
            ></button>
          </li>
        {%- endfor -%}
      </ul>

      <button
        class="ts-btn ts-btn--next"
        type="button"
        data-ts-next
        aria-label="Next testimonial"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  {%- endif -%}

</div>
{%- endif -%}

{% stylesheet %}
  /* ── Wrapper ── */
  .testimonial-slider {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-10);
    text-align: center;
  }

  .testimonial-slider--subtle {
    background-color: var(--color-bg-subtle);
    padding-block: var(--section-spacing);
    /* pull out edge-to-edge within section grid */
    grid-column: 1 / -1;
    padding-inline: var(--page-margin);
  }

  /* ── Header ── */
  .testimonial-slider__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .testimonial-slider__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-style: italic;
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  /* ── Viewport / track ── */
  .testimonial-slider__viewport {
    width: 100%;
    overflow: hidden;
  }

  .testimonial-slider__track {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    /* each slide is 1 viewport wide */
    transform: translateX(calc(var(--ts-active, 0) * -100%));
    transition: transform var(--duration-slow) var(--ease-out);
    will-change: transform;
  }

  /* ── Slide ── */
  .testimonial-slider__slide {
    flex: 0 0 100%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    padding-inline: clamp(var(--space-4), 8vw, var(--space-24));
  }

  /* ── Stars ── */
  .ts-stars {
    display: flex;
    gap: var(--space-1);
    color: var(--color-accent);
  }

  .ts-star { flex-shrink: 0; }

  /* ── Quote ── */
  .ts-quote {
    margin: 0;
  }

  .ts-quote__text {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(var(--text-lg), 2.5vw, var(--text-xl));
    line-height: var(--leading-relaxed, 1.65);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text);
    max-width: 52ch;
    margin: 0 auto;
  }

  .ts-quote__text::before { content: '\201C'; }
  .ts-quote__text::after  { content: '\201D'; }

  /* ── Author ── */
  .ts-author {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .ts-author__name {
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .ts-author__sub {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
  }

  /* ── Controls ── */
  .testimonial-slider__controls {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .ts-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    background: none;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: border-color var(--duration-fast) var(--ease-default),
                color var(--duration-fast) var(--ease-default);
  }

  .ts-btn:hover        { border-color: var(--color-text); color: var(--color-text); }
  .ts-btn:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  /* ── Dots ── */
  .ts-dots {
    display: flex;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ts-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-border);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color var(--duration-fast) var(--ease-default),
                transform var(--duration-fast) var(--ease-default);
  }

  .ts-dot[aria-pressed="true"] {
    background-color: var(--color-text);
    transform: scale(1.4);
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    document.querySelectorAll('[data-testimonial-slider]').forEach(function (slider) {
      const track  = slider.querySelector('[data-ts-track]');
      const slides = slider.querySelectorAll('[data-ts-slide]');
      const dots   = slider.querySelectorAll('[data-ts-dot]');
      const prev   = slider.querySelector('[data-ts-prev]');
      const next   = slider.querySelector('[data-ts-next]');
      if (!track || slides.length < 2) return;

      let active = 0;

      function go(idx) {
        active = (idx + slides.length) % slides.length;
        track.style.setProperty('--ts-active', active);
        slides.forEach(function (s, i) {
          s.setAttribute('aria-hidden', i !== active ? 'true' : 'false');
        });
        dots.forEach(function (d, i) {
          d.setAttribute('aria-pressed', i === active ? 'true' : 'false');
        });
      }

      prev?.addEventListener('click', function () { go(active - 1); });
      next?.addEventListener('click', function () { go(active + 1); });
      dots.forEach(function (d) {
        d.addEventListener('click', function () { go(parseInt(d.dataset.tsDot, 10)); });
      });

      // Auto-advance (pause on hover/focus)
      let timer;
      function start() { timer = setInterval(function () { go(active + 1); }, 5000); }
      function stop()  { clearInterval(timer); }

      if (slides.length > 1) {
        start();
        slider.addEventListener('mouseenter', stop);
        slider.addEventListener('focusin',    stop);
        slider.addEventListener('mouseleave', start);
        slider.addEventListener('focusout',   start);
      }

      // Touch/swipe
      let touchStartX = 0;
      track.addEventListener('touchstart', function (e) { touchStartX = e.touches[0].clientX; }, { passive: true });
      track.addEventListener('touchend',   function (e) {
        const dx = e.changedTouches[0].clientX - touchStartX;
        if (Math.abs(dx) > 40) go(dx < 0 ? active + 1 : active - 1);
      });

      go(0);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Testimonial slider",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "placeholder": "What our clients say"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by thousands"
    },
    {
      "type": "select",
      "id": "bg_style",
      "label": "Background",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "subtle",  "label": "Subtle tint" }
      ],
      "default": "subtle"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Star rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "placeholder": "This piece is absolutely stunning — the quality exceeded all expectations."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "placeholder": "Emily R."
        },
        {
          "type": "text",
          "id": "author_sub",
          "label": "Author subtitle",
          "placeholder": "Verified customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial slider",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "stars": 5,
            "quote": "This piece is absolutely stunning — the quality exceeded all expectations.",
            "author": "Emily R.",
            "author_sub": "Verified customer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "stars": 5,
            "quote": "Effortless elegance. I wear it constantly and get compliments every time.",
            "author": "Isabelle T.",
            "author_sub": "Verified customer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "stars": 5,
            "quote": "The fabric feels incredibly luxurious — worth every penny.",
            "author": "Natalie M.",
            "author_sub": "Verified customer"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
