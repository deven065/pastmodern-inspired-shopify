{%- liquid
  assign section_heading = section.settings.heading
  assign section_eyebrow = section.settings.eyebrow
  assign cols            = section.settings.columns
  assign card_ratio      = section.settings.image_ratio
-%}

<div class="promo-grid" style="--pg-cols: {{ cols }};">

  {%- comment -%} ── Section header ── {%- endcomment -%}
  {%- if section_eyebrow != blank or section_heading != blank -%}
    <div class="promo-grid__header">
      {%- if section_eyebrow != blank -%}
        <p class="eyebrow promo-grid__eyebrow">{{ section_eyebrow }}</p>
      {%- endif -%}
      {%- if section_heading != blank -%}
        <h2 class="promo-grid__heading">{{ section_heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Cards ── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <ul class="promo-grid__cards" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign card_image   = block.settings.image
          assign card_heading = block.settings.heading
          assign card_subtext = block.settings.subtext
          assign card_label   = block.settings.cta_label
          assign card_url     = block.settings.cta_url | default: '#'
          if forloop.index <= 2
            assign card_loading = 'eager'
          else
            assign card_loading = 'lazy'
          endif
        -%}
        <li
          class="promo-card"
          {{ block.shopify_attributes }}
          style="--card-ratio: {{ card_ratio }};"
        >
          {%- comment -%} Image {%- endcomment -%}
          <a href="{{ card_url }}" class="promo-card__media-link" tabindex="-1" aria-hidden="true">
            <div class="promo-card__media">
              {%- if card_image != blank -%}
                {{
                  card_image
                  | image_tag:
                      sizes: '(max-width: 48rem) 100vw, (max-width: 90rem) 50vw, 45vw',
                      widths: '400, 600, 800, 1000, 1200',
                      loading: card_loading,
                      class: 'promo-card__img',
                      alt: card_image.alt | default: card_heading
                }}
              {%- else -%}
                <div class="promo-card__placeholder">
                  {{ 'collection-apparel-' | append: forloop.index | placeholder_svg_tag: 'promo-card__placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>
          </a>

          {%- comment -%} Text body {%- endcomment -%}
          <div class="promo-card__body">
            {%- if card_heading != blank -%}
              <h3 class="promo-card__heading">
                <a href="{{ card_url }}" class="promo-card__heading-link">{{ card_heading }}</a>
              </h3>
            {%- endif -%}

            {%- if card_subtext != blank -%}
              <p class="promo-card__subtext">{{ card_subtext }}</p>
            {%- endif -%}

            {%- if card_label != blank -%}
              <a href="{{ card_url }}" class="promo-card__cta">
                {{- card_label -}}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="14" height="14">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

</div>

{% stylesheet %}
  /* ── Wrapper ───────────────────────────────────────────────── */
  .promo-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  /* ── Section header ────────────────────────────────────────── */
  .promo-grid__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 42ch;
  }

  .promo-grid__eyebrow {
    margin: 0;
  }

  .promo-grid__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-style: italic;
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  /* ── Card grid ─────────────────────────────────────────────── */
  .promo-grid__cards {
    display: grid;
    grid-template-columns: repeat(var(--pg-cols, 2), 1fr);
    gap: var(--space-8) var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ── Individual card ───────────────────────────────────────── */
  .promo-card {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Media */
  .promo-card__media-link {
    display: block;
    overflow: hidden;
  }

  .promo-card__media {
    aspect-ratio: var(--card-ratio, 3/4);
    overflow: hidden;
    background-color: var(--color-bg-subtle);
  }

  .promo-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform var(--duration-slow) var(--ease-out);
    display: block;
  }

  .promo-card:hover .promo-card__img {
    transform: scale(1.03);
  }

  .promo-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg-subtle);
  }

  .promo-card__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Text body */
  .promo-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-block: var(--space-5);
    padding-inline: 0;
  }

  .promo-card__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-style: italic;
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .promo-card__heading-link {
    text-decoration: none;
    color: inherit;
    transition: opacity var(--duration-fast) var(--ease-default);
  }

  .promo-card__heading-link:hover {
    opacity: 0.65;
  }

  .promo-card__subtext {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 40ch;
  }

  .promo-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    margin-block-start: var(--space-1);
    transition: gap var(--duration-base) var(--ease-out),
                opacity var(--duration-fast) var(--ease-default);
  }

  .promo-card__cta:hover {
    gap: var(--space-3);
    opacity: 0.65;
  }

  /* ── 3-col variant: first card spans 2 columns ─────────────── */
  .promo-grid[style*="--pg-cols: 3"] .promo-grid__cards .promo-card:first-child {
    grid-column: span 2;
  }

  .promo-grid[style*="--pg-cols: 3"] .promo-grid__cards .promo-card:first-child .promo-card__media {
    aspect-ratio: 16 / 9;
  }

  /* ── Mobile: always one column ─────────────────────────────── */
  @media (max-width: 48rem) {
    .promo-grid__cards {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    /* Reset the 3-col span on mobile */
    .promo-grid[style*="--pg-cols: 3"] .promo-grid__cards .promo-card:first-child {
      grid-column: span 1;
    }

    .promo-grid[style*="--pg-cols: 3"] .promo-grid__cards .promo-card:first-child .promo-card__media {
      aspect-ratio: var(--card-ratio, 3/4);
    }

    .promo-card__heading {
      font-size: var(--text-xl);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Promo grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "placeholder": "Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "placeholder": "Shop by category"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns (first card spans 2)" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "3/4",  "label": "Portrait 3:4" },
        { "value": "4/5",  "label": "Portrait 4:5" },
        { "value": "1/1",  "label": "Square" },
        { "value": "16/9", "label": "Landscape 16:9" }
      ],
      "default": "3/4"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Promo card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "The Collection"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "placeholder": "A short description"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo grid",
      "settings": {
        "eyebrow":  "Explore",
        "heading":  "Shop the edit",
        "columns":  "2",
        "image_ratio": "3/4"
      },
      "blocks": [
        {
          "type": "card",
          "settings": {
            "heading":   "Ready to wear",
            "cta_label": "Discover"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading":   "Accessories",
            "cta_label": "Discover"
          }
        }
      ]
    }
  ],
  "max_blocks": 4,
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
