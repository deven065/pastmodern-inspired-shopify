{%- liquid
  assign section_heading = section.settings.heading
  assign section_eyebrow = section.settings.eyebrow
  assign cols            = section.settings.columns
  assign mobile_cols     = section.settings.columns_mobile | default: '2'
  assign card_ratio      = section.settings.image_ratio
-%}

<div
  class="promo-grid"
  style="
    --pg-cols:     {{ cols }};
    --pg-cols-mob: {{ mobile_cols }};
    --card-ratio:  {{ card_ratio }};
  "
>

  {%- comment -%} ── Section header ── {%- endcomment -%}
  {%- if section_eyebrow != blank or section_heading != blank -%}
    <div class="promo-grid__header">
      {%- if section_eyebrow != blank -%}
        <p class="eyebrow">{{ section_eyebrow }}</p>
      {%- endif -%}
      {%- if section_heading != blank -%}
        <h2 class="promo-grid__heading">{{ section_heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Cards ── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <ul class="promo-grid__cards" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign card_image   = block.settings.image
          assign card_heading = block.settings.heading
          assign card_url     = block.settings.cta_url | default: '#'
          if forloop.index < 10
            assign card_num_str = '0' | append: forloop.index
          else
            assign card_num_str = forloop.index | append: ''
          endif
          if forloop.index <= 2
            assign card_loading = 'eager'
          else
            assign card_loading = 'lazy'
          endif
        -%}
        <li
          class="promo-card"
          {{ block.shopify_attributes }}
        >
          <a href="{{ card_url }}" class="promo-card__link">
            <div class="promo-card__media">

              {%- if card_image != blank -%}
                {{
                  card_image
                  | image_url: width: 1200
                  | image_tag:
                      sizes: '(max-width: 48rem) 50vw, (max-width: 90rem) 25vw, 22vw',
                      widths: '400, 600, 800, 1000, 1200',
                      loading: card_loading,
                      class: 'promo-card__img',
                      alt: card_image.alt | default: card_heading
                }}
              {%- else -%}
                <div class="promo-card__placeholder">
                  {{- 'collection-apparel-' | append: forloop.index | placeholder_svg_tag: 'promo-card__placeholder-svg' -}}
                </div>
              {%- endif -%}

              <div class="promo-card__overlay" aria-hidden="true">
                <span class="promo-card__num">{{ card_num_str }}</span>
                <div class="promo-card__footer">
                  {%- if card_heading != blank -%}
                    <span class="promo-card__heading">{{ card_heading }}</span>
                  {%- endif -%}
                  <span class="promo-card__arrow">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true" focusable="false">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </span>
                </div>
              </div>

            </div>
            {%- if card_heading != blank -%}
              <span class="visually-hidden">{{ card_heading }}</span>
            {%- endif -%}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

</div>

{% stylesheet %}
  /* ── Wrapper ─────────────────────────────────────────────── */
  .promo-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  /* ── Section header ─────────────────────────────────────── */
  .promo-grid__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .promo-grid__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-style: italic;
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  /* ── Card grid ──────────────────────────────────────────── */
  .promo-grid__cards {
    display: grid;
    grid-template-columns: repeat(var(--pg-cols, 4), 1fr);
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ── Individual card ────────────────────────────────────── */
  .promo-card__link {
    display: block;
    text-decoration: none;
    color: white;
    overflow: hidden;
  }

  .promo-card__media {
    position: relative;
    aspect-ratio: var(--card-ratio, 3/4);
    overflow: hidden;
    background-color: var(--color-bg-subtle);
  }

  .promo-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.7s cubic-bezier(0.0, 0.0, 0.2, 1);
    display: block;
  }

  .promo-card__link:hover .promo-card__img {
    transform: scale(1.06);
  }

  .promo-card__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg-subtle);
  }

  .promo-card__placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Overlay gradient + text ────────────────────────────── */
  .promo-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-5);
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.60) 0%,
      rgba(0, 0, 0, 0.06) 45%,
      transparent         70%
    );
    transition: background 0.4s var(--ease-out);
  }

  .promo-card__link:hover .promo-card__overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.72) 0%,
      rgba(0, 0, 0, 0.18) 50%,
      rgba(0, 0, 0, 0.04) 80%
    );
  }

  /* ── Card number ────────────────────────────────────────── */
  .promo-card__num {
    display: block;
    align-self: flex-start;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    font-weight: 400;
    opacity: 0.40;
  }

  /* ── Bottom: heading + arrow ────────────────────────────── */
  .promo-card__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .promo-card__heading {
    display: block;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: var(--font-heading-weight);
    font-size: clamp(var(--text-xl), 2vw, var(--text-2xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: white;
  }

  .promo-card__arrow {
    flex-shrink: 0;
    opacity: 0;
    transform: translate(-0.4rem, 0.4rem);
    transition:
      opacity   0.28s var(--ease-out),
      transform 0.28s var(--ease-out);
  }

  .promo-card__link:hover .promo-card__arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  /* ── Tablet: 2 cols ─────────────────────────────────────── */
  @media (max-width: 62rem) {
    .promo-grid__cards {
      grid-template-columns: repeat(var(--pg-cols-mob, 2), 1fr);
      gap: var(--space-3);
    }
  }

  /* ── Mobile: always 2 cols, compact ────────────────────── */
  @media (max-width: 30rem) {
    .promo-grid__cards {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-2);
    }

    .promo-card__overlay {
      padding: var(--space-3);
    }

    .promo-card__heading {
      font-size: var(--text-lg);
    }

    .promo-card__arrow { display: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Promo grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "placeholder": "Collections"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "placeholder": "Shop by category"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "3/4",  "label": "Portrait 3:4" },
        { "value": "4/5",  "label": "Portrait 4:5" },
        { "value": "1/1",  "label": "Square 1:1" },
        { "value": "16/9", "label": "Landscape 16:9" }
      ],
      "default": "3/4"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Promo card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "placeholder": "New Arrivals"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo grid",
      "settings": {
        "columns":      "4",
        "image_ratio":  "3/4"
      },
      "blocks": [
        { "type": "card", "settings": { "heading": "New Arrivals" } },
        { "type": "card", "settings": { "heading": "Bridal" } },
        { "type": "card", "settings": { "heading": "Couture" } },
        { "type": "card", "settings": { "heading": "Dresses" } }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
