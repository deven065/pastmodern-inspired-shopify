{%- if section.settings.enable and section.settings.message != blank -%}
  <style>
    #shopify-section-{{ section.id }} {
      --ann-bg:   {{ section.settings.bg_color }};
      --ann-text: {{ section.settings.text_color }};
    }
  </style>
  <div
    class="announcement-bar{% if section.settings.dismissible %} announcement-bar--dismissible{% endif %}"
    role="region"
    aria-label="Announcement"
    data-announcement-bar
    data-section-id="{{ section.id }}"
  >
    <div class="announcement-bar__inner">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="announcement-bar__text">
          {{- section.settings.message -}}
        </a>
      {%- else -%}
        <p class="announcement-bar__text">{{- section.settings.message -}}</p>
      {%- endif -%}

      {%- if section.settings.dismissible -%}
        <button
          class="announcement-bar__close"
          aria-label="Dismiss announcement"
          data-announcement-close
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="12" height="12">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .announcement-bar {
    background-color: var(--ann-bg, var(--color-text));
    color: var(--ann-text, var(--color-bg));
  }

  .announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    padding-block: 10px;
    padding-inline: var(--space-6);
  }

  .announcement-bar__text {
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-align: center;
    text-decoration: none;
    color: inherit;
  }

  a.announcement-bar__text:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  p.announcement-bar__text {
    margin: 0;
  }

  .announcement-bar__close {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: var(--space-1);
    flex-shrink: 0;
    opacity: 0.4;
    transition: opacity var(--duration-base) var(--ease-default);
  }

  .announcement-bar__close:hover {
    opacity: 0.9;
  }

  .announcement-bar[hidden] {
    display: none;
  }

  /* ── Mobile refinements ── */
  @media (max-width: 56.25rem) {
    .announcement-bar__inner {
      padding-block: 8px;
      padding-inline: var(--space-4);
      gap: var(--space-3);
      /* Relative positioning for absolute-positioned close button */
      position: relative;
    }

    /* Centered text regardless of dismiss button presence */
    .announcement-bar--dismissible .announcement-bar__inner {
      padding-inline-end: 2.75rem;
    }

    .announcement-bar__text {
      letter-spacing: 0.10em;
    }

    /* Close button anchored to the right, not part of flex flow */
    .announcement-bar__close {
      position: absolute;
      inset-block: 0;
      inset-inline-end: 0;
      min-width: 2.75rem;
      min-height: 100%;
      margin: 0;
      padding: 0;
      opacity: 0.35;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var bar   = document.querySelector('[data-announcement-bar]');
    var close = document.querySelector('[data-announcement-close]');
    if (!bar || !close) return;

    var KEY = 'ann-dismissed-' + bar.dataset.sectionId;
    if (sessionStorage.getItem(KEY)) {
      bar.hidden = true;
      return;
    }

    close.addEventListener('click', function () {
      bar.hidden = true;
      sessionStorage.setItem(KEY, '1');
    });
  })();
</script>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "Complimentary shipping on orders over $250"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "checkbox",
      "id": "dismissible",
      "label": "Allow visitors to dismiss",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#214630"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#F7F3EC"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ],
  "disabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
