{%- liquid
  assign logo_image   = section.settings.logo
  assign logo_width   = section.settings.logo_width
  assign menu_links   = section.settings.menu.links
  assign show_search  = section.settings.show_search
  assign show_account = section.settings.show_account
-%}

{%- comment -%} ── Colour / behaviour overrides ── {%- endcomment -%}
<style>
  #shopify-section-{{ section.id }} {
    --header-bg:       {{ section.settings.header_bg }};
    --header-text:     {{ section.settings.header_text }};
    --header-position: {%- if section.settings.sticky_header %}sticky{% else %}relative{% endif -%};
    --header-height:   {{ section.settings.header_height_desktop | default: 72 }}px;
  }
  @media (max-width: 56.25rem) {
    #shopify-section-{{ section.id }} { --header-height: 4.25rem; }
  }
</style>

{%- comment -%} ── Backdrop for mobile drawer ── {%- endcomment -%}
<div
  class="header-overlay"
  data-mobile-overlay
  aria-hidden="true"
></div>

{%- comment -%} ── Mobile nav drawer ── {%- endcomment -%}
<nav
  class="header-drawer"
  id="header-mobile-menu"
  data-mobile-menu
  aria-label="Mobile navigation"
  aria-hidden="true"
  inert
>
  <div class="header-drawer__inner">
    <div class="header-drawer__header">
      <button
        class="header-drawer__close"
        data-drawer-close
        aria-label="Close menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="18" height="18">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
      {%- if logo_image != blank -%}
        <img
          src="{{ logo_image | image_url: width: 200 }}"
          width="{{ logo_width | at_most: 100 }}"
          height="auto"
          alt="{{ shop.name }}"
          class="header-drawer__brand-img"
          loading="eager"
          aria-hidden="true"
        >
      {%- else -%}
        <span class="header-drawer__brand-name" aria-hidden="true">{{ shop.name }}</span>
      {%- endif -%}
    </div>

    <ul class="header-drawer__nav" role="list">
      {%- for link in menu_links -%}
        <li>
          {%- if link.links.size > 0 -%}
            <details class="header-drawer__details">
              <summary class="header-drawer__summary">
                {{- link.title -}}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="14" height="14" class="chevron">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </summary>
              <ul class="header-drawer__sub" role="list">
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}" class="header-drawer__link header-drawer__link--sub"
                      {%- if child.current %} aria-current="page"{% endif %}>
                      {{- child.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </details>
          {%- else -%}
            <a href="{{ link.url }}" class="header-drawer__link"
              {%- if link.current %} aria-current="page"{% endif %}>
              {{- link.title -}}
            </a>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    {%- if show_search -%}
      <div class="header-drawer__search">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <label class="visually-hidden" for="drawer-search-input">Search</label>
          <input
            id="drawer-search-input"
            type="search"
            name="q"
            placeholder="Search"
            autocomplete="off"
          >
          <button type="submit" class="visually-hidden">Submit search</button>
        </form>
      </div>
    {%- endif -%}
  </div>
</nav>

{%- comment -%} ── Main header ── {%- endcomment -%}
<header class="header" data-header role="banner">
  <div class="header__inner">

    {%- comment -%} Left — hamburger (mobile) + desktop nav {%- endcomment -%}
    <div class="header__start">
      <button
        class="header__hamburger"
        data-hamburger
        aria-expanded="false"
        aria-controls="header-mobile-menu"
        aria-label="Open menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="18" height="18">
          <path d="M4 7h16M4 17h16"/>
        </svg>
      </button>

      <nav class="header__nav" aria-label="Main navigation">
        <ul class="header__nav-list" role="list">
          {%- for link in menu_links -%}
            <li class="header__nav-item{% if link.links.size > 0 %} header__nav-item--has-dropdown{% endif %}">
              {%- if link.links.size > 0 -%}
                <button
                  class="header__nav-link header__nav-link--parent"
                  aria-expanded="false"
                  aria-haspopup="true"
                >
                  {{- link.title -}}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="12" height="12" class="chevron">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </button>
                <ul class="header__dropdown" role="list">
                  {%- for child in link.links -%}
                    <li>
                      <a href="{{ child.url }}" class="header__dropdown-link"
                        {%- if child.current %} aria-current="page"{% endif %}>
                        {{- child.title -}}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- else -%}
                <a href="{{ link.url }}" class="header__nav-link"
                  {%- if link.current %} aria-current="page"{% endif %}>
                  {{- link.title -}}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    </div>

    {%- comment -%} Centre — logo {%- endcomment -%}
    <div class="header__logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }} — home">
        {%- if logo_image != blank -%}
          {{ logo_image | image_url: width: logo_width | image_tag:
              width: logo_width,
              height: 'auto',
              alt: shop.name,
              loading: 'eager',
              fetchpriority: 'high',
              class: 'header__logo-img'
          }}
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} Right — search, account, cart {%- endcomment -%}
    <div class="header__end">
      {%- if show_search -%}
        <a href="{{ routes.search_url }}" class="header__icon-btn header__search-btn" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="20" height="20">
            <circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </a>
      {%- endif -%}

      {%- if show_account -%}
        {%- if shop.customer_accounts_enabled -%}
          <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="Account">
        {%- else -%}
          <span class="header__icon-btn header__icon-btn--muted" aria-hidden="true">
        {%- endif -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="20" height="20">
            <circle cx="12" cy="7" r="4"/><path d="M5.5 20a6.5 6.5 0 0 1 13 0"/>
          </svg>
        {%- if shop.customer_accounts_enabled -%}
          </a>
        {%- else -%}
          </span>
        {%- endif -%}
      {%- endif -%}

      {%- if settings.enable_cart_drawer -%}
        <button
          class="header__icon-btn header__cart-btn"
          data-open-cart
          aria-label="Open cart{% if cart.item_count > 0 %}, {{ cart.item_count }} item{{ cart.item_count | pluralize: '', 's' }}{% endif %}"
        >
      {%- else -%}
        <a href="{{ routes.cart_url }}" class="header__icon-btn header__cart-btn" aria-label="Cart{% if cart.item_count > 0 %}, {{ cart.item_count }} items{% endif %}">
      {%- endif -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="20" height="20">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span
            class="header__cart-count"
            data-cart-count
            {%- if cart.item_count == 0 %} hidden{%- endif -%}
            aria-hidden="true"
          >
            {{- cart.item_count -}}
          </span>
      {%- if settings.enable_cart_drawer -%}
        </button>
      {%- else -%}
        </a>
      {%- endif -%}
    </div>

  </div>
</header>

{% stylesheet %}
  /* ── Header shell ─────────────────────────────────────────── */
  .header {
    background-color: var(--header-bg, var(--color-bg));
    color: var(--header-text, var(--color-text));
    border-block-end: 1px solid var(--color-border);
    position: var(--header-position, sticky);
    top: 0;
    z-index: 100;
    transition: box-shadow var(--duration-base) var(--ease-default);
  }

  .header.is-sticky {
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    background-color: color-mix(in srgb, var(--header-bg, var(--color-bg)) 88%, transparent);
    box-shadow: 0 1px 0 color-mix(in srgb, var(--color-border) 40%, transparent);
    border-block-end-color: transparent;
  }

  /* Strip Shopify's default section padding */
  .shopify-section-group-header-group .shopify-section {
    padding-block: 0;
  }

  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: var(--header-height, 4.5rem);
    padding-inline: var(--page-margin);
    max-width: var(--page-width);
    margin-inline: auto;
  }

  /* ── Logo ─────────────────────────────────────────────────── */
  .header__logo {
    display: flex;
    justify-content: center;
  }

  .header__logo a {
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
  }

  .header__logo-img {
    display: block;
    width: var(--logo-width, 120px);
    height: auto;
  }

  .header__logo-text {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-style: italic;
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    white-space: nowrap;
  }

  /* ── Icon buttons ─────────────────────────────────────────── */
  .header__start,
  .header__end {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .header__end {
    justify-content: flex-end;
  }

  .header__icon-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: 6px;
    text-decoration: none;
    transition: opacity var(--duration-fast) var(--ease-default);
  }

  .header__icon-btn:hover {
    opacity: 0.45;
  }

  .header__icon-btn--muted {
    opacity: 0.35;
    cursor: default;
  }

  .header__cart-count {
    position: absolute;
    top: -2px;
    right: -6px;
    min-width: 1.1rem;
    height: 1.1rem;
    padding-inline: 3px;
    border-radius: var(--radius-pill);
    background-color: var(--color-gold);
    color: #1E1D1A;
    font-size: 0.6rem;
    font-weight: 600;
    line-height: 1.1rem;
    text-align: center;
  }

  /* ── Desktop nav ──────────────────────────────────────────── */
  .header__hamburger {
    display: none;
  }

  .header__nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-7);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Slightly tighter spacing on mid-size laptops */
  @media (max-width: 75rem) {
    .header__nav-list { gap: var(--space-5); }
  }

  .header__nav-item {
    position: relative;
  }

  .header__nav-link {
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding-block: var(--space-2);
    padding-block-end: calc(var(--space-2) + 4px);
    white-space: nowrap;
    position: relative;
  }

  /* Center-outward underline — the luxury editorial nav signature */
  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    right: 50%;
    height: 1px;
    background: currentColor;
    opacity: 0.4;
    transition:
      left  var(--duration-measured, 600ms) var(--ease-brand, var(--ease-out)),
      right var(--duration-measured, 600ms) var(--ease-brand, var(--ease-out));
  }

  .header__nav-link:hover::after,
  .header__nav-link[aria-current="page"]::after {
    left: 0;
    right: 0;
  }

  .header__nav-link .chevron {
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .header__nav-link--parent[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .header__dropdown {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 50%;
    transform: translateX(-50%);
    min-width: 12rem;
    background-color: color-mix(in srgb, var(--color-bg) 96%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: none;
    border-top: 1px solid var(--color-border);
    box-shadow:
      0 16px 40px color-mix(in srgb, var(--color-text) 8%, transparent),
      0 4px 12px  color-mix(in srgb, var(--color-text) 4%, transparent);
    list-style: none;
    margin: 0;
    padding: var(--space-4) 0;
    opacity: 0;
    pointer-events: none;
    translate: 0 var(--space-2);
    transition:
      opacity  var(--duration-measured) var(--ease-brand),
      translate var(--duration-measured) var(--ease-brand);
  }

  .header__nav-item--has-dropdown:hover .header__dropdown,
  .header__nav-item--has-dropdown:focus-within .header__dropdown,
  .header__dropdown:focus-within {
    opacity: 1;
    pointer-events: auto;
    translate: 0 0;
  }

  .header__dropdown-link {
    display: block;
    padding: var(--space-4) var(--space-7);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-brand);
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    transition: background-color var(--duration-fast) var(--ease-default);
  }

  .header__dropdown-link:hover,
  .header__dropdown-link[aria-current="page"] {
    background-color: var(--color-bg-subtle);
  }

  /* ── Mobile: swap nav for hamburger below 900px ───────────── */
  @media (max-width: 56.25rem) {
    .header__inner {
      height: var(--header-height, 4.25rem);
      padding-inline: clamp(1rem, 5vw, var(--page-margin));
    }

    /* ── Logo: proportional cap, never crowds icons ── */
    .header__logo-img {
      max-width: 88px;
      width: min(var(--logo-width, 88px), 88px);
      /* Ensure pixel-sharp rendering on retina */
      image-rendering: -webkit-optimize-contrast;
    }

    .header__logo-text {
      font-size: var(--text-xl);
      letter-spacing: -0.025em;
    }

    /* ── Search lives in the drawer on mobile — remove from bar ── */
    .header__search-btn {
      display: none;
    }

    /* ── Icon clusters: optically flush to edges, zero gap ── */
    .header__start,
    .header__end {
      gap: 0;
    }

    /* ── All icons: 18px, tighter padding for visual precision ── */
    .header__icon-btn {
      padding: 7px;
    }
    .header__icon-btn svg {
      width: 18px;
      height: 18px;
    }

    /* ── Hamburger: same optical padding as icons ── */
    .header__hamburger {
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      color: inherit;
      cursor: pointer;
      padding: 7px;
      min-width: 2.75rem;
      min-height: 2.75rem;
    }

    .header__nav {
      display: none;
    }

    /* ── Cart badge: minimal dot, not a notification pill ── */
    .header__cart-count {
      min-width: 0.8125rem;
      height: 0.8125rem;
      line-height: 0.8125rem;
      font-size: 0.4375rem;
      font-weight: 700;
      letter-spacing: 0;
      top: 2px;
      right: -2px;
      padding-inline: 2px;
    }
  }

  /* ── Mobile drawer ────────────────────────────────────────── */
  .header-overlay {
    position: fixed;
    inset: 0;
    z-index: 110;
    background-color: var(--color-overlay);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-slow) var(--ease-out);
  }

  body.menu-open {
    overflow: hidden;
    overscroll-behavior: none;
  }

  body.menu-open .header-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  .header-drawer {
    position: fixed;
    inset-block: 0;
    inset-inline-start: 0;
    z-index: 120;
    width: min(100vw, 22rem);
    background-color: var(--color-bg);
    display: flex;
    flex-direction: column;
    visibility: hidden;
    transform: translateX(-100%);
    transition:
      transform  var(--duration-measured) var(--ease-brand),
      visibility 0s linear var(--duration-measured);
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
  }

  .header-drawer.is-open {
    visibility: visible;
    transform: translateX(0);
    transition:
      transform  var(--duration-measured) var(--ease-brand),
      visibility 0s linear 0s;
  }

  .header-drawer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-8) var(--space-7);
  }

  .header-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-direction: row-reverse;
    padding-block-end: var(--space-6);
    border-block-end: 1px solid var(--color-border);
  }

  .header-drawer__brand-img {
    display: block;
    width: var(--logo-width, 90px);
    max-width: 110px;
    height: auto;
  }

  .header-drawer__brand-name {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
  }

  .header-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: var(--space-2);
    min-width: 2.75rem;
    min-height: 2.75rem;
    opacity: 0.55;
    transition: opacity var(--duration-fast) var(--ease-default);
  }

  .header-drawer__close:hover {
    opacity: 1;
  }

  .header-drawer__nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .header-drawer__link {
    display: block;
    padding-block: var(--space-4);
    border-block-end: 1px solid var(--color-border);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    transition: color var(--duration-fast) var(--ease-default), opacity var(--duration-fast) var(--ease-default);
  }

  .header-drawer__link:hover { opacity: 0.6; }
  .header-drawer__link[aria-current="page"] {
    color: var(--color-accent);
    opacity: 1;
  }

  .header-drawer__link--sub {
    padding-inline-start: var(--space-6);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    opacity: 0.72;
    border-block-end: none;
  }

  .header-drawer__details > summary {
    list-style: none;
  }

  .header-drawer__details > summary::-webkit-details-marker {
    display: none;
  }

  .header-drawer__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-4);
    border-block-end: 1px solid var(--color-border);
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    color: inherit;
  }

  .header-drawer__summary .chevron {
    transition: transform var(--duration-fast) var(--ease-default);
    flex-shrink: 0;
  }

  .header-drawer__details[open] .header-drawer__summary .chevron {
    transform: rotate(180deg);
  }

  .header-drawer__sub {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header-drawer__search {
    margin-block-start: auto;
    padding-block-start: var(--space-4);
    border-block-start: 1px solid var(--color-border);
  }

  .header-drawer__search input {
    background-color: var(--color-bg-subtle);
    border-color: transparent;
    font-size: var(--text-sm);
  }

  /* ── iOS safe-area insets (notch, Dynamic Island, home bar) ── */
  .header {
    padding-block-start: env(safe-area-inset-top, 0px);
  }

  .header-drawer__inner {
    padding-block-start: max(var(--space-8), env(safe-area-inset-top, 0px));
    padding-block-end:   max(var(--space-6), env(safe-area-inset-bottom, 0px));
    padding-inline-start: max(var(--space-7), env(safe-area-inset-left, 0px));
    padding-inline-end:   max(var(--space-7), env(safe-area-inset-right, 0px));
  }

  /* ── 44px minimum touch targets + tap-highlight reset ───────  */
  .header__icon-btn,
  .header-drawer__close {
    min-width: 2.75rem;
    min-height: 2.75rem;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .header__hamburger {
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .header-drawer__link,
  .header-drawer__summary {
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    /*
     * NOTE: Sticky header and mobile drawer are handled by theme.js
     * (StickyHeader + HeaderMenu classes). Only section-specific
     * interactions that don't exist in theme.js live here.
     */

    /* ── Desktop dropdown buttons ── */
    document.querySelectorAll('.header__nav-link--parent').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var expanded = btn.getAttribute('aria-expanded') === 'true';
        document.querySelectorAll('.header__nav-link--parent').forEach(function (b) {
          b.setAttribute('aria-expanded', 'false');
        });
        btn.setAttribute('aria-expanded', String(!expanded));
      });

      /* Close on outside click */
      document.addEventListener('click', function (e) {
        if (!btn.closest('.header__nav-item').contains(e.target)) {
          btn.setAttribute('aria-expanded', 'false');
        }
      });
    });

    /* ── Logo width CSS var ── */
    var logoImg = document.querySelector('.header__logo-img');
    if (logoImg) {
      document.documentElement.style.setProperty(
        '--logo-width',
        logoImg.getAttribute('width') + 'px'
      );
    }
  })();
{% endjavascript %}

