{%- liquid
  assign logo_image   = section.settings.logo
  assign logo_width   = section.settings.logo_width
  assign menu_links   = section.settings.menu.links
  assign show_search  = section.settings.show_search
  assign show_account = section.settings.show_account
-%}

{%- comment -%} ── Colour / behaviour overrides ── {%- endcomment -%}
<style>
  #shopify-section-{{ section.id }} {
    --header-bg:       {{ section.settings.header_bg }};
    --header-text:     {{ section.settings.header_text }};
    --header-position: {%- if settings.header_sticky == false %}relative{% else %}sticky{% endif -%};
    --header-height:   {{ section.settings.header_height_desktop | default: 72 }}px;
    --logo-width:      {{ logo_width | default: 120 }}px;
  }
  @media (max-width: 56.25rem) {
    #shopify-section-{{ section.id }} { --header-height: 4.25rem; }
  }
</style>

{%- comment -%} ── Backdrop for mobile drawer ── {%- endcomment -%}
<div
  class="header-overlay"
  data-mobile-overlay
  aria-hidden="true"
></div>

{%- comment -%} ── Mobile nav drawer ── {%- endcomment -%}
<nav
  class="header-drawer"
  id="header-mobile-menu"
  data-mobile-menu
  aria-label="Mobile navigation"
  aria-hidden="true"
  inert
>
  <div class="header-drawer__inner">
    <div class="header-drawer__header">
      <button
        class="header-drawer__close"
        data-drawer-close
        aria-label="Close menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="18" height="18">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
      {%- if logo_image != blank -%}
        <img
          src="{{ logo_image | image_url: width: 200 }}"
          width="{{ logo_width | at_most: 100 }}"
          height="auto"
          alt="{{ shop.name }}"
          class="header-drawer__brand-img"
          loading="eager"
          aria-hidden="true"
        >
      {%- else -%}
        <span class="header-drawer__brand-name" aria-hidden="true">{{ shop.name }}</span>
      {%- endif -%}
    </div>

    <ul class="header-drawer__nav" role="list">
      {%- for link in menu_links -%}
        {%- liquid
          assign link_is_active = false
          if link.current or link.active or link.child_active
            assign link_is_active = true
          endif
        -%}
        <li>
          {%- if link.links.size > 0 -%}
            <details class="header-drawer__details">
              <summary class="header-drawer__summary{% if link_is_active %} is-active{% endif %}">
                {{- link.title -}}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="14" height="14" class="chevron">
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </summary>
              <ul class="header-drawer__sub" role="list">
                <li>
                  <a href="{{ link.url }}" class="header-drawer__link header-drawer__link--sub header-drawer__link--parent"
                    {%- if link.current %} aria-current="page"{% endif %}>
                    Shop all {{- ' ' -}}{{- link.title -}}
                  </a>
                </li>
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}" class="header-drawer__link header-drawer__link--sub"
                      {%- if child.current %} aria-current="page"{% endif %}>
                      {{- child.title -}}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </details>
          {%- else -%}
            <a href="{{ link.url }}" class="header-drawer__link"
              {%- if link.current %} aria-current="page"{% endif %}>
              {{- link.title -}}
            </a>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>

    {%- if show_search -%}
      <div class="header-drawer__search">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <label class="visually-hidden" for="drawer-search-input">Search</label>
          <input
            id="drawer-search-input"
            type="search"
            name="q"
            placeholder="Search"
            autocomplete="off"
          >
          <button type="submit" class="visually-hidden">Submit search</button>
        </form>
      </div>
    {%- endif -%}
  </div>
</nav>

{%- comment -%} ── Main header ── {%- endcomment -%}
<header class="header full-width" data-header role="banner">
  <div class="header__inner">

    {%- comment -%} Left — hamburger (mobile) + desktop nav {%- endcomment -%}
    <div class="header__start">
      <button
        class="header__hamburger"
        data-hamburger
        aria-expanded="false"
        aria-controls="header-mobile-menu"
        aria-label="Open menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="18" height="18">
          <path d="M4 7h16M4 17h16"/>
        </svg>
      </button>

      <nav class="header__nav" aria-label="Main navigation">
        <ul class="header__nav-list" role="list">
          {%- for link in menu_links -%}
            {%- liquid
              assign link_is_active = false
              if link.current or link.active or link.child_active
                assign link_is_active = true
              endif
            -%}
            <li class="header__nav-item{% if link.links.size > 0 %} header__nav-item--has-dropdown{% endif %}{% if link_is_active %} is-active{% endif %}">
              {%- if link.links.size > 0 -%}
                <a
                  href="{{ link.url }}"
                  class="header__nav-link header__nav-link--parent"
                  aria-haspopup="true"
                  {%- if link.current %} aria-current="page"{% endif %}
                >
                  {{- link.title -}}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="12" height="12" class="chevron">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </a>
                <ul class="header__dropdown" role="list">
                  <li>
                    <a href="{{ link.url }}" class="header__dropdown-link header__dropdown-link--parent"
                      {%- if link.current %} aria-current="page"{% endif %}>
                      Shop all {{- ' ' -}}{{- link.title -}}
                    </a>
                  </li>
                  {%- for child in link.links -%}
                    <li>
                      <a href="{{ child.url }}" class="header__dropdown-link"
                        {%- if child.current %} aria-current="page"{% endif %}>
                        {{- child.title -}}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- else -%}
                <a href="{{ link.url }}" class="header__nav-link"
                  {%- if link.current %} aria-current="page"{% endif %}>
                  {{- link.title -}}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    </div>

    {%- comment -%} Centre — logo {%- endcomment -%}
    <div class="header__logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }} — home">
        {%- if logo_image != blank -%}
          {{ logo_image | image_url: width: logo_width | image_tag:
              width: logo_width,
              height: 'auto',
              alt: shop.name,
              loading: 'eager',
              fetchpriority: 'high',
              class: 'header__logo-img'
          }}
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} Right — search, account, cart {%- endcomment -%}
    <div class="header__end">
      {%- if show_search -%}
        <a href="{{ routes.search_url }}" class="header__icon-btn header__search-btn" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="20" height="20">
            <circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </a>
      {%- endif -%}

      {%- if show_account -%}
        {%- if shop.customer_accounts_enabled -%}
          <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="Account">
        {%- else -%}
          <span class="header__icon-btn header__icon-btn--muted" aria-hidden="true">
        {%- endif -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="20" height="20">
            <circle cx="12" cy="7" r="4"/><path d="M5.5 20a6.5 6.5 0 0 1 13 0"/>
          </svg>
        {%- if shop.customer_accounts_enabled -%}
          </a>
        {%- else -%}
          </span>
        {%- endif -%}
      {%- endif -%}

      {%- if settings.enable_cart_drawer -%}
        <button
          class="header__icon-btn header__cart-btn"
          data-open-cart
          aria-label="Open cart{% if cart.item_count > 0 %}, {{ cart.item_count }} item{{ cart.item_count | pluralize: '', 's' }}{% endif %}"
        >
      {%- else -%}
        <a href="{{ routes.cart_url }}" class="header__icon-btn header__cart-btn" aria-label="Cart{% if cart.item_count > 0 %}, {{ cart.item_count }} items{% endif %}">
      {%- endif -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" width="20" height="20">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          <span
            class="header__cart-count"
            data-cart-count
            {%- if cart.item_count == 0 %} hidden{%- endif -%}
            aria-hidden="true"
          >
            {{- cart.item_count -}}
          </span>
      {%- if settings.enable_cart_drawer -%}
        </button>
      {%- else -%}
        </a>
      {%- endif -%}
    </div>

  </div>
</header>

{% stylesheet %}
  .header {
    position: var(--header-position, sticky);
    top: 0;
    z-index: 100;
    color: var(--header-text, var(--color-text));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--header-bg, var(--color-accent)) 95%, black) 0%, var(--header-bg, var(--color-accent)) 100%);
    border-block-end: 1px solid color-mix(in srgb, var(--color-gold) 28%, transparent);
    transition:
      box-shadow var(--duration-base) var(--ease-default),
      background-color var(--duration-base) var(--ease-default),
      border-color var(--duration-base) var(--ease-default);
  }

  .header::after {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, color-mix(in srgb, var(--color-gold) 58%, transparent) 48%, transparent 100%);
    opacity: 0.8;
    pointer-events: none;
  }

  .header.is-sticky {
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    background-color: color-mix(in srgb, var(--header-bg, var(--color-accent)) 90%, transparent);
    box-shadow:
      0 1px 0 color-mix(in srgb, var(--color-gold) 24%, transparent),
      0 18px 40px rgba(10, 18, 14, 0.18);
    border-block-end-color: transparent;
  }

  .shopify-section-group-header-group .shopify-section {
    padding-block: 0;
  }

  .header__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(var(--space-4), 2vw, var(--space-8));
    height: var(--header-height, 5rem);
    width: min(
      calc(var(--page-width) - (var(--page-margin) * 2)),
      calc(100% - (var(--page-margin) * 2))
    );
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: 0;
  }

  .header__start,
  .header__end {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 0;
  }

  .header__end {
    justify-content: flex-end;
  }

  .header__logo {
    display: flex;
    justify-content: center;
    min-width: 0;
  }

  .header__logo a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: inherit;
  }

  .header__logo-img {
    display: block;
    width: min(var(--logo-width, 150px), var(--logo-max-width, 170px));
    height: auto;
  }

  .header__logo-text {
    font-family: var(--font-heading);
    font-size: clamp(var(--text-xl), 2.6vw, var(--text-3xl));
    font-style: italic;
    letter-spacing: -0.03em;
    line-height: 1;
    white-space: nowrap;
    color: var(--color-gold-soft);
  }

  .header__icon-btn,
  .header__hamburger {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border: 1px solid color-mix(in srgb, var(--color-gold) 34%, transparent);
    border-radius: 999px;
    background-color: color-mix(in srgb, var(--header-bg, var(--color-accent)) 82%, white 6%);
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    padding: 0;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transition:
      transform var(--duration-fast) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default),
      background-color var(--duration-fast) var(--ease-default),
      opacity var(--duration-fast) var(--ease-default);
  }

  .header__icon-btn:hover,
  .header__hamburger:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--color-gold) 54%, transparent);
    background-color: color-mix(in srgb, var(--header-bg, var(--color-accent)) 72%, white 12%);
  }

  .header__icon-btn--muted {
    opacity: 0.35;
    cursor: default;
  }

  .header__cart-count {
    position: absolute;
    top: -3px;
    right: -3px;
    min-width: 1rem;
    height: 1rem;
    padding-inline: 3px;
    border-radius: 999px;
    background-color: var(--color-gold);
    color: #182015;
    font-size: 0.5625rem;
    font-weight: 700;
    line-height: 1rem;
    text-align: center;
    box-shadow: 0 10px 18px rgba(24, 32, 21, 0.2);
  }

  .header__hamburger {
    display: none;
  }

  .header__nav {
    min-width: 0;
  }

  .header__nav-list {
    display: flex;
    align-items: center;
    gap: clamp(var(--space-3), 1.8vw, var(--space-8));
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__nav-item {
    position: relative;
  }

  .header__nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding-block: 1.5rem;
    background: none;
    border: none;
    color: color-mix(in srgb, var(--header-text, white) 80%, transparent);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    position: relative;
    transition: color var(--duration-fast) var(--ease-default);
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: 1.05rem;
    height: 1px;
    background: linear-gradient(90deg, var(--color-gold) 0%, color-mix(in srgb, var(--color-gold-soft) 80%, transparent) 100%);
    transition:
      right var(--duration-measured) var(--ease-brand),
      opacity var(--duration-fast) var(--ease-default);
    opacity: 0;
  }

  .header__nav-link:hover,
  .header__nav-link[aria-current="page"],
  .header__nav-item.is-active > .header__nav-link {
    color: var(--header-text, white);
  }

  .header__nav-link:hover::after,
  .header__nav-link[aria-current="page"]::after,
  .header__nav-item.is-active > .header__nav-link::after {
    right: 0;
    opacity: 1;
  }

  .header__nav-link .chevron {
    width: 0.7rem;
    height: 0.7rem;
    color: color-mix(in srgb, var(--color-gold-soft) 90%, transparent);
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .header__nav-item:hover > .header__nav-link .chevron,
  .header__nav-item:focus-within > .header__nav-link .chevron {
    transform: rotate(180deg);
  }

  .header__dropdown {
    position: absolute;
    top: calc(100% - 0.35rem);
    left: 0;
    min-width: 15rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-bg) 92%, white) 0%, color-mix(in srgb, var(--color-bg) 100%, var(--color-bg-warm)) 100%);
    border: 1px solid color-mix(in srgb, var(--color-gold) 28%, var(--color-border));
    border-radius: 1rem;
    box-shadow:
      0 24px 60px rgba(13, 20, 16, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    opacity: 0;
    pointer-events: none;
    translate: 0 0.75rem;
    transition:
      opacity var(--duration-measured) var(--ease-brand),
      translate var(--duration-measured) var(--ease-brand);
  }

  .header__nav-item--has-dropdown:hover .header__dropdown,
  .header__nav-item--has-dropdown:focus-within .header__dropdown,
  .header__dropdown:focus-within {
    opacity: 1;
    pointer-events: auto;
    translate: 0 0;
  }

  .header__dropdown-link {
    display: block;
    padding: 0.9rem 1.1rem;
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text);
    white-space: nowrap;
    transition:
      color var(--duration-fast) var(--ease-default),
      background-color var(--duration-fast) var(--ease-default);
  }

  .header__dropdown-link--parent {
    color: var(--color-accent);
  }

  .header__dropdown-link:hover,
  .header__dropdown-link[aria-current="page"] {
    color: var(--color-text);
    background-color: color-mix(in srgb, var(--color-gold) 10%, white);
  }

  .header-overlay {
    position: fixed;
    inset: 0;
    z-index: 110;
    background-color: var(--color-overlay);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-slow) var(--ease-out);
  }

  body.menu-open {
    overflow: hidden;
    overscroll-behavior: none;
  }

  body.menu-open .header-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  .header-drawer {
    position: fixed;
    inset-block: 0;
    inset-inline-start: 0;
    z-index: 120;
    width: min(100vw, 23rem);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-bg) 94%, white) 0%, color-mix(in srgb, var(--color-bg) 100%, var(--color-bg-warm)) 100%);
    display: flex;
    flex-direction: column;
    visibility: hidden;
    transform: translateX(-100%);
    box-shadow: 24px 0 70px rgba(13, 20, 16, 0.18);
    transition:
      transform var(--duration-measured) var(--ease-brand),
      visibility 0s linear var(--duration-measured);
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
  }

  .header-drawer.is-open {
    visibility: visible;
    transform: translateX(0);
    transition:
      transform var(--duration-measured) var(--ease-brand),
      visibility 0s linear 0s;
  }

  .header-drawer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: max(var(--space-8), env(safe-area-inset-top, 0px)) max(var(--space-7), env(safe-area-inset-right, 0px)) max(var(--space-7), env(safe-area-inset-bottom, 0px)) max(var(--space-7), env(safe-area-inset-left, 0px));
  }

  .header-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block-end: var(--space-6);
    border-block-end: 1px solid var(--color-border);
  }

  .header-drawer__brand-img {
    display: block;
    width: min(var(--logo-width, 90px), 110px);
    height: auto;
  }

  .header-drawer__brand-name {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-xl);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    color: var(--color-accent);
  }

  .header-drawer__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.75rem;
    min-height: 2.75rem;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background-color: color-mix(in srgb, var(--color-bg) 82%, white);
    color: inherit;
    cursor: pointer;
    transition:
      transform var(--duration-fast) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default);
  }

  .header-drawer__close:hover {
    transform: rotate(90deg);
    border-color: color-mix(in srgb, var(--color-text) 20%, transparent);
  }

  .header-drawer__nav,
  .header-drawer__sub {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header-drawer__link,
  .header-drawer__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-4);
    border-block-end: 1px solid var(--color-border);
    font-size: 0.71875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-default);
  }

  .header-drawer__link:hover,
  .header-drawer__summary:hover {
    color: var(--color-accent);
  }

  .header-drawer__link[aria-current="page"],
  .header-drawer__summary.is-active {
    color: var(--color-accent);
  }

  .header-drawer__details > summary {
    list-style: none;
  }

  .header-drawer__details > summary::-webkit-details-marker {
    display: none;
  }

  .header-drawer__summary .chevron {
    flex-shrink: 0;
    transition: transform var(--duration-fast) var(--ease-default);
  }

  .header-drawer__details[open] .header-drawer__summary .chevron {
    transform: rotate(180deg);
  }

  .header-drawer__link--sub {
    padding-inline-start: var(--space-6);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    border-block-end: none;
    color: var(--color-text-muted);
  }

  .header-drawer__link--parent {
    color: var(--color-accent);
  }

  .header-drawer__search {
    margin-block-start: auto;
    padding-block-start: var(--space-4);
    border-block-start: 1px solid var(--color-border);
  }

  .header-drawer__search input {
    background-color: color-mix(in srgb, var(--color-bg) 84%, white);
    border-color: var(--color-border);
    font-size: var(--text-sm);
  }

  .header,
  .header__icon-btn,
  .header__hamburger,
  .header-drawer__close,
  .header-drawer__link,
  .header-drawer__summary {
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .header {
    padding-block-start: env(safe-area-inset-top, 0px);
  }

  @media (max-width: 56.25rem) {
    .header__inner {
      height: 4.5rem;
      gap: var(--space-2);
    }

    .header__nav {
      display: none;
    }

    .header__hamburger {
      display: inline-flex;
    }

    .header__start,
    .header__end {
      gap: 0.35rem;
    }

    .header__search-btn {
      display: none;
    }

    .header__logo-img {
      width: min(var(--logo-width, 96px), 104px);
      image-rendering: -webkit-optimize-contrast;
    }

    .header__logo-text {
      font-size: var(--text-xl);
    }

    .header__icon-btn,
    .header__hamburger {
      width: 2.5rem;
      height: 2.5rem;
    }

    .header__cart-count {
      min-width: 0.8125rem;
      height: 0.8125rem;
      line-height: 0.8125rem;
      font-size: 0.4375rem;
      top: 0;
      right: 0;
      padding-inline: 2px;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    /* Header interactions are handled by theme.js. */
  })();
{% endjavascript %}

