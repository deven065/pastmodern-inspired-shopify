{%- comment -%}
  product-accordion.liquid
  Standalone section rendered below product-main on the product template.
  Each block is one accordion row. Structured types read from product metafields
  and fall back to the block's richtext content field.
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}

  <div class="product-accordion" data-accordion>

    {%- for block in section.blocks -%}

      {%- liquid
        assign acc_heading = block.settings.heading
        assign acc_content = nil

        # Each block type pulls from a known product metafield if available,
        # then falls back to the block's richtext content setting.
        case block.type
          when 'description'
            assign mf_val = product.description
            if mf_val != blank
              assign acc_content = mf_val
            else
              assign acc_content = block.settings.content
            endif

          when 'fabric'
            assign mf_val = product.metafields.custom.fabric.value
            if mf_val != blank
              assign acc_content = mf_val
            else
              assign acc_content = block.settings.content
            endif

          when 'care'
            assign mf_val = product.metafields.custom.care_instructions.value
            if mf_val != blank
              assign acc_content = mf_val
            else
              assign acc_content = block.settings.content
            endif

          when 'fit'
            assign mf_val = product.metafields.custom.fit_notes.value
            if mf_val != blank
              assign acc_content = mf_val
            else
              assign acc_content = block.settings.content
            endif

          when 'model'
            assign mf_val = product.metafields.custom.model_info.value
            if mf_val != blank
              assign acc_content = mf_val
            else
              assign acc_content = block.settings.content
            endif

          when 'shipping'
            assign mf_val = product.metafields.custom.shipping_info.value
            if mf_val != blank
              assign acc_content = mf_val
            else
              assign acc_content = block.settings.content
            endif

          when 'returns'
            assign mf_val = product.metafields.custom.returns_policy.value
            if mf_val != blank
              assign acc_content = mf_val
            else
              assign acc_content = block.settings.content
            endif

          else
            assign acc_content = block.settings.content
        endcase

        # Pair-it-with block: build product-card grid from metafield list
        if block.type == 'pair_it_with'
          assign pair_prods = product.metafields.custom.pair_it_with.value
          if pair_prods != blank
            assign acc_heading = block.settings.heading | default: 'Pair It With'
            capture pair_html
              echo '<div class="accordion-pair-grid">'
              for p in pair_prods limit: 4
                render 'product-card', product: p, show_sizes: false, lazy: true
              endfor
              echo '</div>'
            endcapture
            assign acc_content = pair_html
          endif
        endif
      -%}

      {%- if acc_heading != blank and acc_content != blank -%}
        <div class="accordion-item" {{ block.shopify_attributes }}>
          {%- render 'accordion-item',
            title:   acc_heading,
            content: acc_content,
            open:    block.settings.open_by_default
          -%}
        </div>
      {%- endif -%}

    {%- endfor -%}

  </div>

{%- endif -%}


{% stylesheet %}
  /* ── Strip default section spacing ── */
  .shopify-section:has(.product-accordion) {
    padding-block: 0;
  }

  /* ── Accordion wrapper ── */
  .product-accordion {
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    padding-block: var(--space-4) var(--space-16);
    border-block-end: 1px solid var(--color-border);
  }

  /* ── Accordion item container ── */
  .accordion-item {
    /* The trigger and panel sit as direct children; no extra wrapper needed */
  }

  /* ── Panel body — matches .accordion-body rendered by accordion-item.liquid ── */
  .accordion-body {
    padding-block: var(--space-5) var(--space-8);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
  }

  .accordion-body :is(p, ul, ol) {
    margin-block: var(--space-2);
  }

  .accordion-body :is(p, ul, ol):first-child { margin-block-start: 0; }
  .accordion-body :is(p, ul, ol):last-child  { margin-block-end:   0; }

  .accordion-body ul,
  .accordion-body ol {
    padding-inline-start: var(--space-5);
  }

  /* ── Final border ── */
  .accordion-item:last-child [data-accordion-content] {
    border-block-end: 1px solid var(--color-border);
  }

  /* ── "Pair it with" product mini-grid ── */
  .accordion-pair-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    padding-block: var(--space-4) var(--space-2);
  }

  @media (max-width: 48rem) {
    .accordion-pair-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}


