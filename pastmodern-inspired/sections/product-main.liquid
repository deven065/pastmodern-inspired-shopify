{%- comment -%}
  product-main.liquid — Premium PDP: gallery + purchase panel.
  JS hooks: [data-product-gallery], [data-gallery-main], [data-thumb],
            [data-variant-picker], [data-option-group], [data-variant-option],
            [data-product-form], [data-atc], [data-price], [data-compare-price],
            [data-qty-wrap], [data-qty-dec], [data-qty-inc], [data-qty-input],
            [data-atc-feedback], [data-sticky-atc], [data-sticky-atc-btn],
            [data-sticky-price], [data-option-selected]
{%- endcomment -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant

  # Section settings
  assign show_qty       = section.settings.show_quantity
  assign show_checkout  = section.settings.show_dynamic_checkout
  assign show_crumbs    = section.settings.show_breadcrumbs
  assign sticky_atc     = section.settings.sticky_atc_mobile
  assign size_guide_url = section.settings.size_guide_url

  # Trust messaging: section setting overrides metafield
  assign delivery      = product.metafields.custom.delivery_timeline.value
  assign shipping_note = product.metafields.custom.shipping_note.value
  assign return_note   = product.metafields.custom.return_note.value
  if section.settings.delivery_text != blank
    assign delivery = section.settings.delivery_text
  endif
  if section.settings.shipping_text != blank
    assign shipping_note = section.settings.shipping_text
  endif
  if section.settings.return_text != blank
    assign return_note = section.settings.return_text
  endif

  # Short intro: prefer metafield, fall back to description
  assign intro = product.metafields.custom.short_description.value
  if intro == blank and product.description != blank
    assign intro = product.description | strip_html | truncate: 220
  endif

  # Sale flag
  assign is_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign is_sale = true
  endif

  # Hide variant pickers for single-option default products
  assign show_pickers = true
  if product.variants.size == 1 and product.options.first == 'Title'
    assign show_pickers = false
  endif
-%}

{{- 'product.css' | asset_url | stylesheet_tag -}}

<script>window.__product = {{ product | json }};</script>

<section
  class="product-main"
  id="product-{{ product.id }}"
  data-section-id="{{ section.id }}"
  itemscope
  itemtype="https://schema.org/Product"
>
  <div class="product-main__inner">

    {%- comment -%}━━━━━━━━━━━━━━━━━━━━━━━━ GALLERY (left) ━━━━━━━━━━━━━━━━━━━━━━━━{%- endcomment -%}
        {%- assign pdp_img_alt = first_media.alt | default: product.title | escape -%}
    <div
      class="product-gallery"
      data-product-gallery
    >

      {%- comment -%} Thumbnail strip (hidden for single-image products) {%- endcomment -%}
      {%- if product.media.size > 1 -%}
        <div
          class="product-gallery__thumbs"
          role="list"
          aria-label="Product images"
        >
          {%- for media in product.media -%}
            <button
              class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
              type="button"
              role="listitem"
              data-thumb
              data-media-id="{{ media.id }}"
              data-full-src="{{ media | image_url: width: 1500 }}"
              data-full-srcset="{{ media | image_url: width: 600 }} 600w, {{ media | image_url: width: 900 }} 900w, {{ media | image_url: width: 1200 }} 1200w, {{ media | image_url: width: 1500 }} 1500w"
              aria-pressed="{{ forloop.first | json }}"
              aria-label="{{ media.alt | default: product.title | escape }}"
            >
              {{
                media
                | image_url: width: 150
                | image_tag:
                    width: 90,
                    height: 120,
                    loading: 'lazy',
                    alt: media.alt | default: product.title | escape
              }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Main image {%- endcomment -%}
      <div class="product-gallery__main-wrap">
        {%- assign first_media = product.selected_media | default: product.featured_media -%}
        {%- if first_media != blank -%}
          {{
            first_media
            | image_url: width: 1400
            | image_tag:
                width: first_media.preview_image.width,
                height: first_media.preview_image.height,
                sizes: '(max-width: 59.999rem) 100vw, 55vw',
                widths: '600, 900, 1200, 1400',
                loading: 'eager',
                fetchpriority: 'high',
                class: 'product-gallery__main-img',
                alt: pdp_img_alt,
                itemprop: 'image',
                data: { 'gallery-main': '' }
          }}
        {%- else -%}
          <div class="product-gallery__no-image">
            {{ 'product-apparel-2' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      </div>

    </div>

    {%- comment -%}━━━━━━━━━━━━━━━━━━━━━━━━ PURCHASE PANEL (right) ━━━━━━━━━━━━━━━━━━━━━━━━{%- endcomment -%}

    <div class="product-panel">

      {%- comment -%} Breadcrumbs {%- endcomment -%}
      {%- if show_crumbs -%}
        <nav aria-label="Breadcrumb">
          <ol class="product-breadcrumbs">
            <li>
              <a href="{{ routes.root_url }}" class="product-breadcrumbs__link">Home</a>
              <span class="product-breadcrumbs__sep" aria-hidden="true">&#8250;</span>
            </li>
            {%- if collection != blank -%}
              <li>
                <a href="{{ collection.url }}" class="product-breadcrumbs__link">
                  {{- collection.title | escape -}}
                </a>
                <span class="product-breadcrumbs__sep" aria-hidden="true">&#8250;</span>
              </li>
            {%- elsif product.collections.first != blank -%}
              <li>
                <a href="{{ product.collections.first.url }}" class="product-breadcrumbs__link">
                  {{- product.collections.first.title | escape -}}
                </a>
                <span class="product-breadcrumbs__sep" aria-hidden="true">&#8250;</span>
              </li>
            {%- endif -%}
            <li aria-current="page">{{ product.title | escape | truncate: 50 }}</li>
          </ol>
        </nav>
      {%- endif -%}

      {%- comment -%} Vendor {%- endcomment -%}
      {%- if product.vendor != blank -%}
        <p
          class="product-vendor eyebrow"
          itemprop="brand"
          itemscope
          itemtype="https://schema.org/Brand"
        ><span itemprop="name">{{ product.vendor | escape }}</span></p>
      {%- endif -%}

      {%- comment -%} Title {%- endcomment -%}
      <h1 class="product-panel__title" itemprop="name">
        {{ product.title | escape }}
      </h1>

      {%- comment -%} Price {%- endcomment -%}
      <div
        class="product-price-row"
        aria-live="polite"
        aria-atomic="true"
        itemprop="offers"
        itemscope
        itemtype="https://schema.org/Offer"
      >
        <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
        <meta
          itemprop="availability"
          content="https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}"
        >

        {%- if is_sale -%}
          <s class="product-price-compare" data-compare-price>
            {{- current_variant.compare_at_price | money -}}
          </s>
          <span
            class="product-price-current"
            data-price
            itemprop="price"
            content="{{ current_variant.price | divided_by: 100.0 }}"
          >{{- current_variant.price | money -}}</span>
          <span class="product-price-badge">Sale</span>
        {%- else -%}
          <span
            class="product-price-current"
            data-price
            itemprop="price"
            content="{{ current_variant.price | divided_by: 100.0 }}"
          >{{- current_variant.price | money -}}</span>
          <s
            class="product-price-compare"
            data-compare-price
            {% unless current_variant.compare_at_price > current_variant.price %}hidden{% endunless %}
          >{{- current_variant.compare_at_price | money -}}</s>
        {%- endif -%}

        {%- comment -%} Low-stock nudge {%- endcomment -%}
        {%- if current_variant.inventory_management == 'shopify'
              and current_variant.inventory_policy == 'deny'
              and current_variant.inventory_quantity > 0
              and current_variant.inventory_quantity <= 5 -%}
          <span class="product-price-badge" style="color: inherit; border-color: inherit;">
            Only {{ current_variant.inventory_quantity }} left
          </span>
        {%- endif -%}
      </div>

      {%- comment -%} Star rating (metafields — compatible with Judge.me / Okendo / Yotpo) {%- endcomment -%}
      {%- assign pdp_rating = product.metafields.reviews.rating.value -%}
      {%- assign pdp_count  = product.metafields.reviews.rating_count.value -%}
      {%- if pdp_rating != blank and pdp_count != blank and pdp_count > 0 -%}
        <div class="product-rating" aria-label="{{ pdp_rating | round: 1 }} out of 5 stars">
          <svg class="product-rating__star" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" focusable="false" width="12" height="12">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/>
          </svg>
          <span class="product-rating__value">{{ pdp_rating | round: 1 }}</span>
          <span class="product-rating__count">{{ pdp_count }} reviews</span>
        </div>
      {%- endif -%}

      {%- comment -%} Short intro {%- endcomment -%}
      {%- if intro != blank -%}
        <p class="product-intro">{{ intro }}</p>
      {%- endif -%}

      {%- comment -%}══════════════ PRODUCT FORM ══════════════{%- endcomment -%}
      {%- form 'product', product,
          id: 'product-form',
          data-product-form: '',
          novalidate: 'novalidate'
      -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        {%- comment -%} Variant pickers {%- endcomment -%}
        {%- if show_pickers -%}
          <div class="product-options" data-variant-picker>

            {%- for option in product.options_with_values -%}
              {%- liquid
                assign opt_down         = option.name | downcase
                assign opt_index        = forloop.index0
                assign is_color_option  = false
                if opt_down == 'color' or opt_down == 'colour'
                  assign is_color_option = true
                endif
              -%}

              <div class="product-option" data-option-group>
                <div class="product-option__header">
                  <span class="product-option__label">{{ option.name | escape }}</span>

                  <span
                    class="product-option__selected"
                    data-option-selected="{{ opt_index }}"
                  >{{- current_variant.options[opt_index] | escape -}}</span>

                  {%- if opt_down == 'size' and size_guide_url != blank -%}
                    <a
                      href="{{ size_guide_url }}"
                      class="product-size-guide"
                      target="_blank"
                      rel="noopener noreferrer"
                    >Size guide</a>
                  {%- endif -%}
                </div>

                <div class="product-option__values">
                  {%- for value in option.values -%}
                    {%- liquid
                      assign is_selected    = false
                      assign val_available  = false
                      if current_variant.options[opt_index] == value
                        assign is_selected = true
                      endif
                      for variant in product.variants
                        if variant.options[opt_index] == value and variant.available
                          assign val_available = true
                          break
                        endif
                      endfor
                    -%}

                    {%- if is_color_option -%}
                      <button
                        class="variant-pill variant-pill--color{% unless val_available %} variant-pill--oos{% endunless %}"
                        type="button"
                        data-variant-option="{{ value | escape }}"
                        aria-pressed="{{ is_selected | json }}"
                        aria-label="{{ value | escape }}{% unless val_available %} — sold out{% endunless %}"
                        style="--swatch: {{ value | downcase }};"
                      >
                        <span class="swatch-dot" aria-hidden="true"></span>
                        <span class="visually-hidden">{{ value | escape }}</span>
                      </button>
                    {%- else -%}
                      <button
                        class="variant-pill{% unless val_available %} variant-pill--oos{% endunless %}"
                        type="button"
                        data-variant-option="{{ value | escape }}"
                        aria-pressed="{{ is_selected | json }}"
                        aria-label="{{ value | escape }}{% unless val_available %} — sold out{% endunless %}"
                      >{{- value | escape -}}</button>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}

          </div>
        {%- endif -%}

        {%- comment -%} Quantity + ATC row {%- endcomment -%}
        <div class="product-buy-row">

          {%- if show_qty -%}
            <div class="product-qty" role="group" aria-label="Quantity" data-qty-wrap>
              <button
                type="button"
                class="product-qty__btn"
                data-qty-dec
                aria-label="Decrease quantity"
              >&#8722;</button>
              <input
                class="product-qty__input"
                type="number"
                name="quantity"
                value="1"
                min="1"
                max="{{ current_variant.inventory_quantity | default: 999 }}"
                aria-label="Quantity"
                data-qty-input
              >
              <button
                type="button"
                class="product-qty__btn"
                data-qty-inc
                aria-label="Increase quantity"
              >&#43;</button>
            </div>
          {%- else -%}
            <input type="hidden" name="quantity" value="1">
          {%- endif -%}

          <button
            type="submit"
            class="product-atc btn-full"
            data-atc
            data-label-add="{{ section.settings.atc_label | default: 'Add to bag' | escape }}"
            data-label-sold-out="{{ section.settings.sold_out_label | default: 'Sold out' | escape }}"
            {%- unless current_variant.available %} disabled aria-disabled="true"{% endunless %}
            aria-live="polite"
          >
            {%- if current_variant.available -%}
              {{- section.settings.atc_label | default: 'Add to bag' -}}
            {%- else -%}
              {{- section.settings.sold_out_label | default: 'Sold out' -}}
            {%- endif -%}
          </button>

        </div>

        {%- comment -%} Feedback / error line {%- endcomment -%}
        <p
          class="product-atc-feedback"
          aria-live="polite"
          aria-atomic="true"
          data-atc-feedback
        ></p>
        <p class="product-form__error visually-hidden" data-form-error hidden role="alert" aria-live="assertive"></p>

        {%- comment -%} Dynamic checkout {%- endcomment -%}
        {%- if show_checkout -%}
          <div class="product-dynamic-checkout">
            {{- form | payment_button -}}
          </div>
        {%- endif -%}

      {%- endform -%}

      {%- comment -%}══════════════ TRUST STRIP ══════════════{%- endcomment -%}
      {%- if delivery != blank or shipping_note != blank or return_note != blank -%}
        <div class="product-trust">

          {%- if delivery != blank -%}
            <div class="product-trust__item">
              <svg class="product-trust__icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" aria-hidden="true">
                <circle cx="8" cy="8" r="7"/>
                <polyline points="8,4 8,8 11,10"/>
              </svg>
              <div class="product-trust__text">
                <strong>Delivery</strong>
                {{ delivery | escape }}
              </div>
            </div>
          {%- endif -%}

          {%- if shipping_note != blank -%}
            <div class="product-trust__item">
              <svg class="product-trust__icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" aria-hidden="true">
                <rect x="1" y="5" width="14" height="8" rx="1"/>
                <path d="M3 5V4a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v1M1 9h14"/>
              </svg>
              <div class="product-trust__text">
                <strong>Shipping</strong>
                {{ shipping_note | escape }}
              </div>
            </div>
          {%- endif -%}

          {%- if return_note != blank -%}
            <div class="product-trust__item">
              <svg class="product-trust__icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" aria-hidden="true">
                <path d="M13 8A5 5 0 1 1 8 3"/>
                <polyline points="8 1 11 3 8 5"/>
              </svg>
              <div class="product-trust__text">
                <strong>Returns</strong>
                {{ return_note | escape }}
              </div>
            </div>
          {%- endif -%}

        </div>
      {%- endif -%}

    </div>

  </div>
</section>

{%- comment -%}━━━━━━━━━━━━━━━━━━ STICKY MOBILE ATC BAR ━━━━━━━━━━━━━━━━━━{%- endcomment -%}
{%- if sticky_atc -%}
  <div
    class="product-sticky-atc"
    data-sticky-atc
    aria-hidden="true"
  >
    <div class="product-sticky-atc__inner">
      <div class="product-sticky-atc__info">
        <p class="product-sticky-atc__title">{{ product.title | escape }}</p>
        <p class="product-sticky-atc__price" data-sticky-price>
          {{- current_variant.price | money -}}
        </p>
      </div>
      <button
        class="product-sticky-atc__btn"
        type="button"
        data-sticky-atc-btn
        {%- unless current_variant.available %} disabled{%- endunless %}
      >
        {%- if current_variant.available -%}Add to bag{%- else -%}Sold out{%- endif -%}
      </button>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product Main",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "Show quantity selector",
      "default": false,
      "info": "Hide for a cleaner purchase area — luxury convention"
    },
    {
      "type": "header",
      "content": "Purchase"
    },
    {
      "type": "text",
      "id": "atc_label",
      "label": "Add to bag label",
      "default": "Add to bag"
    },
    {
      "type": "text",
      "id": "sold_out_label",
      "label": "Sold out label",
      "default": "Sold out"
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Show dynamic checkout button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "sticky_atc_mobile",
      "label": "Sticky add-to-cart bar on mobile",
      "default": true
    },
    {
      "type": "url",
      "id": "size_guide_url",
      "label": "Size guide URL",
      "info": "Appears next to the Size option label"
    },
    {
      "type": "header",
      "content": "Trust messaging"
    },
    {
      "type": "text",
      "id": "delivery_text",
      "label": "Delivery timeline",
      "placeholder": "e.g. 3–5 business days",
      "info": "Overrides metafield custom.delivery_timeline"
    },
    {
      "type": "text",
      "id": "shipping_text",
      "label": "Shipping note",
      "placeholder": "e.g. Complimentary on orders over $200",
      "info": "Overrides metafield custom.shipping_note"
    },
    {
      "type": "text",
      "id": "return_text",
      "label": "Return policy note",
      "placeholder": "e.g. Free returns within 30 days",
      "info": "Overrides metafield custom.return_note"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
