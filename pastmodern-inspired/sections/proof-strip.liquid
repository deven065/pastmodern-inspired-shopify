{%- liquid
  assign proof_1_label = settings.proof_item_1_label
  assign proof_1_text = settings.proof_item_1_text
  assign proof_2_label = settings.proof_item_2_label
  assign proof_2_text = settings.proof_item_2_text
  assign proof_3_label = settings.proof_item_3_label
  assign proof_3_text = settings.proof_item_3_text
-%}

<section class="proof-strip" aria-label="Shopping reassurance">
  <div class="proof-strip__inner">
    <article class="proof-strip__item">
      <span class="proof-strip__icon" aria-hidden="true">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.25">
          <circle cx="10" cy="10" r="8"/>
          <path d="M10 5v5l3 2"/>
        </svg>
      </span>
      <div class="proof-strip__copy">
        <p class="proof-strip__label">{{ proof_1_label | default: 'Dispatch' | escape }}</p>
        <p class="proof-strip__text">{{ proof_1_text | default: 'Ships in 3–5 business days.' | escape }}</p>
      </div>
    </article>

    <article class="proof-strip__item">
      <span class="proof-strip__icon" aria-hidden="true">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.25">
          <path d="M15.4 6.8A5.4 5.4 0 0 0 6 10.3L4.5 11.8a.9.9 0 0 0 .63 1.54h3.15"/>
          <path d="M4.6 13.2A5.4 5.4 0 0 0 14 9.7l1.5-1.5a.9.9 0 0 0-.63-1.54h-3.15"/>
        </svg>
      </span>
      <div class="proof-strip__copy">
        <p class="proof-strip__label">{{ proof_2_label | default: 'Returns' | escape }}</p>
        <p class="proof-strip__text">{{ proof_2_text | default: 'Easy exchanges and returns within 30 days.' | escape }}</p>
      </div>
    </article>

    <article class="proof-strip__item">
      <span class="proof-strip__icon" aria-hidden="true">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.25">
          <path d="M10 2 4.4 4.3v4.8c0 4.1 2.4 7.8 5.6 8.9 3.2-1.1 5.6-4.8 5.6-8.9V4.3L10 2Z"/>
          <path d="m7.7 10 1.55 1.55L12.8 8"/>
        </svg>
      </span>
      <div class="proof-strip__copy">
        <p class="proof-strip__label">{{ proof_3_label | default: 'Craft' | escape }}</p>
        <p class="proof-strip__text">{{ proof_3_text | default: 'Small-batch pieces with premium finishing.' | escape }}</p>
      </div>
    </article>
  </div>
</section>

{% stylesheet %}
  .shopify-section:has(.proof-strip) {
    padding-block: 0;
  }

  .proof-strip {
    margin-block: 0;
    background:
      radial-gradient(circle at top center, color-mix(in srgb, var(--color-gold) 14%, transparent) 0%, transparent 34%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-bg) 92%, white) 0%, color-mix(in srgb, var(--color-bg) 98%, var(--color-bg-warm)) 100%);
  }

  .proof-strip__inner {
    width: min(calc(var(--page-width) - (var(--page-margin) * 2)), calc(100% - (var(--page-margin) * 2)));
    max-width: var(--page-width);
    margin-inline: auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(var(--space-3), 2vw, var(--space-5));
    padding-block: clamp(var(--space-5), 2vw, var(--space-8));
  }

  .proof-strip__item {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: clamp(var(--space-4), 2vw, var(--space-5));
    border: 1px solid color-mix(in srgb, var(--color-gold) 22%, var(--color-border));
    border-radius: 1.25rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-surface) 94%, white) 0%, color-mix(in srgb, var(--color-blush) 10%, var(--color-surface-strong)) 100%);
    box-shadow:
      0 14px 28px color-mix(in srgb, var(--color-accent) 8%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.52);
    transition:
      transform var(--duration-base) var(--ease-default),
      box-shadow var(--duration-base) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default);
  }

  .proof-strip__item:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--color-gold) 42%, var(--color-border));
    box-shadow:
      0 18px 36px color-mix(in srgb, var(--color-gold) 10%, transparent),
      inset 0 1px 0 rgba(255, 255, 255, 0.56);
  }

  .proof-strip__icon {
    width: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: color-mix(in srgb, var(--color-accent) 72%, var(--color-gold) 28%);
    flex-shrink: 0;
    margin-block-start: 0.1rem;
    border: 1px solid color-mix(in srgb, var(--color-gold) 24%, var(--color-border));
    border-radius: 999px;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--color-blush) 28%, white) 0%, color-mix(in srgb, var(--color-surface) 100%, var(--color-bg)) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.56),
      0 10px 20px color-mix(in srgb, var(--color-gold) 8%, transparent);
  }

  .proof-strip__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .proof-strip__copy {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .proof-strip__label {
    margin: 0;
    font-size: 0.625rem;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text);
  }

  .proof-strip__text {
    margin: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 26ch;
  }

  @media (max-width: 48rem) {
    .proof-strip__inner {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .proof-strip__item {
      padding: var(--space-4);
    }

    .proof-strip__text {
      max-width: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Proof strip",
  "settings": [],
  "presets": [
    {
      "name": "Proof strip"
    }
  ]
}
{% endschema %}
