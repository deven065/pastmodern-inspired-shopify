{% comment %}
  This section is used in the search template to render search results for
  products, articles, and pages.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/search
{% endcomment %}

{%- liquid
  assign featured_search_terms = 'Satin dresses,Ruched mini,Bridal corset,Column skirt' | split: ','
-%}

<section class="search-page">
  <div class="search-page__hero">
    <p class="eyebrow search-page__eyebrow">Discover the edit</p>
    <h1 class="search-page__title">{{ 'search.title' | t }}</h1>
    <p class="search-page__intro">
      Search products, pages, and editorial pieces in one place, with results styled to feel as considered as the collection itself.
    </p>
  </div>

  <div class="search-page__surface">
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-page__form">
      <label class="visually-hidden" for="search-page-input">{{ 'search.placeholder' | t }}</label>

      <div class="search-page__field">
        <span class="search-page__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="6.5"></circle>
            <path d="m16 16 5 5"></path>
          </svg>
        </span>

        <input
          id="search-page-input"
          class="search-page__input"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.placeholder' | t }}"
          autocomplete="off"
        >

        <button type="submit" class="btn btn-primary search-page__submit">
          {{ 'search.submit' | t }}
        </button>
      </div>

      <div class="search-page__quick-links" aria-label="Popular searches">
        <span class="search-page__quick-label">Popular</span>
        {%- for term in featured_search_terms -%}
          <a
            href="{{ routes.search_url }}?q={{ term | strip | url_encode }}"
            class="search-page__quick-link"
          >{{ term | strip }}</a>
        {%- endfor -%}
      </div>
    </form>
  </div>

  {% if search.performed %}
    {% paginate search.results by 20 %}
      {% if search.results_count == 0 %}
        <div class="search-page__empty">
          <p class="eyebrow search-page__empty-eyebrow">No exact match</p>
          <h2 class="search-page__empty-title">
            Nothing matched “{{ search.terms | escape }}” yet
          </h2>
          <p class="search-page__empty-text">
            Try a broader phrase, search by product type, or start with one of the popular searches above.
          </p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn-secondary">
            Browse the full collection
          </a>
        </div>
      {% else %}
        <div class="search-page__results-meta">
          <p class="search-page__results-count">
            {{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}
          </p>
        </div>

        <div class="search-page__results-grid">
          {% for result in search.results %}
            {%- liquid
              assign featured_image = result.featured_image | default: result.image
              assign result_type = result.object_type | default: 'item'
              assign result_label = result_type | capitalize
              assign result_excerpt = blank

              case result_type
                when 'product'
                  assign result_excerpt = result.description | strip_html | truncate: 140
                when 'article'
                  assign result_excerpt = result.excerpt_or_content | strip_html | truncate: 140
                else
                  assign result_excerpt = result.content | strip_html | truncate: 140
              endcase
            -%}

            <article class="search-card search-card--{{ result_type }}">
              <a href="{{ result.url }}" class="search-card__media-link" aria-label="{{ result.title | escape }}">
                {%- if featured_image -%}
                  {% render 'image', class: 'search-card__media', image: featured_image, width: 560 %}
                {%- else -%}
                  <div class="search-card__media search-card__media--placeholder">
                    {{ 'product-apparel-2' | placeholder_svg_tag: 'search-card__placeholder' }}
                  </div>
                {%- endif -%}
              </a>

              <div class="search-card__body">
                <div class="search-card__topline">
                  <span class="search-card__type">{{ result_label }}</span>
                  {%- if result_type == 'product' and result.price -%}
                    <span class="search-card__price">
                      {%- if result.compare_at_price > result.price -%}
                        <s class="search-card__compare">{{ result.compare_at_price | money }}</s>
                      {%- endif -%}
                      {{ result.price | money_with_currency }}
                    </span>
                  {%- endif -%}
                </div>

                <h2 class="search-card__title">
                  <a href="{{ result.url }}">{{ result.title }}</a>
                </h2>

                {%- if result_excerpt != blank -%}
                  <p class="search-card__excerpt">{{ result_excerpt }}</p>
                {%- endif -%}

                <a href="{{ result.url }}" class="search-card__cta">
                  {%- if result_type == 'product' -%}
                    View product
                  {%- elsif result_type == 'article' -%}
                    Read article
                  {%- else -%}
                    Open page
                  {%- endif -%}
                </a>
              </div>
            </article>
          {% endfor %}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="search-page__pagination">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}
      {% endif %}
    {% endpaginate %}
  {% endif %}
</section>

{% stylesheet %}
  .shopify-section:has(.search-page) {
    padding-block: 0;
  }

  .search-page {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    padding:
      clamp(var(--space-12), 7vw, var(--space-20))
      max(var(--page-margin), calc((100vw - var(--page-width)) / 2))
      clamp(var(--space-14), 8vw, var(--space-24));
    overflow: hidden;
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--color-gold) 22%, transparent) 0%, transparent 28%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-bg) 86%, white) 0%, color-mix(in srgb, var(--color-bg) 96%, var(--color-bg-warm)) 100%);
  }

  .search-page::before,
  .search-page::after {
    content: '';
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
    filter: blur(0.5px);
  }

  .search-page::before {
    inset: auto auto 12% -6rem;
    width: 13rem;
    height: 13rem;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 12%, transparent) 0%, transparent 72%);
  }

  .search-page::after {
    inset: 4rem -2rem auto auto;
    width: 18rem;
    height: 18rem;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-gold) 18%, transparent) 0%, transparent 70%);
  }

  .search-page__hero,
  .search-page__surface,
  .search-page__results-meta,
  .search-page__results-grid,
  .search-page__pagination,
  .search-page__empty {
    position: relative;
    z-index: 1;
  }

  .search-page__hero {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 44rem;
  }

  .search-page__eyebrow {
    margin: 0;
  }

  .search-page__title {
    margin: 0;
    font-size: clamp(4.5rem, 10vw, 7.5rem);
    line-height: 0.92;
  }

  .search-page__intro {
    margin: 0;
    max-width: 38rem;
    font-size: clamp(var(--text-base), 1.8vw, var(--text-md));
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
  }

  .search-page__surface {
    padding: clamp(var(--space-5), 3vw, var(--space-8));
    border: 1px solid color-mix(in srgb, var(--color-gold) 24%, var(--color-border));
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0.48) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.4),
      0 24px 60px rgba(24, 34, 28, 0.08);
    backdrop-filter: blur(18px);
  }

  .search-page__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .search-page__field {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    border: 1px solid color-mix(in srgb, var(--color-gold) 28%, var(--color-border));
    background-color: rgba(255, 255, 255, 0.58);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }

  .search-page__field:focus-within {
    border-color: color-mix(in srgb, var(--color-gold) 54%, var(--color-border));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      0 0 0 5px color-mix(in srgb, var(--color-gold) 12%, transparent);
  }

  .search-page__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    color: var(--color-text-muted);
  }

  .search-page__icon svg {
    width: 1.2rem;
    height: 1.2rem;
    display: block;
  }

  .search-page__input {
    min-width: 0;
    border: none;
    background: transparent;
    box-shadow: none;
    padding: 0;
    font-size: clamp(var(--text-md), 2vw, var(--text-lg));
  }

  .search-page__input:focus {
    outline: none;
    box-shadow: none;
    background: transparent;
  }

  .search-page__submit {
    min-width: 8.5rem;
  }

  .search-page__quick-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-3);
  }

  .search-page__quick-label {
    font-size: 0.625rem;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .search-page__quick-link {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-gold) 22%, var(--color-border));
    background-color: rgba(255, 255, 255, 0.4);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default),
      transform var(--duration-fast) var(--ease-default),
      color var(--duration-fast) var(--ease-default);
  }

  .search-page__quick-link:hover {
    color: var(--color-text);
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--color-gold) 46%, var(--color-border));
    background-color: color-mix(in srgb, var(--color-gold) 8%, white);
  }

  .search-page__results-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .search-page__results-count {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .search-page__results-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(var(--space-4), 2vw, var(--space-6));
  }

  .search-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-gold) 18%, var(--color-border));
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0.58) 100%);
    box-shadow: var(--shadow-soft);
  }

  .search-card__media-link {
    display: block;
    text-decoration: none;
  }

  .search-card__media,
  .search-card__media.image {
    aspect-ratio: 4 / 5;
    background-color: color-mix(in srgb, var(--color-bg) 90%, white);
  }

  .search-card__media > img,
  .search-card__media.image > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .search-card__media--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 18rem;
  }

  .search-card__placeholder {
    width: 46%;
    height: auto;
    opacity: 0.26;
  }

  .search-card__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: clamp(var(--space-5), 2vw, var(--space-6));
  }

  .search-card__topline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .search-card__type,
  .search-card__price {
    font-size: 0.625rem;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .search-card__compare {
    margin-inline-end: 0.35rem;
    opacity: 0.65;
  }

  .search-card__title {
    margin: 0;
    font-size: clamp(var(--text-xl), 2vw, var(--text-2xl));
  }

  .search-card__title a {
    text-decoration: none;
    color: inherit;
  }

  .search-card__title a:hover {
    color: var(--color-accent);
  }

  .search-card__excerpt {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .search-card__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: auto;
    font-size: 0.6875rem;
    letter-spacing: var(--tracking-brand);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text);
  }

  .search-card__cta:hover {
    color: var(--color-accent);
  }

  .search-page__empty {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    max-width: 36rem;
    padding: clamp(var(--space-8), 4vw, var(--space-12));
    border: 1px solid color-mix(in srgb, var(--color-gold) 22%, var(--color-border));
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.76) 0%, rgba(255, 255, 255, 0.58) 100%);
    box-shadow: var(--shadow-soft);
  }

  .search-page__empty-eyebrow,
  .search-page__empty-title,
  .search-page__empty-text {
    margin: 0;
  }

  .search-page__empty-title {
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
  }

  .search-page__empty-text {
    max-width: 34ch;
    color: var(--color-text-muted);
  }

  .search-page__pagination {
    margin-top: var(--space-4);
  }

  .search-page__pagination .pagination {
    justify-content: flex-start;
  }

  @media (max-width: 64rem) {
    .search-page__results-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 48rem) {
    .search-page {
      gap: var(--space-8);
      padding-inline: var(--page-margin);
    }

    .search-page__title {
      font-size: clamp(3.5rem, 18vw, 5rem);
    }

    .search-page__field {
      grid-template-columns: 1fr;
      align-items: stretch;
    }

    .search-page__icon {
      display: none;
    }

    .search-page__submit {
      width: 100%;
    }

    .search-page__results-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
