{%- liquid
  assign show_brand   = section.settings.show_brand_col
  assign brand_text   = section.settings.brand_text
  assign show_social  = section.settings.show_social
  assign show_payment = section.settings.show_payment
  assign policy_menu  = section.settings.policy_menu
  assign contact_text = section.settings.contact_text
  assign has_conversion_links = false

  if settings.shipping_policy_url != blank or settings.returns_policy_url != blank or settings.size_help_url != blank or settings.support_url != blank
    assign has_conversion_links = true
  endif

  assign nav_block_count = 0
  for block in section.blocks
    if block.type == 'nav_column'
      assign nav_block_count = nav_block_count | plus: 1
    endif
  endfor
-%}

<footer class="site-footer full-width" role="contentinfo">

  {%- comment -%} ── Newsletter strip — full-width above column grid ── {%- endcomment -%}
  {%- if section.settings.show_newsletter -%}
    <div class="footer__newsletter-strip">
      <div class="footer__newsletter-intro">
        {%- if section.settings.newsletter_heading != blank -%}
          <p class="footer__newsletter-heading">{{ section.settings.newsletter_heading }}</p>
        {%- endif -%}
        {%- if section.settings.newsletter_sub_text != blank -%}
          <p class="footer__newsletter-sub">{{ section.settings.newsletter_sub_text }}</p>
        {%- endif -%}
      </div>
      {%- form 'customer', id: 'footer-newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p class="footer__newsletter-success">Thank you for subscribing.</p>
        {%- else -%}
          <div class="footer__newsletter-field">
            <label class="visually-hidden" for="footer-email">Email address</label>
            <input
              type="email"
              id="footer-email"
              name="contact[email]"
              placeholder="Your email address"
              autocomplete="email"
              required
            >
            <button type="submit" aria-label="Subscribe">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </button>
          </div>
          {%- if form.errors -%}
            <p class="footer__newsletter-error">{{ form.errors.translated_fields.first | capitalize }} {{ form.errors.messages.first }}</p>
          {%- endif -%}
        {%- endif -%}
      {%- endform -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Upper: brand + nav columns + contact ── {%- endcomment -%}
  <div
    class="footer__upper"
    style="--footer-nav-cols: {{ nav_block_count | at_least: 1 }};"
  >

    {%- comment -%} Brand column ── {%- endcomment -%}
    {%- if show_brand -%}
      <div class="footer__brand">
        {%- if section.settings.logo != blank -%}
          {{- section.settings.logo | image_url: width: 200 | image_tag:
              width: section.settings.logo_width,
              alt: shop.name,
              class: 'footer__logo',
              loading: 'lazy'
          -}}
        {%- else -%}
          <a href="{{ routes.root_url }}" class="footer__brand-name">
            <span class="footer__brand-name-text">{{ shop.name }}</span>
          </a>
        {%- endif -%}

        {%- if brand_text != blank -%}
          <p class="footer__brand-text text-muted">{{ brand_text }}</p>
        {%- endif -%}

        {%- if show_social -%}
          <ul class="footer__social" role="list" aria-label="Social media">
            {%- liquid
              assign social_accounts = 'instagram,tiktok,pinterest,facebook,twitter,youtube' | split: ','
              assign social_labels   = 'Instagram,TikTok,Pinterest,Facebook,Twitter,YouTube' | split: ','
              assign social_id_keys  = 'social_instagram_link,social_tiktok_link,social_pinterest_link,social_facebook_link,social_twitter_link,social_youtube_link' | split: ','
            -%}
            {%- for account in social_accounts -%}
              {%- assign handle_key = social_id_keys[forloop.index0] -%}
              {%- assign url = section.settings[handle_key] -%}
              {%- if url != blank -%}
                <li>
                  <a
                    href="{{ url }}"
                    class="footer__social-link"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="{{ social_labels[forloop.index0] }}"
                  >
                    {%- case account -%}
                      {%- when 'instagram' -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                      {%- when 'tiktok' -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.88a8.22 8.22 0 0 0 4.82 1.55V7a4.85 4.85 0 0 1-1.05-.31z"/></svg>
                      {%- when 'pinterest' -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.08 3.17 9.44 7.65 11.18-.1-.97-.2-2.46.04-3.52.22-.96 1.47-6.23 1.47-6.23s-.38-.75-.38-1.87c0-1.75 1.02-3.06 2.28-3.06 1.08 0 1.6.81 1.6 1.78 0 1.08-.69 2.7-1.05 4.2-.3 1.25.62 2.27 1.84 2.27 2.22 0 3.72-2.84 3.72-6.2 0-2.56-1.74-4.35-4.22-4.35-2.88 0-4.57 2.16-4.57 4.39 0 .87.33 1.8.75 2.3a.3.3 0 0 1 .07.29l-.28 1.13c-.09.36-.3.44-.68.26-1.65-.77-2.68-3.18-2.68-5.12 0-4.16 3.02-7.98 8.72-7.98 4.57 0 8.12 3.26 8.12 7.61 0 4.54-2.86 8.19-6.83 8.19-1.33 0-2.59-.69-3.02-1.5l-.82 3.07c-.3 1.14-1.1 2.57-1.63 3.44A12 12 0 0 0 12 24c6.63 0 12-5.37 12-12S18.63 0 12 0z"/></svg>
                      {%- when 'facebook' -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                      {%- when 'twitter' -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                      {%- when 'youtube' -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23 7s-.3-1.9-1.1-2.7c-1.1-1.1-2.3-1.1-2.8-1.2C16.4 3 12 3 12 3s-4.4 0-7.1.1c-.6.1-1.8.1-2.8 1.2C1.3 5.1 1 7 1 7S.7 9.1.7 11.3v2c0 2.1.3 4.3.3 4.3s.3 1.9 1.1 2.7c1.1 1.1 2.5 1 3.1 1.1C7.2 21.5 12 21.5 12 21.5s4.4 0 7.1-.2c.6-.1 1.8-.1 2.8-1.2.8-.8 1.1-2.7 1.1-2.7s.3-2.1.3-4.3v-2C23.3 9.1 23 7 23 7zM9.7 15.5V8.4l7.6 3.6-7.6 3.5z"/></svg>
                    {%- endcase -%}
                  </a>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Nav columns (blocks) ── {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'nav_column' -%}
        <div class="footer__nav-col" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h3 class="footer__col-heading">{{ block.settings.heading | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            <ul class="footer__nav-list" role="list">
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a class="footer__nav-link" href="{{ link.url }}">{{ link.title | escape }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

    {%- comment -%} Contact block ── {%- endcomment -%}
    {%- if contact_text != blank -%}
      <div class="footer__contact">
        <h3 class="footer__col-heading">{{ section.settings.contact_heading | default: 'Contact' }}</h3>
        <div class="footer__contact-text text-muted">{{ contact_text }}</div>
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} ── Lower: copyright + policies + payment ── {%- endcomment -%}
  <div class="footer__lower">

    <p class="footer__copyright text-muted">
      &copy; {{ 'now' | date: '%Y' }}
      <a href="{{ routes.root_url }}">{{ shop.name | escape }}</a>
    </p>

    {%- if policy_menu != blank -%}
      <nav class="footer__policies" aria-label="Legal">
        <ul role="list">
          {%- for link in policy_menu.links -%}
            <li><a class="footer__policy-link" href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    {%- if has_conversion_links -%}
      <nav class="footer__conversion-links" aria-label="Shopping support">
        <ul role="list">
          {%- if settings.shipping_policy_url != blank -%}
            <li><a class="footer__conversion-link" href="{{ settings.shipping_policy_url }}">Shipping</a></li>
          {%- endif -%}
          {%- if settings.returns_policy_url != blank -%}
            <li><a class="footer__conversion-link" href="{{ settings.returns_policy_url }}">Returns</a></li>
          {%- endif -%}
          {%- if settings.size_help_url != blank -%}
            <li><a class="footer__conversion-link" href="{{ settings.size_help_url }}">Size help</a></li>
          {%- endif -%}
          {%- if settings.support_url != blank -%}
            <li><a class="footer__conversion-link" href="{{ settings.support_url }}">{{ settings.support_label | default: 'Need styling help?' }}</a></li>
          {%- endif -%}
        </ul>
      </nav>
    {%- endif -%}

    {%- if show_payment -%}
      <ul class="footer__payment-icons" role="list" aria-label="Accepted payment methods">
        {%- for type in shop.enabled_payment_types -%}
          <li>{{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}</li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>

</footer>

{% stylesheet %}
  /* ── Site footer shell ── */
  .site-footer {
    padding-block: var(--space-16) var(--space-10);
    padding-inline: max(
      var(--page-margin),
      calc((100vw - var(--page-width) + (var(--page-margin) * 2)) / 2)
    );
    display: flex;
    flex-direction: column;
    gap: var(--space-10);

    background:
      radial-gradient(circle at top right, rgba(199, 163, 71, 0.16) 0%, transparent 24%),
      linear-gradient(180deg, #102115 0%, #163120 52%, #22452d 100%);

    /* Locally override design tokens so every child selector
       gets the right colour for a dark-bg context without
       touching any markup. */
    --color-text:       #F7F3EC;
    --color-text-muted: rgba(247, 243, 236, 0.52);
    --color-border:     rgba(247, 243, 236, 0.12);
    --color-bg:         #214630;
    --color-bg-subtle:  rgba(247, 243, 236, 0.06);
    --color-bg-warm:    rgba(247, 243, 236, 0.06);
    --color-accent:     #DFA86D;
  }

  /* ── Upper grid ── */
  .footer__upper {
    display: grid;
    grid-template-columns:
      minmax(0, 1.4fr)
      repeat(var(--footer-nav-cols, 2), minmax(0, 1fr))
      minmax(0, 1fr);
    gap: var(--space-10) var(--space-8);
    align-items: start;
  }

  /* ── Brand column ── */
  .footer__brand {
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-inline-end: var(--space-8);
    border-inline-end: 1px solid var(--color-border);
  }

  .footer__brand::before {
    content: '';
    position: absolute;
    inset: -2.5rem auto auto -2rem;
    width: 12rem;
    height: 12rem;
    border-radius: 999px;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-gold-soft) 16%, transparent) 0%, transparent 72%);
    z-index: -1;
    pointer-events: none;
  }

  .footer__logo { height: auto; display: block; }

  .footer__brand-name {
    display: inline-flex;
    align-self: flex-start;
    width: fit-content;
    max-width: max-content;
    color: inherit;
    text-decoration: none;
    text-decoration-color: transparent;
    line-height: 1;
  }

  .footer__brand-name:hover {
    color: inherit;
  }

  .footer__brand-name-text {
    position: relative;
    display: inline-block;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(3.25rem, 6vw, 4.75rem);
    line-height: 0.9;
    letter-spacing: -0.035em;
    color: rgba(247, 243, 236, 0.96);
    transition: color var(--duration-measured) var(--ease-brand), transform var(--duration-base) var(--ease-default);
  }

  .footer__brand-name-text::after {
    content: '';
    display: block;
    width: 52%;
    min-width: 4.5rem;
    height: 1px;
    margin-top: 0.85rem;
    background: linear-gradient(90deg, color-mix(in srgb, var(--color-gold-soft) 72%, transparent) 0%, transparent 100%);
    opacity: 0.72;
    transform-origin: left center;
    transition: width var(--duration-base) var(--ease-brand), opacity var(--duration-base) var(--ease-default), background var(--duration-base) var(--ease-default);
  }

  .footer__brand-name:hover .footer__brand-name-text,
  .footer__brand-name:focus-visible .footer__brand-name-text {
    color: var(--color-gold-soft);
    transform: translateX(1px);
  }

  .footer__brand-name:hover .footer__brand-name-text::after,
  .footer__brand-name:focus-visible .footer__brand-name-text::after {
    width: 78%;
    opacity: 1;
    background: linear-gradient(90deg, var(--color-gold-soft) 0%, transparent 100%);
  }

  .footer__brand-name:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .footer__brand-text {
    position: relative;
    padding-inline-start: var(--space-5);
    font-size: clamp(1.05rem, 1.3vw, 1.25rem);
    line-height: 1.72;
    letter-spacing: 0.01em;
    color: rgba(247, 243, 236, 0.68);
    max-width: 28ch;
    margin: 0;
  }

  .footer__brand-text::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 1px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--color-gold-soft) 52%, transparent) 0%, transparent 100%);
    opacity: 0.7;
  }

  /* ── Social icons ── */
  .footer__social {
    display: flex;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    transition: color var(--duration-measured) var(--ease-brand);
  }

  .footer__social-link:hover        { color: var(--color-text); }
  .footer__social-link:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* ── Nav column ── */
  .footer__nav-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__col-heading {
    font-family: var(--font-body);
    font-style: normal;
    font-weight: 500;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-brand, 0.18em);
    text-transform: uppercase;
    margin: 0;
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__nav-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-measured) var(--ease-brand), opacity var(--duration-fast) var(--ease-default);
  }

  .footer__nav-link:hover        { color: var(--color-text); opacity: 1; }
  .footer__nav-link:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* ── Contact block ── */
  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__contact-text {
    font-size: var(--text-xs);
    line-height: var(--leading-relaxed, 1.65);
  }

  .footer__contact-text a {
    color: var(--color-text);
    text-decoration-color: var(--color-border);
    text-underline-offset: 2px;
  }

  /* ── Lower bar ── */
  .footer__lower {
    padding-block-start: var(--space-6);
    border-block-start: 1px solid var(--color-border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3) var(--space-5);
  }

  .footer__copyright { font-size: var(--text-xs); margin: 0; }
  .footer__copyright a { color: inherit; text-decoration: none; }
  .footer__copyright a:hover { text-decoration: underline; }

  /* ── Policy links ── */
  .footer__policies ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-5);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__policy-link {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-measured) var(--ease-brand);
  }

  .footer__policy-link:hover { color: var(--color-text); }

  .footer__conversion-links ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-5);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__conversion-link {
    font-size: var(--text-xs);
    color: var(--color-text);
    text-decoration: none;
    text-underline-offset: 3px;
    transition: color var(--duration-measured) var(--ease-brand), opacity var(--duration-fast) var(--ease-default);
  }

  .footer__conversion-link:hover {
    color: var(--color-gold-soft);
    opacity: 1;
  }

  /* ── Payment icons ── */
  .footer__payment-icons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin: 0 0 0 auto;
    padding: 0;
  }

  .footer__payment-icon {
    height: 1.5rem;
    width: auto;
    border-radius: var(--radius-sm);
    opacity: 0.7;
  }

  /* ── Newsletter strip (full-width above columns) ── */
  .footer__newsletter-strip {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    align-items: center;
    gap: var(--space-5) var(--space-10);
    padding: clamp(var(--space-6), 3vw, var(--space-8));
    border: 1px solid color-mix(in srgb, var(--color-gold) 28%, var(--color-border));
    border-radius: 1.35rem;
    background:
      linear-gradient(135deg, rgba(247, 243, 236, 0.06) 0%, rgba(247, 243, 236, 0.02) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 18px 40px rgba(8, 14, 11, 0.14);
  }

  .footer__newsletter-intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__newsletter-heading {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(var(--text-xl), 2.5vw, var(--text-3xl));
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin: 0;
  }

  .footer__newsletter-sub {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    max-width: 42ch;
    line-height: var(--leading-relaxed);
  }

  /* ── Newsletter form fields ── */
  .footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__newsletter-field {
    display: flex;
    align-items: center;
    min-height: 3.5rem;
    padding-inline: var(--space-4);
    border: 1px solid color-mix(in srgb, var(--color-gold) 24%, var(--color-border));
    border-radius: 999px;
    background-color: rgba(247, 243, 236, 0.04);
    transition:
      border-color var(--duration-measured) var(--ease-brand),
      background-color var(--duration-fast) var(--ease-default);
  }

  .footer__newsletter-field:focus-within {
    border-color: var(--color-gold-soft);
    background-color: rgba(247, 243, 236, 0.08);
  }

  .footer__newsletter-field input {
    flex: 1;
    background: none;
    border: none;
    padding: var(--space-3) 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    color: var(--color-text);
    min-width: 0;
    box-shadow: none;
  }

  .footer__newsletter-field input::placeholder {
    color: var(--color-text-muted);
  }

  .footer__newsletter-field input:focus {
    outline: none;
  }

  .footer__newsletter-field button {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-gold-soft);
    padding: var(--space-2) 0 var(--space-2) var(--space-2);
    display: flex;
    align-items: center;
    transition: opacity var(--duration-fast) var(--ease-default), transform var(--duration-fast) var(--ease-default);
  }

  .footer__newsletter-field button:hover {
    opacity: 1;
    transform: translateX(1px);
  }

  .footer__newsletter-success {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
  }

  .footer__newsletter-error {
    font-size: var(--text-xs);
    color: var(--color-text);
    margin: var(--space-1) 0 0;
  }

  /* ── Mobile ── */
  @media (max-width: 64rem) {
    .footer__upper {
      grid-template-columns: 1fr 1fr;
    }

    .footer__brand {
      grid-column: 1 / -1;
      padding-inline-end: 0;
      border-inline-end: none;
      padding-block-end: var(--space-6);
      border-block-end: 1px solid var(--color-border);
    }

    .footer__newsletter-strip {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }

  @media (max-width: 40rem) {
    .footer__upper  { grid-template-columns: 1fr; gap: var(--space-6); }
    .site-footer    { gap: var(--space-6); padding-block: var(--space-10) var(--space-6); }
    .footer__brand  { border-block-end: none; padding-block-end: 0; }
    .footer__payment-icons { margin-left: 0; }
    .footer__newsletter-strip { padding-block-end: var(--space-6); gap: var(--space-4); }
  }
{% endstylesheet %}

