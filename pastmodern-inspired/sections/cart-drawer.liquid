{%- comment -%}
  sections/cart-drawer.liquid
  Slide-in cart drawer rendered in layout/theme.liquid.
  Populated and controlled by CartDrawer in assets/theme.js.
{%- endcomment -%}

<div data-cart-overlay></div>

<div
  data-cart-drawer
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'cart.title' | t }}"
>
  <div class="cart-drawer__header">
    <p class="cart-drawer__title eyebrow">{{ 'cart.title' | t }}</p>
    <button
      data-cart-close
      class="cart-drawer__close btn-ghost"
      aria-label="{{ 'accessibility.close' | t | default: 'Close' }}"
    >
      {%- render 'icon-close' -%}
    </button>
  </div>

  <div data-cart-items class="cart-drawer__items">
    {%- comment -%}Populated by CartDrawer JS{%- endcomment -%}
  </div>

  <div class="cart-drawer__footer">
    <div class="cart-drawer__subtotal">
      <span class="eyebrow">{{ 'cart.subtotal' | t | default: 'Subtotal' }}</span>
      <span data-cart-subtotal></span>
    </div>
    <a href="{{ routes.cart_url }}" class="btn btn-primary btn-full">
      {{ 'cart.checkout' | t }}
    </a>
    <p class="cart-drawer__note text-muted">
      {{ 'cart.taxes_and_shipping' | t | default: 'Taxes and shipping calculated at checkout' }}
    </p>
  </div>
</div>

{% stylesheet %}
  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-6) var(--space-6) var(--space-4);
    border-block-end: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .cart-drawer__title {
    margin: 0;
  }

  .cart-drawer__close {
    font-size: var(--text-xl);
    line-height: 1;
    padding: var(--space-1);
  }

  .cart-drawer__items {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-4) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .cart-empty {
    padding-block: var(--space-8);
    text-align: center;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 5rem 1fr auto;
    gap: var(--space-4);
    align-items: start;
  }

  .cart-item__image-link img {
    width: 5rem;
    height: 6.25rem;
    object-fit: cover;
    background-color: var(--color-bg-subtle);
  }

  .cart-item__title {
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }

  .cart-item__variant {
    font-size: var(--text-xs);
    margin-block-start: var(--space-1);
  }

  .cart-item__price {
    font-size: var(--text-sm);
    margin-block-start: var(--space-2);
  }

  .cart-item__remove {
    font-size: var(--text-lg);
    line-height: 1;
    padding: var(--space-1);
    color: var(--color-text-muted);
  }

  .cart-drawer__footer {
    padding: var(--space-6);
    border-block-start: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: var(--text-sm);
  }

  .cart-drawer__note {
    font-size: var(--text-xs);
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}
