{%- comment -%}
  sections/cart-drawer.liquid
  Slide-in cart drawer rendered once in layout/theme.liquid.
  Opened / closed via cart:open / cart:close events in assets/cart.js.
  Content refreshed after AJAX changes using the Section Rendering API.
{%- endcomment -%}

<div class="cart-overlay" data-cart-overlay aria-hidden="true"></div>

<div
  class="cart-drawer"
  id="cart-drawer"
  data-cart-drawer
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'cart.title' | t }}"
  aria-hidden="true"
  inert
>

  {%- comment -%} ── Header ── {%- endcomment -%}
  <div class="cart-drawer__header">
    <h2 class="cart-drawer__title">{{ 'cart.title' | t }}</h2>
    <button
      class="cart-drawer__close"
      type="button"
      data-cart-close
      aria-label="Close cart"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true" focusable="false">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  {%- comment -%} ── Line items ── {%- endcomment -%}
  <div class="cart-drawer__items" data-cart-items>
    {%- if cart.item_count == 0 -%}
      <div class="cart-drawer__empty">
        <p class="cart-drawer__empty-msg">Your bag is empty.</p>
        <a
          class="btn btn-ghost"
          href="{{ routes.all_products_collection_url }}"
          data-cart-continue
        >Continue shopping</a>
      </div>
    {%- else -%}
      {%- for item in cart.items -%}
        {%- render 'cart-line-item', item: item -%}
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- comment -%} ── Footer (hidden when cart is empty) ── {%- endcomment -%}
  <div
    class="cart-drawer__footer"
    data-cart-footer
    {% if cart.item_count == 0 %}hidden{% endif %}
  >
    <div class="cart-drawer__subtotal">
      <span class="cart-drawer__subtotal-label eyebrow">Subtotal</span>
      <span class="cart-drawer__subtotal-amount" data-cart-subtotal>
        {{- cart.total_price | money -}}
      </span>
    </div>
    <p class="cart-drawer__taxes text-muted">
      Taxes and shipping calculated at checkout
    </p>
    <a
      href="{{ routes.checkout_url }}"
      class="btn btn-primary btn-full"
    >{{ 'cart.checkout' | t }}</a>
  </div>

</div>

{% stylesheet %}
  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-6) var(--space-6) var(--space-4);
    border-block-end: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .cart-drawer__title {
    margin: 0;
  }

  .cart-drawer__close {
    font-size: var(--text-xl);
    line-height: 1;
    padding: var(--space-1);
  }

  .cart-drawer__items {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-4) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .cart-empty {
    padding-block: var(--space-8);
    text-align: center;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 5rem 1fr auto;
    gap: var(--space-4);
    align-items: start;
  }

  .cart-item__image-link img {
    width: 5rem;
    height: 6.25rem;
    object-fit: cover;
    background-color: var(--color-bg-subtle);
  }

  .cart-item__title {
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }

  .cart-item__variant {
    font-size: var(--text-xs);
    margin-block-start: var(--space-1);
  }

  .cart-item__price {
    font-size: var(--text-sm);
    margin-block-start: var(--space-2);
  }

  .cart-item__remove {
    font-size: var(--text-lg);
    line-height: 1;
    padding: var(--space-1);
    color: var(--color-text-muted);
  }

  .cart-drawer__footer {
    padding: var(--space-6);
    border-block-start: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    flex-shrink: 0;
  }

  .cart-drawer__subtotal {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: var(--text-sm);
  }

  .cart-drawer__note {
    font-size: var(--text-xs);
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}
