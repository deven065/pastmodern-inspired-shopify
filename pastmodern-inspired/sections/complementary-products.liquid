{%- comment -%}
  complementary-products.liquid
  Loads complementary recommendations via Shopify's product recommendations API.
{%- endcomment -%}

{%- assign heading_text = section.settings.heading | default: 'Style it with' -%}
{%- assign eyebrow_text = section.settings.eyebrow -%}
{%- assign count = section.settings.products_to_show | default: 4 -%}

{%- assign rec_url = routes.product_recommendations_url
  | append: '?section_id='
  | append: section.id
  | append: '&product_id='
  | append: product.id
  | append: '&limit='
  | append: count
  | append: '&intent=complementary'
-%}

<product-recommendations
  class="related-products related-products--complementary"
  data-url="{{ rec_url }}"
>
  {%- if recommendations.performed and recommendations.products_count > 0 -%}
    <div class="related-products__header">
      {%- if eyebrow_text != blank -%}
        <p class="related-products__eyebrow eyebrow">{{ eyebrow_text | escape }}</p>
      {%- endif -%}
      <h2 class="related-products__title">{{ heading_text | escape }}</h2>
    </div>

    <ul
      class="related-products__grid"
      style="--rp-cols: {{ count }};"
      role="list"
    >
      {%- for rec in recommendations.products -%}
        <li class="reveal">
          {%- render 'product-card', product: rec, lazy: true -%}
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</product-recommendations>

{% stylesheet %}
  .shopify-section:has(.related-products--complementary) {
    padding-block-start: var(--space-12);
    border-block-start: 1px solid var(--color-border);
  }

  .related-products__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
    text-align: center;
    margin-block-end: var(--space-16);
  }

  .related-products__title {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-style: italic;
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-3xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  .related-products__grid {
    display: grid;
    grid-template-columns: repeat(var(--rp-cols, 4), 1fr);
    gap: clamp(var(--space-3), 2vw, var(--space-6));
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (max-width: 56rem) {
    .related-products__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 36rem) {
    .related-products__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-3);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Complementary products",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "placeholder": "Finish the look"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Style it with"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
