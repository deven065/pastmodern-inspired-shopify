{%- liquid
  assign fc_collection  = section.settings.collection
  assign fc_heading     = section.settings.heading
  assign fc_eyebrow     = section.settings.eyebrow
  assign fc_limit       = section.settings.product_limit
  assign fc_ratio       = section.settings.image_ratio
  assign fc_quick_add   = section.settings.show_quick_add
  assign fc_hover       = section.settings.show_hover_image
  assign fc_cols_desk   = section.settings.columns_desktop
  assign fc_cols_mob    = section.settings.columns_mobile
  assign fc_cta_label   = section.settings.cta_label
  assign fc_cta_url     = section.settings.cta_url

  # Responsive sizes hint based on desktop columns
  case fc_cols_desk
    when 2
      assign img_sizes = '(max-width: 48rem) calc(50vw - 2rem), (max-width: 90rem) 45vw, 40vw'
    when 3
      assign img_sizes = '(max-width: 48rem) calc(50vw - 2rem), (max-width: 90rem) 31vw, 28vw'
    else
      assign img_sizes = '(max-width: 48rem) calc(50vw - 2rem), (max-width: 90rem) 24vw, 22vw'
  endcase
-%}

<div
  class="featured-collection"
  style="
    --fc-cols-desk: {{ fc_cols_desk }};
    --fc-cols-mob:  {{ fc_cols_mob }};
  "
>
  {%- comment -%} ── Section header ── {%- endcomment -%}
  {%- if fc_eyebrow != blank or fc_heading != blank -%}
    <div class="featured-collection__header">
      <div class="featured-collection__header-text">
        {%- if fc_eyebrow != blank -%}
          <p class="eyebrow">{{ fc_eyebrow }}</p>
        {%- endif -%}
        {%- if fc_heading != blank -%}
          <h2 class="featured-collection__heading">{{ fc_heading }}</h2>
        {%- endif -%}
      </div>
      {%- if fc_cta_label != blank and fc_collection != blank -%}
        <a href="{{ fc_cta_url | default: fc_collection.url }}" class="featured-collection__header-cta">
          {{ fc_cta_label }}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14" aria-hidden="true" focusable="false">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Product grid ── {%- endcomment -%}
  {%- if fc_collection == blank -%}
    <p class="featured-collection__empty">Select a collection in the theme editor.</p>
  {%- elsif fc_collection.products_count == 0 -%}
    <p class="featured-collection__empty">This collection has no products.</p>
  {%- else -%}
    <ul class="featured-collection__grid" role="list">
      {%- for product in fc_collection.products limit: fc_limit -%}
        <li class="featured-collection__item reveal">
          {%- render 'product-card',
            product:          product,
            image_ratio:      fc_ratio,
            sizes:            img_sizes,
            show_quick_add:   fc_quick_add,
            show_hover_image: fc_hover,
            lazy:             true
          -%}
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

</div>

{% stylesheet %}
  /* ── Wrapper ───────────────────────────────────────────────── */
  .featured-collection {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  /* ── Header ─────────────────────────────────────────────── */
  .featured-collection__header {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: var(--space-4);
    padding-block-start: var(--space-8);
    padding-block-end: var(--space-2);
    border-block-start: 2px solid var(--color-text);
  }

  .featured-collection__header-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .featured-collection__header-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    white-space: nowrap;
    padding-block-end: var(--space-1);
    transition:
      gap       var(--duration-base) var(--ease-out),
      opacity   var(--duration-fast) var(--ease-default);
  }

  .featured-collection__header-cta:hover {
    gap: var(--space-3);
    opacity: 0.6;
  }

  .featured-collection__heading {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-style: italic;
    font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl));
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }

  /* ── Grid ──────────────────────────────────────────────────── */
  .featured-collection__grid {
    display: grid;
    grid-template-columns: repeat(var(--fc-cols-desk, 4), 1fr);
    gap: var(--space-8) var(--space-6);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .featured-collection__item {
    min-width: 0; /* prevent grid blowout */
  }

  /* ── Empty state ───────────────────────────────────────────── */
  .featured-collection__empty {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    padding-block: var(--space-8);
  }

  /* ── Mobile ────────────────────────────────────────────────── */
  @media (max-width: 48rem) {
    .featured-collection__grid {
      grid-template-columns: repeat(var(--fc-cols-mob, 2), 1fr);
      gap: var(--space-6) var(--space-3);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "placeholder": "New arrivals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Number of products",
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns — desktop",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns — mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "3/4",  "label": "Portrait 3:4" },
        { "value": "4/5",  "label": "Portrait 4:5" },
        { "value": "1/1",  "label": "Square" }
      ],
      "default": "3/4"
    },
    {
      "type": "header",
      "content": "Card options"
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_hover_image",
      "label": "Show hover image",
      "default": true
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "placeholder": "View all"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link",
      "info": "Defaults to the collection URL if left blank."
    }
  ],
  "presets": [
    {
      "name": "Featured collection",
      "settings": {
        "heading":          "Featured collection",
        "product_limit":    8,
        "columns_desktop":  "4",
        "columns_mobile":   "2",
        "image_ratio":      "3/4",
        "show_quick_add":   true,
        "show_hover_image": true,
        "cta_label":        "View all"
      }
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
