<!doctype html>
<html lang="{{ request.locale.iso_code }}" data-color-mode="light">
  <head>
    {% render 'css-variables' %}
    <script>
      (function () {
        var storageKey = 'pastmodern-color-mode';

        try {
          var storedMode = window.localStorage.getItem(storageKey);
          var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          var mode = storedMode === 'dark' || storedMode === 'light'
            ? storedMode
            : (prefersDark ? 'dark' : 'light');

          document.documentElement.setAttribute('data-color-mode', mode);
        } catch (error) {
          document.documentElement.setAttribute('data-color-mode', 'light');
        }
      })();
    </script>

    {% unless settings.type_body_font.system? %}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
      {{ settings.type_body_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {% unless settings.type_heading_font.system? %}
      {{ settings.type_heading_font | font_url | preload_tag: as: 'font', crossorigin: 'anonymous' }}
    {% endunless %}

    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ 'cart.css'  | asset_url | stylesheet_tag }}

    {% render 'meta-tags' %}

    {{ content_for_header }}
  </head>

  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    {% sections 'header-group' %}

    <main id="main-content" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% render 'welcome-capture' %}

    {% sections 'footer-group' %}

    {% section 'cart-drawer' %}

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
    <script src="{{ 'cart.js'  | asset_url }}" defer></script>
    {%- if request.page_type == 'product' -%}
      <script src="{{ 'product.js' | asset_url }}" defer></script>
    {%- endif -%}
  </body>
</html>
