{% style %}
  {%- comment -%}Body font — load all four variants{%- endcomment -%}
  {{ settings.type_body_font | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ settings.type_body_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  {%- comment -%}Heading font — load regular, bold, italic{%- endcomment -%}
  {{ settings.type_heading_font | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  :root {
    /* ── Typography ─────────────────────────────────────────── */
    --font-body:         {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
    --font-body-weight:  {{ settings.type_body_font.weight }};
    --font-body-style:   {{ settings.type_body_font.style }};

    --font-heading:        {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    --font-heading-weight: {{ settings.type_heading_font.weight }};
    --font-heading-style:  {{ settings.type_heading_font.style }};

    /* ── Colors — merchant-controllable ────────────────────── */
    --color-bg-base:     {{ settings.color_background }};
    --color-text-base:   {{ settings.color_text }};
    --color-accent-base: {{ settings.color_accent }};
    --color-bg:          var(--color-bg-base);
    --color-text:        var(--color-text-base);
    --color-accent:      var(--color-accent-base);

    /* ── Colors — emerald-led conversion palette ───────────── */
    --color-bg-warm:        #F3E7D6;
    --color-bg-stone:       #E0C9A4;
    --color-bg-subtle:      #FCF6EE;
    --color-surface:        color-mix(in srgb, var(--color-bg) 84%, #FFF8F1);
    --color-surface-strong: color-mix(in srgb, var(--color-bg) 74%, #FFF8F1);
    --color-border:         color-mix(in srgb, var(--color-accent) 14%, #D5B06C 38%);
    --color-border-strong:  color-mix(in srgb, var(--color-accent) 22%, #C99E43 48%);
    --color-text-muted:     #746A60;
    --color-text-secondary: #22352B;
    --color-overlay:        rgba(7, 12, 10, 0.42);

    /* Brand and accent family */
    --color-accent-hover:   #103222;
    --color-accent-soft:    #3A694F;
    --color-sage:           #869A7D;
    --color-accent-subtle:  color-mix(in srgb, var(--color-accent) 12%, #FFF8F1);
    --color-accent-dim:     color-mix(in srgb, var(--color-accent) 22%, transparent);

    /* Gold-forward highlight family */
    --color-gold:           #C9A24B;
    --color-gold-soft:      #E7CA86;
    --color-clay:           #B77555;
    --color-blush:          #F0E2D6;
    --color-butter:         #E3C164;
    --color-mint:           #D7E1D2;
    --color-berry:          #536A5B;
    --color-sand:           #B48C3E;
    --color-rose-clay:      #C88668;
    --color-success:        #86A38D;

    /* Shadows */
    --shadow-soft:          0 18px 38px rgba(18, 24, 20, 0.08);
    --shadow-card:          0 28px 78px rgba(18, 24, 20, 0.12);
    --shadow-pop:           0 22px 52px rgba(18, 24, 20, 0.18);
    --color-input-bg:       color-mix(in srgb, var(--color-bg) 72%, #FFF8F1);
    --color-input-bg-active: color-mix(in srgb, var(--color-bg) 78%, white);
    --color-input-shadow:   inset 0 1px 0 rgba(255, 255, 255, 0.72);
    --color-input-shadow-active: inset 0 1px 0 rgba(255, 255, 255, 0.88);
    --color-page-top-glow:  rgba(201, 162, 75, 0.18);
    --color-page-bottom-glow: rgba(58, 105, 79, 0.1);
    --color-page-gradient-start: color-mix(in srgb, var(--color-bg) 88%, #FFF8F1);
    --color-page-gradient-end: color-mix(in srgb, var(--color-bg) 74%, var(--color-bg-warm));
    --color-page-sheen:     rgba(255, 255, 255, 0.58);
    --color-page-sheen-accent: rgba(201, 162, 75, 0.12);

    /* ── Layout ─────────────────────────────────────────────────── */
    --page-width:    {{ settings.page_width }};
    --page-margin:   {{ settings.page_margin }}px;
    --header-height: 5.5rem;

    /* ── Shape ──────────────────────────────────────────────── */
    --radius-input: {{ settings.input_radius }}px;
    /* ── Merchant scales ─────────────────────────────────── */
    --heading-scale:  {{ settings.heading_scale | default: 1.0 }};
    --base-font-size: {{ settings.body_font_size | default: '0.9375rem' }};
    --logo-max-width: {{ settings.logo_max_width | default: 140 }}px;
    {%- if settings.button_style == 'soft' -%}
      --btn-radius: 2px;
    {%- elsif settings.button_style == 'rounded' -%}
      --btn-radius: 6px;
    {%- else -%}
      --btn-radius: 0px;
    {%- endif -%}
    --header-position: {% if settings.header_sticky == false %}relative{% else %}sticky{% endif %};

    /* ── Section vertical rhythm ─────────────────────────── */
    {%- if settings.section_spacing == 'compact' -%}
      --section-spacing: clamp(1.5rem, 3vw, 2.75rem);
    {%- elsif settings.section_spacing == 'comfortable' -%}
      --section-spacing: clamp(2.75rem, 5.5vw, 5rem);
    {%- else -%}
      --section-spacing: clamp(4rem, 8vw, 8rem);
    {%- endif -%}
  }

  html[data-color-mode="dark"] {
    color-scheme: dark;
    --color-bg:            #08100D;
    --color-text:          #F4EDDE;
    --color-accent:        var(--color-accent-base);
    --color-bg-warm:       #152119;
    --color-bg-stone:      #263327;
    --color-bg-subtle:     #0D1712;
    --color-surface:       color-mix(in srgb, #0F1814 90%, rgba(247, 243, 236, 0.04));
    --color-surface-strong: #16211A;
    --color-border:        color-mix(in srgb, var(--color-gold) 28%, rgba(247, 243, 236, 0.12));
    --color-border-strong: color-mix(in srgb, var(--color-gold) 44%, rgba(247, 243, 236, 0.18));
    --color-text-muted:    #AFA792;
    --color-text-secondary: #E7DEC9;
    --color-overlay:       rgba(4, 8, 6, 0.76);
    --color-accent-hover:  #25543A;
    --color-accent-soft:   #3E7453;
    --color-sage:          #93A38D;
    --color-accent-subtle: color-mix(in srgb, var(--color-accent) 20%, rgba(247, 243, 236, 0.04));
    --color-accent-dim:    color-mix(in srgb, var(--color-accent) 28%, transparent);
    --color-clay:          #D38B66;
    --color-blush:         #D8D4C7;
    --color-mint:          #96A892;
    --color-berry:         #6D846C;
    --color-sand:          #D1AC60;
    --color-rose-clay:     #D89A78;
    --color-success:       #A1C5A7;
    --shadow-soft:         0 22px 52px rgba(0, 0, 0, 0.32);
    --shadow-card:         0 32px 86px rgba(0, 0, 0, 0.46);
    --shadow-pop:          0 22px 52px rgba(0, 0, 0, 0.54);
    --color-input-bg:      color-mix(in srgb, var(--color-bg) 88%, rgba(247, 243, 236, 0.06));
    --color-input-bg-active: color-mix(in srgb, var(--color-bg) 80%, rgba(247, 243, 236, 0.1));
    --color-input-shadow:  inset 0 1px 0 rgba(255, 255, 255, 0.05);
    --color-input-shadow-active: inset 0 1px 0 rgba(255, 255, 255, 0.08);
    --color-page-top-glow: rgba(199, 163, 71, 0.12);
    --color-page-bottom-glow: rgba(35, 71, 48, 0.18);
    --color-page-gradient-start: color-mix(in srgb, var(--color-bg) 96%, #0C130F);
    --color-page-gradient-end: color-mix(in srgb, var(--color-bg-warm) 84%, #08100D);
    --color-page-sheen:    rgba(255, 255, 255, 0.04);
    --color-page-sheen-accent: rgba(199, 163, 71, 0.14);
  }
{% endstyle %}
