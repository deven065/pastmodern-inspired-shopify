{% doc %}
  Renders a single cart line item row inside the cart drawer.
  Called by sections/cart-drawer.liquid and refreshed via Section Rendering API.

  @param {line_item} item — Shopify cart line item object (required)
{% enddoc %}

<div class="cart-item" data-key="{{ item.key }}">

  {%- comment -%} ── Image ── {%- endcomment -%}
  <a href="{{ item.url }}" class="cart-item__image-link" tabindex="-1" aria-hidden="true">
    {%- if item.image -%}
      {{- item.image
          | image_url: width: 220
          | image_tag:
              width: 110,
              height: 140,
              loading: 'lazy',
              alt: item.product.title,
              class: 'cart-item__image'
      -}}
    {%- else -%}
      <div class="cart-item__image cart-item__image--placeholder"></div>
    {%- endif -%}
  </a>

  {%- comment -%} ── Details ── {%- endcomment -%}
  <div class="cart-item__details">

    {%- comment -%} Title — italic serif, links to product ── {%- endcomment -%}
    <a href="{{ item.url }}" class="cart-item__title">
      {{- item.product.title | escape -}}
    </a>

    {%- comment -%} Variant (omit for single-variant products) ── {%- endcomment -%}
    {%- unless item.variant.title == 'Default Title' -%}
      <p class="cart-item__variant">{{ item.variant.title | escape }}</p>
    {%- endunless -%}

    {%- comment -%} Price — shown before qty for visual hierarchy ── {%- endcomment -%}
    <div class="cart-item__price-row">
      <span class="cart-item__price">{{ item.final_line_price | money }}</span>
      {%- if item.original_line_price > item.final_line_price -%}
        <s class="cart-item__price-compare">{{ item.original_line_price | money }}</s>
      {%- endif -%}
    </div>

    {%- comment -%} Qty stepper + remove ── {%- endcomment -%}
    <div class="cart-item__actions">

      <div
        class="cart-item__qty"
        role="group"
        aria-label="Quantity for {{ item.product.title | escape }}"
      >
        <button
          class="cart-item__qty-btn"
          type="button"
          data-qty-decrease
          data-line-key="{{ item.key }}"
          aria-label="Decrease quantity"
          {% if item.quantity <= 1 %}disabled{% endif %}
        >&#8722;</button>

        <span class="cart-item__qty-num" data-qty-num aria-live="polite">
          {{- item.quantity -}}
        </span>

        <button
          class="cart-item__qty-btn"
          type="button"
          data-qty-increase
          data-line-key="{{ item.key }}"
          aria-label="Increase quantity"
        >&#43;</button>
      </div>

      <button
        class="cart-item__remove"
        type="button"
        data-remove-item
        data-line-key="{{ item.key }}"
        aria-label="Remove {{ item.product.title | escape }} from bag"
      >Remove</button>

    </div>
  </div>

</div>
