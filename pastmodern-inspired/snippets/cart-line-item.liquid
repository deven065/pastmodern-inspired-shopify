{% doc %}
  Renders a single cart line item row inside the cart drawer.
  Called by sections/cart-drawer.liquid and refreshed via Section Rendering API.

  @param {line_item} item — Shopify cart line item object (required)
{% enddoc %}

<div class="cart-item" data-key="{{ item.key }}">

  {%- comment -%} ── Image ── {%- endcomment -%}
  <a href="{{ item.url }}" class="cart-item__image-link" tabindex="-1" aria-hidden="true">
    {%- if item.image -%}
      {{- item.image | image_url: width: 160 | image_tag:
          width: 80,
          height: 100,
          loading: 'lazy',
          alt: item.product.title,
          class: 'cart-item__image'
      -}}
    {%- else -%}
      <div class="cart-item__image cart-item__image--placeholder"></div>
    {%- endif -%}
  </a>

  {%- comment -%} ── Details ── {%- endcomment -%}
  <div class="cart-item__details">
    <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title | escape }}</a>

    {%- unless item.variant.title == 'Default Title' -%}
      <p class="cart-item__variant text-muted">{{ item.variant.title | escape }}</p>
    {%- endunless -%}

    <div class="cart-item__qty-row">
      <div
        class="cart-item__qty"
        role="group"
        aria-label="Quantity for {{ item.product.title | escape }}"
      >
        <button
          class="cart-item__qty-btn"
          type="button"
          data-qty-decrease
          data-line-key="{{ item.key }}"
          aria-label="Decrease quantity"
          {% if item.quantity <= 1 %}disabled{% endif %}
        >&#8722;</button>
        <span class="cart-item__qty-num" data-qty-num aria-live="polite">{{ item.quantity }}</span>
        <button
          class="cart-item__qty-btn"
          type="button"
          data-qty-increase
          data-line-key="{{ item.key }}"
          aria-label="Increase quantity"
        >+</button>
      </div>

      <span class="cart-item__price">{{ item.final_line_price | money }}</span>
    </div>
  </div>

  {%- comment -%} ── Remove ── {%- endcomment -%}
  <button
    class="cart-item__remove"
    type="button"
    data-remove-item
    data-line-key="{{ item.key }}"
    aria-label="Remove {{ item.product.title | escape }}"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true" focusable="false">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

</div>
