{% doc %}
  Renders a single accessible accordion item.
  Accordion open/close behaviour is handled by the Accordion class in theme.js.
  Must be inside a block with [data-accordion].

  @param {string}  title    — Button label and ARIA ID seed (required)
  @param {string}  [content] — Body HTML rendered inside the panel
  @param {boolean} [open]    — Start expanded; default false

  @example
  {%- capture fabric_html -%}<p>100% Silk Crepe</p>{%- endcapture -%}
  {% render 'accordion-item', title: 'Fabric & Materials', content: fabric_html %}
{% enddoc %}

{%- liquid
  assign is_open = open | default: false
  assign slug    = title | handle
-%}

<button
  type="button"
  id="acc-trigger-{{ slug }}"
  aria-expanded="{{ is_open | json }}"
  aria-controls="acc-body-{{ slug }}"
  data-accordion-trigger
>
  <span>{{ title | escape }}</span>
  <span class="accordion-icon" aria-hidden="true"></span>
</button>

<div
  id="acc-body-{{ slug }}"
  role="region"
  aria-labelledby="acc-trigger-{{ slug }}"
  data-accordion-content
  style="max-height: 0;"
>
  <div class="accordion-body">
    {{ content }}
  </div>
</div>

