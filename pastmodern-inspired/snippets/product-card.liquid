{% doc %}
  Renders a product card with image, hover image, title, price, badges,
  size pills, and an optional quick-add button.

  @param {product} product              - The product object (required)
  @param {string}  [image_ratio]        - CSS aspect-ratio value, e.g. '3/4' (default '3/4')
  @param {string}  [sizes]              - img sizes attribute (default responsive)
  @param {boolean} [show_quick_add]     - Show quick-add button (default true)
  @param {boolean} [show_hover_image]   - Show hover/secondary image on mouse-over (default true)
  @param {boolean} [show_sizes]         - Show size pills (default true)
  @param {boolean} [show_vendor]        - Show brand name above title (default false)
  @param {boolean} [lazy]               - Lazy-load image (default true)

  @example
  {% render 'product-card', product: product %}
  {% render 'product-card', product: product, show_quick_add: false, image_ratio: '1/1' %}
{% enddoc %}

{%- liquid
  assign ratio       = image_ratio | default: '3/4'
  assign img_sizes   = sizes | default: '(max-width: 48rem) 50vw, (max-width: 90rem) 33vw, 25vw'
  assign do_quick    = show_quick_add | default: true
  assign do_hover    = show_hover_image | default: true
  assign do_sizes    = show_sizes | default: true
  assign do_vendor   = show_vendor | default: false
  assign img_loading = lazy | default: true

  if img_loading
    assign loading_val = 'lazy'
  else
    assign loading_val = 'eager'
  endif

  # Primary image
  assign primary_img = product.featured_media

  # Hover image: prefer metafield custom.hover_image, fall back to second media item
  assign hover_img = product.metafields.custom.hover_image.value
  if hover_img == blank and product.media.size > 1
    assign hover_img = product.media[1]
  endif

  # Badges: metafield first, then sold-out, then on-sale
  assign badge_text  = product.metafields.custom.badge_text.value
  assign is_sold_out = true
  for variant in product.variants
    if variant.available
      assign is_sold_out = false
      break
    endif
  endfor
  assign is_on_sale = false
  if product.compare_at_price > product.price
    assign is_on_sale = true
  endif

  # Size option — find option titled 'Size', 'size', or 'SIZE'
  assign size_option_index = nil
  for option in product.options_with_values
    assign option_down = option.name | downcase
    if option_down == 'size'
      assign size_option_index = forloop.index0
    endif
  endfor

  # Quick-add mode: 'add' (single available), 'soldout' (single sold out), 'select' (multi-variant)
  assign quick_add_mode    = nil
  assign quick_add_variant = nil
  if do_quick
    if product.variants.size == 1
      assign quick_add_variant = product.variants.first
      if quick_add_variant.available
        assign quick_add_mode = 'add'
      else
        assign quick_add_mode = 'soldout'
      endif
    elsif product.variants.size > 1
      assign quick_add_mode = 'select'
    endif
  endif
-%}

<div class="product-card{% if is_sold_out %} product-card--sold-out{% endif %}" data-product-card>
  {%- comment -%} ── Media ── {%- endcomment -%}
  <div class="product-card__media" style="--card-ratio: {{ ratio }};">
    <a href="{{ product.url }}" class="product-card__media-link" aria-label="{{ product.title | escape }}" tabindex="-1">

      {%- comment -%} Primary image {%- endcomment -%}
      {%- if primary_img != blank -%}
        {{
          primary_img
          | image_url: width: 800
          | image_tag:
              width: primary_img.preview_image.width,
              height: primary_img.preview_image.height,
              sizes: img_sizes,
              widths: '300, 450, 600, 800, 1000',
              loading: loading_val,
              fetchpriority: 'auto',
              class: 'product-card__img product-card__img--primary',
              alt: primary_img.alt | default: product.title | escape
        }}
      {%- else -%}
        <div class="product-card__no-image">
          {{ 'product-apparel-2' | placeholder_svg_tag: 'product-card__placeholder-svg' }}
        </div>
      {%- endif -%}

      {%- comment -%} Hover image {%- endcomment -%}
      {%- if hover_img != blank and do_hover -%}
        {{
          hover_img
          | image_url: width: 800
          | image_tag:
              width: hover_img.preview_image.width,
              height: hover_img.preview_image.height,
              sizes: img_sizes,
              widths: '300, 450, 600, 800, 1000',
              loading: 'lazy',
              class: 'product-card__img product-card__img--hover',
              alt: hover_img.alt | default: product.title | escape
        }}
      {%- endif -%}

    </a>

    {%- comment -%} Badges {%- endcomment -%}
    {%- if badge_text != blank -%}
      <span class="product-card__badge product-card__badge--custom" aria-label="{{ badge_text | escape }}">
        {{ badge_text }}
      </span>
    {%- elsif is_sold_out -%}
      <span class="product-card__badge product-card__badge--sold-out">Sold out</span>
    {%- elsif is_on_sale -%}
      <span class="product-card__badge product-card__badge--sale">Sale</span>
    {%- endif -%}

  </div>

  {%- comment -%} ── Info ── {%- endcomment -%}
  <div class="product-card__info">
    {%- if do_vendor and product.vendor != blank -%}
      <p class="product-card__vendor">{{ product.vendor | escape }}</p>
    {%- endif -%}

    {%- if do_sizes and size_option_index != nil -%}
      {%- assign size_option = product.options_with_values[size_option_index] -%}
      {%- if size_option.values.size > 0 -%}
        <ul class="product-card__sizes" role="list" aria-label="Available sizes">
          {%- for size_val in size_option.values -%}
            {%- assign size_available = false -%}
            {%- for variant in product.variants -%}
              {%- if variant.options[size_option_index] == size_val and variant.available -%}
                {%- assign size_available = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            <li class="product-card__size-pill{% unless size_available %} product-card__size-pill--oos{% endunless %}">
              {{ size_val }}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    {%- endif -%}

    <div class="product-card__actions">
      {%- if quick_add_mode != nil -%}
        {%- if quick_add_mode == 'add' -%}
          <button
            class="product-card__action product-card__action--primary"
            data-quick-add
            data-variant-id="{{ quick_add_variant.id }}"
            aria-label="Add {{ product.title | escape }} to bag"
            type="button"
          >Quick add</button>
        {%- elsif quick_add_mode == 'soldout' -%}
          <button
            class="product-card__action product-card__action--primary"
            disabled
            aria-disabled="true"
            type="button"
          >Sold out</button>
        {%- else -%}
          <a
            href="{{ product.url }}"
            class="product-card__action product-card__action--primary"
            aria-label="Select options for {{ product.title | escape }}"
          >Select options</a>
        {%- endif -%}
      {%- endif -%}

      <a
        href="{{ product.url }}"
        class="product-card__action product-card__action--secondary"
        aria-label="Quick shop {{ product.title | escape }}"
      >Quick shop</a>
    </div>

    <a href="{{ product.url }}" class="product-card__title-link">
      <p class="product-card__title">{{ product.title }}</p>
    </a>

    {%- comment -%} Price {%- endcomment -%}
    <div class="product-card__price-row" aria-label="Price">
      {%- if is_on_sale -%}
        <s class="price--compare">{{ product.compare_at_price | money }}</s>
        <span class="price--sale">{{ product.price | money }}</span>
      {%- elsif is_sold_out -%}
        <span class="price--sold-out">{{ product.price | money }}</span>
      {%- elsif product.price_varies -%}
        <span class="product-card__price">From {{ product.price_min | money }}</span>
      {%- else -%}
        <span class="product-card__price">{{ product.price | money }}</span>
      {%- endif -%}
    </div>

    {%- comment -%} Star rating (native Shopify metafields — compatible with Judge.me / Okendo / Yotpo) {%- endcomment -%}
    {%- assign pc_rating = product.metafields.reviews.rating.value -%}
    {%- assign pc_count  = product.metafields.reviews.rating_count.value -%}
    {%- if pc_rating != blank and pc_count != blank and pc_count > 0 -%}
      <div class="product-card__rating" aria-label="{{ pc_rating | round: 1 }} out of 5 stars">
        <svg class="product-card__rating-star" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" focusable="false" width="10" height="10">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/>
        </svg>
        <span class="product-card__rating-value">{{ pc_rating | round: 1 }}</span>
        <span class="product-card__rating-count">({{ pc_count }})</span>
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
  /* ══════════════════════════════════════════════════════════
     Product Card — luxury fashion editorial
     Portrait 3:4 · breath-in hover · glass quick-add
     ══════════════════════════════════════════════════════════ */

  /* ── Card shell ─────────────────────────────────────────── */
  .product-card {
    display: flex;
    flex-direction: column;
    transition: transform var(--duration-base) var(--ease-default);
  }

  .product-card:hover {
    transform: translateY(-3px);
  }

  /* ── Media ──────────────────────────────────────────────── */
  .product-card__media {
    position: relative;
    aspect-ratio: var(--card-ratio, 3/4);
    overflow: hidden;
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 1.1rem;
    box-shadow: var(--shadow-soft);
  }

  .product-card__media-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* ── Images ─────────────────────────────────────────────── */
  .product-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  /* Primary — slow Ken Burns; suppressed once hover image exists */
  .product-card__img--primary {
    z-index: 1;
    transition:
      opacity   500ms var(--ease-brand, var(--ease-default)),
      transform 500ms var(--ease-brand, var(--ease-out));
  }

  .product-card:hover .product-card__img--primary {
    transform: scale(1.035);
  }

  .product-card:has(.product-card__img--hover):hover .product-card__img--primary {
    transform: scale(1.02);
    opacity: 0;
  }

  /* Hover/secondary — starts zoomed, breathes in to natural size as it reveals */
  .product-card__img--hover {
    z-index: 2;
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity   500ms               var(--ease-brand, var(--ease-default)),
      transform var(--duration-measured) var(--ease-brand, var(--ease-out));
  }

  .product-card:has(.product-card__img--hover):hover .product-card__img--hover {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Placeholder ─────────────────────────────────────────── */
  .product-card__no-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg-subtle);
  }

  .product-card__placeholder-svg {
    width: 55%;
    height: 55%;
    opacity: 0.14;
  }

  /* ── Sold-out veil ───────────────────────────────────────── */
  .product-card--sold-out .product-card__media::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 3;
    background-color: color-mix(in srgb, var(--color-bg) 20%, transparent);
    pointer-events: none;
  }

  /* ── Badge ──────────────────────────────────────────────── */
  .product-card__badge {
    position: absolute;
    top: var(--space-4);
    z-index: 5;
    padding: 2px var(--space-3);
    font-family: var(--font-body);
    font-size: 0.5625rem;
    font-style: normal;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    line-height: 1.8;
    pointer-events: none;
    white-space: nowrap;
  }

  /* Custom — left, dark stamp */
  .product-card__badge--custom {
    left: var(--space-4);
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  /* Sale — left, gold-tinted minimal stamp */
  .product-card__badge--sale {
    left: var(--space-4);
    background-color: transparent;
    color: var(--color-gold);
    outline: 1px solid color-mix(in srgb, var(--color-gold) 45%, transparent);
    outline-offset: -1px;
  }

  /* Sold-out — right, very subtle */
  .product-card__badge--sold-out {
    right: var(--space-4);
    background-color: transparent;
    color: var(--color-text);
    outline: 1px solid color-mix(in srgb, var(--color-text) 20%, transparent);
    outline-offset: -1px;
  }

  /* ── Info block ─────────────────────────────────────────── */
  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-block: var(--space-4) var(--space-2);
    padding-inline: 2px;
  }

  /* ── Vendor ─────────────────────────────────────────────── */
  .product-card__vendor {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.2;
  }

  /* ── Title ──────────────────────────────────────────────── */
  .product-card__title-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .product-card__title {
    font-family: var(--font-body);
    font-size: clamp(var(--text-sm), 1vw, var(--text-base));
    font-style: normal;
    font-weight: 500;
    line-height: 1.45;
    letter-spacing: 0.01em;
    margin: 0;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 0% 1px;
    background-repeat: no-repeat;
    background-position: left bottom 1px;
    transition: background-size var(--duration-measured, 600ms) var(--ease-brand, var(--ease-out));
  }

  .product-card__title-link:hover .product-card__title {
    background-size: 100% 1px;
  }

  /* ── Price ──────────────────────────────────────────────── */
  .product-card__price-row {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    column-gap: var(--space-3);
    row-gap: var(--space-1);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-normal);
    margin-block-start: 0;
    color: var(--color-text-secondary);
  }

  .product-card__price {
    color: var(--color-text-secondary);
  }

  /* ── Rating star ─────────────────────────────────────────── */
  .product-card__rating-star {
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .product-card__rating-value {
    font-size: var(--text-xs);
    font-style: normal;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
  }

  .product-card__rating-count {
    font-size: var(--text-xs);
    font-style: normal;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
  }

  /* Scoped overrides — keep global theme.css definitions, refine here */
  .product-card__price-row .price--compare {
    opacity: 0.5;
    text-decoration-thickness: 1px;
  }

  .product-card__price-row .price--sale {
    color: var(--color-gold);
  }

  .product-card__price-row .price--sold-out {
    color: var(--color-text-muted);
    opacity: 0.42;
  }

  /* ── Size pills ─────────────────────────────────────────── */
  .product-card__sizes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .product-card__size-pill {
    font-size: 0.625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0;
    border: none;
    background: none;
    line-height: 1.5;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .product-card__size-pill--oos {
    opacity: 0.22;
    text-decoration: line-through;
    text-decoration-thickness: 1px;
  }

  .product-card__actions {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
  }

  .product-card__action {
    flex: 1;
    min-height: 2.65rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 0.8rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background-color: color-mix(in srgb, var(--color-bg) 84%, white);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 0.625rem;
    font-style: normal;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-align: center;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
    transition:
      background-color var(--duration-fast) var(--ease-default),
      border-color var(--duration-fast) var(--ease-default),
      color var(--duration-fast) var(--ease-default),
      transform var(--duration-fast) var(--ease-default);
  }

  .product-card__action:hover:not([disabled]):not([aria-disabled="true"]) {
    transform: translateY(-1px);
  }

  .product-card__action:only-child {
    flex-basis: 100%;
  }

  .product-card__action--primary {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: #F8F4EA;
  }

  .product-card__action--primary:hover:not([disabled]):not([aria-disabled="true"]) {
    background-color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: #F8F4EA;
  }

  .product-card__action--secondary:hover {
    border-color: color-mix(in srgb, var(--color-gold) 46%, var(--color-border));
    background-color: color-mix(in srgb, var(--color-gold) 8%, white);
  }

  .product-card__action[disabled],
  .product-card__action[aria-disabled="true"] {
    opacity: 0.38;
    cursor: default;
  }

  /* ── Rating ─────────────────────────────────────────────── */
  .product-card__rating {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-block-start: 0;
  }

  .product-card__rating-star {
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .product-card__rating-value {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
  }

  .product-card__rating-count {
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-muted);
  }

  /* ── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 48rem) {
    .product-card__info {
      padding-block: var(--space-4) var(--space-3);
    }

    .product-card__title {
      font-size: var(--text-base);
    }

    .product-card__price-row {
      font-size: var(--text-xs);
    }

    .product-card__actions {
      flex-direction: column;
    }
  }
{% endstylesheet %}
