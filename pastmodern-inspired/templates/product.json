{
  "sections": {
    "product-main": {
      "type": "product-main",
      "settings": {
        "show_breadcrumbs": true,
        "show_quantity": false,
        "show_dynamic_checkout": true,
        "sticky_atc_mobile": true,
        "atc_label": "Add to bag",
        "sold_out_label": "Sold out",
        "delivery_text": "3–5 business days",
        "shipping_text": "Complimentary on orders over $200",
        "return_text": "Complimentary returns within 30 days"
      }
    },
    "product-accordion": {
      "type": "product-accordion",
      "blocks": {
        "description": {
          "type": "description",
          "settings": {
            "heading": "Description",
            "open_by_default": true
          }
        },
        "fabric": {
          "type": "fabric",
          "settings": {
            "heading": "Fabric & Materials",
            "open_by_default": false
          }
        },
        "care": {
          "type": "care",
          "settings": {
            "heading": "Care",
            "open_by_default": false
          }
        },
        "fit": {
          "type": "fit",
          "settings": {
            "heading": "Fit & Sizing",
            "open_by_default": false
          }
        },
        "shipping": {
          "type": "shipping",
          "settings": {
            "heading": "Shipping",
            "open_by_default": false
          }
        },
        "returns": {
          "type": "returns",
          "settings": {
            "heading": "Returns & Exchanges",
            "open_by_default": false
          }
        }
      },
      "block_order": [
        "description",
        "fabric",
        "care",
        "fit",
        "shipping",
        "returns"
      ],
      "settings": {}
    }
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You May Also Like",
        "products_to_show": 4,
        "recommendation_intent": "related"
      }
    }
  },
  "order": [
    "product-main",
    "product-accordion",
    "related-products"
  ]
}
